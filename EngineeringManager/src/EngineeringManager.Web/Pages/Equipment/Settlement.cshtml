@page
@model EngineeringManager.Web.Pages.Equipment.SettlementModel
@{ ViewData["Title"] = "设备最终结算"; }
<section class="page-heading"><div><p class="eyebrow">在线核心操作</p><h1>设备最终结算</h1><p class="page-lead">退场且日期全部分类后才能结算；修改会保留前后快照与原因。</p></div></section><form method="post" class="panel form-grid">
    <section class="form-section"><h2 class="section-heading">结算信息</h2><p class="section-help">租金和应付属于在线核心数据，不进入离线缓存。</p><label>使用记录 ID<input asp-for="UsageId" required /></label><label>结算日期<input asp-for="SettlementDate" type="date" /></label><label class="checkbox-field"><input asp-for="GeneratePayable" /> 同时生成应付</label><label class="form-span">备注<textarea asp-for="Notes" rows="4"></textarea></label><label class="form-span">修改原因<input asp-for="Reason" required /></label></section>
    <div class="sticky-actions form-span"><button class="button button--primary">确认最终结算</button></div>
</form>@if(Model.Result is not null){<section class="metric-grid"><article class="metric-card"><span class="metric-label">基础租金</span><strong class="metric-value">@Model.Result.BaseAmount.ToString("N2")</strong></article><article class="metric-card"><span class="metric-label">抵扣后应付</span><strong class="metric-value">@Model.Result.PayableAmount.ToString("N2")</strong></article></section>}
