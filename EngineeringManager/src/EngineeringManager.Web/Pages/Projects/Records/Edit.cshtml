@page "/Projects/Records/Edit"
@model EngineeringManager.Web.Pages.Projects.Records.EditModel
@using EngineeringManager.Application.Projects
@using EngineeringManager.Application.Finance
@using EngineeringManager.Domain.Finance
@{ var title = Model.Section switch { "collection" => "收款明细", "invoice" => "开票明细", "payment" => "付款明细", "construction" => "施工详情", _ => "业务明细" }; ViewData["Title"] = title + "详细编辑"; }
@if (Model.Workspace is not null)
{
    <section class="page-heading"><div><p class="eyebrow">@Model.Workspace.Overview.ProjectNumber</p><h1>@title 详细编辑</h1><p class="page-lead">本页面仅管理当前项目的 @title，不包含项目总览字段。</p></div><div class="button-row"><a class="button button--secondary" asp-page="/Projects/Details" asp-route-id="@Model.ProjectId" asp-route-tab="@Model.Section">返回项目</a>@if (Model.Section == "collection") { <a class="button button--primary" asp-page="/Finance/Entries/Create" asp-route-EntryKind="@FinanceEntryKind.Receivable" asp-route-ProjectId="@Model.ProjectId">新增应收或收款</a> } else if (Model.Section == "invoice") { <a class="button button--primary" asp-page="/Ledger/Entries/Edit" asp-route-scope="@LedgerScope.External" asp-route-recordType="@FinanceRecordType.Invoice" asp-route-direction="@LedgerDirection.Receivable" asp-route-projectId="@Model.ProjectId">新增发票</a> } else if (Model.Section == "payment") { <a class="button button--primary" asp-page="/Finance/Entries/Create" asp-route-EntryKind="@FinanceEntryKind.Payable" asp-route-ProjectId="@Model.ProjectId">新增应付或付款</a> } }</div></section>
    @if (Model.Section == "construction")
    {
        <section class="panel construction-detail-create"><div class="panel-heading"><div><h2>新增施工记录</h2><p>新增后即可在本页编辑并上传附件。</p></div></div><div class="content-grid">
            <form method="post" asp-page-handler="Construction" class="form-stack"><input type="hidden" name="ProjectId" value="@Model.ProjectId" /><input type="hidden" name="Section" value="construction" /><input type="hidden" name="ConstructionEdit.RecordType" value="Equipment" /><label>施工机械<select name="ConstructionEdit.SubjectId" required><option value="">请选择</option>@foreach (var option in Model.Construction.Equipment) { <option value="@option.Id">@option.Label</option> }</select></label><label>进场日期<input type="date" name="ConstructionEdit.EntryDate" /></label><label>退场日期<input type="date" name="ConstructionEdit.ExitDate" /></label><label>停工天数<input type="number" min="0" name="ConstructionEdit.StopDays" value="0" /></label><label>备注<input name="ConstructionEdit.Notes" /></label><label class="checkbox-row"><input type="checkbox" name="ConstructionEdit.ShowInProjectOverview" value="true" />显示在项目总览</label><input type="hidden" name="ConstructionEdit.Reason" value="施工详情页新增机械记录" /><button class="button button--primary" type="submit">新增机械记录</button></form>
            <form method="post" asp-page-handler="Construction" class="form-stack"><input type="hidden" name="ProjectId" value="@Model.ProjectId" /><input type="hidden" name="Section" value="construction" /><input type="hidden" name="ConstructionEdit.RecordType" value="ConstructionCrew" /><label>施工班组<select name="ConstructionEdit.SubjectId" required><option value="">请选择</option>@foreach (var option in Model.Construction.Crews) { <option value="@option.Id">@option.Label</option> }</select></label><label>进场日期<input type="date" name="ConstructionEdit.EntryDate" /></label><label>退场日期<input type="date" name="ConstructionEdit.ExitDate" /></label><label>停工天数<input type="number" min="0" name="ConstructionEdit.StopDays" value="0" /></label><label>备注<input name="ConstructionEdit.Notes" /></label><input type="hidden" name="ConstructionEdit.Reason" value="施工详情页新增班组记录" /><button class="button button--primary" type="submit">新增班组记录</button></form>
        </div></section>
    }
    <section class="panel record-editor-list">
    @if (Model.Section == "collection")
    {
        @foreach (var row in Model.Workspace.Receivables) { <article class="record-business-editor"><h2>应收 @row.EntryDate · @row.Amount.ToString("N2")</h2><partial name="_FinanceRecordEditor" model="@(FinanceRecordEditorViewModel.From(Model.ProjectId, row))" /><partial name="_RecordAttachmentEditor" model="@(new RecordAttachmentEditorViewModel(Model.ProjectId, Model.Section, ProjectRecordAttachmentType.Settlement, row.Id, $"应收附件", Model.Attachments.GetValueOrDefault(row.Id) ?? []))" /></article> }
        @foreach (var row in Model.Workspace.Collections) { <article class="record-business-editor"><h2>收款 @row.CollectionDate · @row.Amount.ToString("N2")</h2><partial name="_FinanceRecordEditor" model="@(FinanceRecordEditorViewModel.From(Model.ProjectId, row))" /><partial name="_RecordAttachmentEditor" model="@(new RecordAttachmentEditorViewModel(Model.ProjectId, Model.Section, ProjectRecordAttachmentType.Cash, row.Id, $"收款附件", Model.Attachments.GetValueOrDefault(row.Id) ?? []))" /></article> }
    }
    else if (Model.Section == "invoice")
    {
        @foreach (var row in Model.Workspace.Invoices) { <article class="record-business-editor"><h2>发票 @row.InvoiceNumber · @row.GrossAmount.ToString("N2")</h2><partial name="_FinanceRecordEditor" model="@(FinanceRecordEditorViewModel.From(Model.ProjectId, row))" /><partial name="_RecordAttachmentEditor" model="@(new RecordAttachmentEditorViewModel(Model.ProjectId, Model.Section, ProjectRecordAttachmentType.Invoice, row.Id, "发票附件", Model.Attachments.GetValueOrDefault(row.Id) ?? []))" /></article> }
    }
    else if (Model.Section == "payment")
    {
        @foreach (var row in Model.Workspace.Payables) { <article class="record-business-editor"><h2>应付 @row.EntryDate · @row.Amount.ToString("N2")</h2><partial name="_FinanceRecordEditor" model="@(FinanceRecordEditorViewModel.From(Model.ProjectId, row))" /><partial name="_RecordAttachmentEditor" model="@(new RecordAttachmentEditorViewModel(Model.ProjectId, Model.Section, ProjectRecordAttachmentType.Settlement, row.Id, "应付附件", Model.Attachments.GetValueOrDefault(row.Id) ?? []))" /></article> }
        @foreach (var row in Model.Workspace.Payments.Where(item => item.SourceType == "FinancePayment")) { <article class="record-business-editor"><h2>付款 @row.PaymentDate · @row.Amount.ToString("N2")</h2><partial name="_FinanceRecordEditor" model="@(FinanceRecordEditorViewModel.From(Model.ProjectId, row))" /><partial name="_RecordAttachmentEditor" model="@(new RecordAttachmentEditorViewModel(Model.ProjectId, Model.Section, ProjectRecordAttachmentType.Cash, row.Id, "付款附件", Model.Attachments.GetValueOrDefault(row.Id) ?? []))" /></article> }
    }
    else if (Model.Section == "construction")
    {
        @foreach (var row in Model.Construction.Records) { <article class="record-business-editor"><h2>@row.SubjectLabel · @row.EntryDate 至 @row.ExitDate</h2><partial name="_ConstructionRecordEditor" model="@row" /><partial name="_RecordAttachmentEditor" model="@(new RecordAttachmentEditorViewModel(Model.ProjectId, Model.Section, ProjectRecordAttachmentType.Construction, row.Id, "施工附件", Model.Attachments.GetValueOrDefault(row.Id) ?? []))" /></article> }
    }
    </section>
}
