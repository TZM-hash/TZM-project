@page
@model EngineeringManager.Web.Pages.Finance.AccountsModel
@{
    ViewData["Title"] = "资金账户";
}

<section class="page-heading"><div><p class="eyebrow">内部账户</p><h1>资金账户</h1><p class="page-lead">账户余额由期初余额和业务流水自动计算，收付款、退款、冲销和内部转账不会直接手改余额。</p></div><a class="button button--secondary" asp-page="/Projects/Index">返回项目管理</a></section>

<section class="panel">
    <div class="panel-heading"><div><p class="eyebrow">新建账户</p><h2>账户资料</h2></div></div>
    <div asp-validation-summary="All" class="panel-copy"></div>
    <form method="post" class="form-grid" data-financial-account-editor>
        <section class="form-section"><h3 class="section-heading">账户归属</h3><label>签约公司<select asp-for="LegalEntityId"><option value="">请选择</option>@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.Label</option> }</select></label><label>账户名称<input asp-for="AccountName" /></label><label>账户类型<select asp-for="AccountType" data-account-type><option value="1">银行账户</option><option value="2">现金账户</option><option value="3">其他账户</option><option value="4">个人垫付账户</option></select></label></section>
        <section class="form-section"><h3 class="section-heading">开户与期初数据</h3><label>期初余额<input asp-for="OpeningBalance" type="number" step="0.01" /></label><label>开户行<input asp-for="BankName" /></label><label>账号<input asp-for="AccountNumber" /></label></section>
        <section class="form-section form-span personal-account-fields" data-personal-account-fields hidden><h3 class="section-heading">个人垫付资料</h3><div class="form-grid"><label>实际付款人<input asp-for="OwnerName" data-personal-owner-name /></label><label>关联员工（可选）<select asp-for="OwnerEmployeeId"><option value="">非员工个人</option>@foreach (var employee in Model.Employees) { <option value="@employee.Id">@employee.Label</option> }</select></label></div></section>
        <div class="sticky-actions form-span"><button class="button button--secondary" type="submit">保存账户</button></div>
    </form>
</section>

<section class="panel page-section">
    <div class="panel-heading"><div><p class="eyebrow">账户清单</p><h2>当前余额</h2></div></div>
    <div class="table-wrap"><table class="data-table"><thead><tr><th>签约公司</th><th>账户</th><th>类型</th><th>实际付款人</th><th>关联员工</th><th>期初余额</th><th>当前余额</th><th>累计垫付</th><th>已归还</th><th>未归还</th><th>状态</th></tr></thead><tbody>
    @foreach (var item in Model.Accounts)
    {
        <tr class="@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? "is-personal-advance" : null)"><td>@item.LegalEntityName</td><td>@item.AccountName</td><td>@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? "个人垫付账户" : item.AccountType.ToString())</td><td>@(item.OwnerName ?? "-")</td><td>@(item.OwnerEmployeeId.HasValue ? Model.Employees.FirstOrDefault(employee => employee.Id == item.OwnerEmployeeId)?.Label ?? "历史员工" : "-")</td><td>@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? "-" : item.OpeningBalance.ToString("N2"))</td><td>@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? "个人垫付往来" : item.CurrentBalance.ToString("N2"))</td><td>@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? item.AdvancedAmount.ToString("N2") : "-")</td><td>@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? item.RepaidAmount.ToString("N2") : "-")</td><td>@(item.AccountType == EngineeringManager.Domain.Finance.FinancialAccountType.PersonalAdvance ? item.OutstandingAmount.ToString("N2") : "-")</td><td>@(item.IsActive ? "启用" : "停用")</td></tr>
    }
    </tbody></table></div>
</section>
