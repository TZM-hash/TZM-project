@page
@model EngineeringManager.Web.Pages.Finance.Entries.CreateModel
@{
    ViewData["Title"] = "录入财务业务";
}

<section class="page-heading"><div><p class="eyebrow">项目经营录入</p><h1>录入经营数据</h1><p class="page-lead">先选择业务类型，再填写对应字段。收付款会自动生成账户流水；退款、冲销和内部转账使用独立记录保存完整修改痕迹。</p></div><a class="button button--secondary" asp-page="/Projects/Index">返回项目管理</a></section>

<form method="post" class="panel form-grid">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="All" class="panel-copy form-span"></div>
    <section class="form-section"><h2 class="section-heading">业务归属</h2><label>业务类型<select asp-for="EntryKind" asp-items="Html.GetEnumSelectList<EngineeringManager.Application.Finance.FinanceEntryKind>()"></select></label><label>业务日期<input asp-for="EntryDate" type="date" /></label><label>项目<select asp-for="ProjectId" data-finance-project-select><option value="">请选择</option>@foreach (var item in Model.Options.Projects) { <option value="@item.Id">@item.Label</option> }</select></label><label>合同<select asp-for="ContractId"><option value="">可不选</option>@foreach (var item in Model.Options.Contracts) { <option value="@item.Id">@item.Label</option> }</select></label><label>开票公司/签约公司<select asp-for="LegalEntityId" data-project-scoped-select><option value="">请选择</option>@foreach (var item in Model.Options.ProjectLegalEntities ?? []) { <option value="@item.Id" data-project-id="@item.ParentId">@item.Label</option> }</select></label><label>合作单位<select asp-for="BusinessPartnerId"><option value="">按业务需要选择</option>@foreach (var item in Model.Options.BusinessPartners) { <option value="@item.Id">@item.Label</option> }</select></label></section>
    <section class="form-section"><h2 class="section-heading">账户与关联记录</h2><label>主账户<select asp-for="AccountId"><option value="">按业务需要选择</option>@foreach (var item in Model.Options.Accounts) { <option value="@item.Id">@item.Label</option> }</select></label><label>转入账户<select asp-for="SecondaryAccountId"><option value="">仅内部转账填写</option>@foreach (var item in Model.Options.Accounts) { <option value="@item.Id">@item.Label</option> }</select></label><label>关联原记录<select asp-for="RelatedEntryId"><option value="">按业务需要选择</option><optgroup label="应收记录">@foreach (var item in Model.Options.Receivables) { <option value="@item.Id">@item.Label</option> }</optgroup><optgroup label="应付记录">@foreach (var item in Model.Options.Payables) { <option value="@item.Id">@item.Label</option> }</optgroup><optgroup label="收款记录">@foreach (var item in Model.Options.Collections) { <option value="@item.Id">@item.Label</option> }</optgroup><optgroup label="付款记录">@foreach (var item in Model.Options.Payments) { <option value="@item.Id">@item.Label</option> }</optgroup></select></label><label>到期日<input asp-for="DueDate" type="date" /></label></section>
    <section class="form-section"><h2 class="section-heading">金额与发票</h2><label>含税/业务金额<input asp-for="Amount" type="number" step="0.01" /></label><label>支付方式<select asp-for="PaymentMethod" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Finance.PaymentMethod>()"></select></label><label>发票方向<select asp-for="InvoiceDirection" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Finance.InvoiceDirection>()"></select></label><label>发票号码<input asp-for="InvoiceNumber" /></label><label>税率与发票类型<select asp-for="ProjectTaxConfigurationId" data-project-scoped-select><option value="">请选择</option>@foreach (var item in Model.Options.ProjectTaxConfigurations ?? []) { <option value="@item.Id" data-project-id="@item.ParentId">@item.Label</option> }</select></label><label>不含税金额<input asp-for="NetAmount" type="number" step="0.01" /></label><label>税额<input asp-for="TaxAmount" type="number" step="0.01" /></label><label class="form-span">备注/原因<textarea asp-for="Description" rows="3"></textarea></label><p class="panel-copy form-span">发票必须先选择项目允许的税率与发票类型；退款、冲销和内部转账按原记录关联。</p></section>
    <div class="sticky-actions form-span"><button class="button button--secondary" type="submit">保存业务记录</button></div>
</form>
