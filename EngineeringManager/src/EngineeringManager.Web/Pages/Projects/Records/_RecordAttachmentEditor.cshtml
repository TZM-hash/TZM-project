@model EngineeringManager.Web.Pages.Projects.Records.RecordAttachmentEditorViewModel
<article class="record-attachment-editor" id="record-@Model.RecordId"><div><h2>@Model.Title</h2><span>@Model.Attachments.Count 个附件</span></div><div class="record-attachments">@foreach (var file in Model.Attachments) { <span><a asp-page-handler="Attachment" asp-route-projectId="@Model.ProjectId" asp-route-section="@Model.Section" asp-route-attachmentId="@file.Id">@file.OriginalFileName</a><form method="post" asp-page-handler="DeleteAttachment" class="inline-form"><input type="hidden" name="ProjectId" value="@Model.ProjectId" /><input type="hidden" name="Section" value="@Model.Section" /><input type="hidden" name="attachmentId" value="@file.Id" /><button class="button button--ghost button--small" type="submit">删除</button></form></span> }<form method="post" enctype="multipart/form-data" asp-page-handler="Attachment" class="inline-form"><input type="hidden" name="ProjectId" value="@Model.ProjectId" /><input type="hidden" name="Section" value="@Model.Section" /><input type="hidden" name="RecordType" value="@Model.RecordType" /><input type="hidden" name="RecordId" value="@Model.RecordId" /><input type="file" name="AttachmentFile" required /><input name="AttachmentDescription" placeholder="附件说明" /><button class="button button--secondary button--small" type="submit">上传附件</button></form></div></article>
