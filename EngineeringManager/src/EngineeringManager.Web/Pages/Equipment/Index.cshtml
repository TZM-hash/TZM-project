@page
@using EngineeringManager.Domain.Equipment
@model EngineeringManager.Web.Pages.Equipment.IndexModel
@{ ViewData["Title"] = "设备管理"; }
<div data-equipment-dashboard>
    <section class="page-heading"><div><p class="eyebrow">设备与项目协同</p><h1>设备管理</h1><p class="page-lead">逐台管理自有和租赁设备、项目使用、施工/停工日期、租金及最终结算。</p></div><div class="button-row">@if(Model.CanManage){<a class="button button--primary" asp-page="Edit">新增设备</a>}<a class="button button--secondary" asp-page="Offline">现场离线记录</a></div></section>
    <form method="get" class="filter-bar"><label>关键字<input asp-for="Keyword" placeholder="编号、名称" /></label><label>状态<select asp-for="Status"><option value="">全部</option>@foreach(var value in Enum.GetValues<EquipmentStatus>()){<option value="@value">@value</option>}</select></label><button class="button button--secondary">筛选</button></form>
    <section class="metric-grid" aria-label="设备指标"><article class="metric-card"><span class="metric-label">设备总数</span><strong class="metric-value">@Model.Dashboard.TotalCount</strong></article><article class="metric-card"><span class="metric-label">使用中</span><strong class="metric-value">@Model.Dashboard.InUseCount</strong></article><article class="metric-card"><span class="metric-label">租赁设备</span><strong class="metric-value">@Model.Dashboard.RentedCount</strong></article><article class="metric-card"><span class="metric-label">已结算金额</span><strong class="metric-value">@Model.Dashboard.SettledAmount.ToString("N2")</strong></article></section>
    <section class="dashboard-grid"><article class="panel"><div class="panel-heading"><div><p class="eyebrow">状态分布</p><h2>设备状态</h2></div></div><div class="comparison-chart">@foreach(var item in Model.Dashboard.StatusDistribution){<div class="comparison-row"><div class="chart-label"><strong>@item.Key</strong><span>@item.Value 台</span></div></div>}</div></article><article class="panel"><div class="panel-heading"><div><p class="eyebrow">逐台档案</p><h2>设备列表</h2></div></div><div class="table-wrap"><table><thead><tr><th>编号</th><th>名称</th><th>型号</th><th>权属</th><th>状态</th><th>操作</th></tr></thead><tbody>@foreach(var item in Model.Dashboard.Items){<tr><td>@item.EquipmentNumber</td><td><a asp-page="Details" asp-route-id="@item.Id">@item.Name</a></td><td>@item.Model</td><td>@item.OwnershipType</td><td>@item.Status</td><td><a asp-page="Edit" asp-route-copyFrom="@item.Id">复制</a> · <a asp-page="Usage" asp-route-equipmentId="@item.Id">进退场</a></td></tr>}</tbody></table></div></article></section>
</div>
