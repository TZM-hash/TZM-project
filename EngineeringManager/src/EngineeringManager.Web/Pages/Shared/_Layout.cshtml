@using EngineeringManager.Application.Settings
@inject ISystemSettingsService SystemSettingsService
@{
    var displaySettings = await SystemSettingsService.GetAsync(Context.RequestAborted);
    var currentPage = Context.Request.Path.Value ?? string.Empty;
    string Nav(string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) ? "nav-link is-active" : "nav-link";
    string NavExact(string path) => string.Equals(currentPage.TrimEnd('/'), path.TrimEnd('/'), StringComparison.OrdinalIgnoreCase) ? "nav-link is-active" : "nav-link";
    string? ParentPage()
    {
        var returnUrl = Context.Request.Query["ReturnUrl"].FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(returnUrl) && returnUrl.StartsWith('/') && !returnUrl.StartsWith("//")) return returnUrl;
        if (currentPage.StartsWith("/Projects/", StringComparison.OrdinalIgnoreCase)) return "/Projects";
        if (currentPage.StartsWith("/Finance/", StringComparison.OrdinalIgnoreCase)) return "/Ledger/External";
        if (currentPage.StartsWith("/Ledger/", StringComparison.OrdinalIgnoreCase)) return "/Ledger/External";
        if (currentPage.StartsWith("/Employees/Certificates/Edit", StringComparison.OrdinalIgnoreCase)) return "/Employees/Certificates";
        if (currentPage.StartsWith("/Employees/", StringComparison.OrdinalIgnoreCase)) return "/Employees";
        if (currentPage.StartsWith("/Payroll/", StringComparison.OrdinalIgnoreCase)) return "/Payroll";
        if (currentPage.StartsWith("/Crews/", StringComparison.OrdinalIgnoreCase)) return "/Crews";
        if (currentPage.StartsWith("/Partners/", StringComparison.OrdinalIgnoreCase)) return "/Partners";
        if (currentPage.StartsWith("/Companies/Certificates/Edit", StringComparison.OrdinalIgnoreCase)) return "/Companies/Certificates";
        if (currentPage.StartsWith("/Companies/", StringComparison.OrdinalIgnoreCase)) return "/Companies";
        if (currentPage.StartsWith("/Equipment/", StringComparison.OrdinalIgnoreCase)) return "/Equipment";
        if (currentPage.StartsWith("/StageResults/", StringComparison.OrdinalIgnoreCase)) return "/Projects";
        if (currentPage.StartsWith("/Admin/", StringComparison.OrdinalIgnoreCase) || currentPage.StartsWith("/Backups", StringComparison.OrdinalIgnoreCase)) return "/Admin";
        return null;
    }
    var parentPage = ParentPage();
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2563eb" />
    <title>@ViewData["Title"] - 工程项目经营管理系统</title>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
</head>
<body class="app-shell @displaySettings.ThemeCssClass @displaySettings.MotionCssClass @displaySettings.EffectsCssClass @displaySettings.FontCssClass @displaySettings.DensityCssClass">
    <div class="app-bg-fx" aria-hidden="true"><span></span><span></span><span></span></div>
    <aside class="app-sidebar" id="primary-nav" data-navigation>
        <a class="app-sidebar-brand" asp-page="/Index"><span class="brand-mark" aria-hidden="true">工</span><span>工程项目经营管理系统</span></a>
        <nav class="app-sidebar-nav" aria-label="主导航">
            <div class="nav-group"><span class="nav-group-label">经营总览</span><a class="@(currentPage == "/" ? "nav-link is-active" : "nav-link")" asp-page="/Index"><svg><use href="/img/icons.svg#home"></use></svg><span>系统总览</span></a></div>
            <div class="nav-group"><span class="nav-group-label">项目经营</span>
                <a class='@Nav("/Projects")' asp-page="/Projects/Index"><svg><use href="/img/icons.svg#projects"></use></svg><span>项目管理</span></a>
            </div>
            @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator") || User.IsInRole("Finance") || User.IsInRole("QueryOnly"))
            {
                <details class="nav-group nav-disclosure" data-central-ledger-nav @(currentPage.StartsWith("/Ledger", StringComparison.OrdinalIgnoreCase) ? "open" : null)>
                    <summary class="nav-link"><svg><use href="/img/icons.svg#finance"></use></svg><span>中央账本</span><span class="nav-disclosure-chevron" aria-hidden="true">⌄</span></summary>
                    <div class="nav-submenu"><a class='@Nav("/Ledger/External")' asp-page="/Ledger/External/Index">外部账本</a><a class='@Nav("/Ledger/Internal")' asp-page="/Ledger/Internal/Index">内部账本</a></div>
                </details>
            }
            <div class="nav-group"><span class="nav-group-label">人员与合作方</span>
                <a class='@NavExact("/Employees")' asp-page="/Employees/Index"><svg><use href="/img/icons.svg#people"></use></svg><span>员工管理</span></a>
                <a class='@Nav("/Payroll")' asp-page="/Payroll/Index"><svg><use href="/img/icons.svg#finance"></use></svg><span>工资台账</span></a>
                <a class='@Nav("/Crews")' asp-page="/Crews/Index"><svg><use href="/img/icons.svg#partners"></use></svg><span>施工班组</span></a>
                <a class='@Nav("/Partners")' asp-page="/Partners/Index"><svg><use href="/img/icons.svg#partners"></use></svg><span>合作单位</span></a>
            </div>
            <div class="nav-group"><span class="nav-group-label">公司与设备</span>
                <a class='@NavExact("/Companies")' asp-page="/Companies/Index"><svg><use href="/img/icons.svg#company"></use></svg><span>自有公司</span></a>
                <a class='@Nav("/Companies/Certificates")' asp-page="/Companies/Certificates/Index"><svg><use href="/img/icons.svg#reminder"></use></svg><span>公司证书</span></a>
                <a class='@Nav("/Equipment")' asp-page="/Equipment/Index"><svg><use href="/img/icons.svg#equipment"></use></svg><span>设备管理</span></a>
            </div>
            <div class="nav-group"><span class="nav-group-label">数据与系统</span>
                <a class='@Nav("/DataExchange")' asp-page="/DataExchange/Index"><svg><use href="/img/icons.svg#exchange"></use></svg><span>导入导出</span></a>
                <a class='@Nav("/Reminders")' asp-page="/Reminders/Index"><svg><use href="/img/icons.svg#reminder"></use></svg><span>提醒中心</span></a>
                @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator"))
                {
                    <a class='@Nav("/Admin")' asp-page="/Admin/Index"><svg><use href="/img/icons.svg#settings"></use></svg><span>系统管理</span></a>
                }
            </div>
        </nav>
        <div class="sidebar-footer"><span class="status-dot" aria-hidden="true"></span><span>阶段 0～10 已完成 · 体验优化迭代</span></div>
    </aside>
    <div class="app-content">
        <header class="app-header">
            <div class="app-header-content">
                <button class="menu-toggle" type="button" aria-expanded="true" aria-controls="primary-nav" data-menu-toggle><span class="sr-only">收起或打开导航菜单</span><svg aria-hidden="true"><use href="/img/icons.svg#menu"></use></svg></button>
                <div class="app-header-title"><span>@ViewData["Title"]</span><small data-network-status>在线</small></div>
                <div class="app-header-tools"><a class="header-icon-button" asp-page="/Reminders/Index" aria-label="提醒中心"><svg><use href="/img/icons.svg#reminder"></use></svg></a><partial name="_LoginPartial" /></div>
            </div>
        </header>
        <main class="main-content app-main" role="main">
            @if (parentPage is not null)
            {
                <nav class="page-parent-nav" aria-label="返回上级"><a class="button button--secondary button--back" href="@parentPage" data-smart-back>← 返回上级</a></nav>
            }
            @RenderBody()
        </main>
        <footer class="app-footer">工程项目经营管理系统 · 内部经营管理</footer>
    </div>
    <div class="toast-region" aria-live="polite" data-pwa-status></div>
    <dialog class="conflict-notice" data-conflict-notice aria-labelledby="conflict-notice-title">
        <div class="conflict-notice__icon" aria-hidden="true">!</div>
        <div><p class="eyebrow">数据已变化</p><h2 id="conflict-notice-title">当前记录存在冲突</h2><p data-conflict-message>其他用户或模块已更新这条数据，请刷新后核对最新内容。</p></div>
        <div class="conflict-notice__actions"><button class="button button--secondary" type="button" data-conflict-close>暂不刷新</button><button class="button button--primary" type="button" data-conflict-refresh>刷新页面</button></div>
    </dialog>
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
