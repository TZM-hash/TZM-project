                                <td><span data-inline-edit-value>@row.PaymentMethod.ToChinese()</span><select class="inline-cell-control" name="PaymentRowEdits[@editIndex].PaymentMethod" form="payment-batch-form" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<PaymentMethod>()) { <option value="@value" selected="@(value == row.PaymentMethod ? "selected" : null)">@value.ToChinese()</option> }</select></td>
                                <td class="record-attachment-column"><div class="record-attachment-tools">@if (Model.CanManageFinance) { <form method="post" enctype="multipart/form-data" asp-page-handler="RecordAttachment" asp-route-id="@item.Overview.Id" asp-route-recordType="@ProjectRecordAttachmentType.Cash" asp-route-recordId="@row.Id" asp-route-tab="payment" data-auto-upload-picker><input type="file" name="RecordAttachmentFile" required data-auto-upload-input hidden /><button class="button button--secondary button--small" type="button" data-auto-upload-trigger>@(Model.RecordAttachments.ContainsKey(row.Id) ? "替换" : "上传")</button></form> }@if (Model.RecordAttachments.TryGetValue(row.Id, out var paymentAttachment)) { <a class="button button--secondary button--small" asp-page-handler="RecordAttachment" asp-route-id="@item.Overview.Id" asp-route-attachmentId="@paymentAttachment.Id" target="_blank" rel="noopener" title="@paymentAttachment.OriginalFileName">预览</a>@if (Model.CanManageFinance) { <form method="post" asp-page-handler="DeleteRecordAttachment" asp-route-id="@item.Overview.Id" asp-route-recordType="@ProjectRecordAttachmentType.Cash" asp-route-recordId="@row.Id" asp-route-attachmentId="@paymentAttachment.Id" asp-route-tab="payment"><button class="button button--ghost button--small" type="submit">删除</button></form> } }</div></td>
                                <td class="quantity-notes-column">@if (string.IsNullOrWhiteSpace(row.Notes)) { <span data-inline-edit-value></span> } else { <span class="quantity-notes-value" data-inline-edit-value data-quantity-notes-anchor tabindex="0" aria-describedby="quantity-notes-comment"><span>@row.Notes</span><span data-quantity-notes-content hidden>@row.Notes</span></span> }@if (row.PayrollBatchId.HasValue) { <div><a asp-page="/Payroll/Edit" asp-route-id="@row.PayrollBatchId" asp-route-lineId="@row.PayrollPaymentId" asp-route-returnUrl="@Request.Path">查看来源批次</a></div> }<button class="quantity-notes-edit-trigger" type="button" data-quantity-notes-edit data-quantity-notes-title="编辑付款备注" data-inline-edit-actions hidden><span data-quantity-notes-button-text>@(string.IsNullOrWhiteSpace(row.Notes) ? "点击编辑备注" : row.Notes)</span></button><input type="hidden" name="PaymentRowEdits[@editIndex].Description" value="@row.Notes" form="payment-batch-form" data-quantity-notes-input hidden /><input type="hidden" name="PaymentRowEdits[@editIndex].Id" value="@row.Id" form="payment-batch-form" /><input type="hidden" name="PaymentRowEdits[@editIndex].RelatedEntryId" value="@row.PayableEntryId" form="payment-batch-form" /><input type="hidden" name="PaymentRowEdits[@editIndex].ConcurrencyStamp" value="@row.ConcurrencyStamp" form="payment-batch-form" /><input type="hidden" name="PaymentRowEdits[@editIndex].IsDirty" value="false" form="payment-batch-form" data-quantity-edit-dirty /></td>
                            </tr>
                        }
                        </tbody></table></div>
                    </article>
                    <article class="project-tab-panel project-tab-panel--construction inline-edit-shell" data-inline-edit="project-construction" data-inline-cell-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-construction" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>施工详情</h2><p>记录设备和施工班组的进退场、停工天数及项目流转。</p></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><form id="construction-batch-form" method="post" asp-page-handler="Constructions" asp-route-id="@item.Overview.Id" class="inline-form" data-inline-edit-actions hidden><button class="button button--primary button--action" type="submit">保存修改</button></form><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        @if (Model.CanManage)
                        {
                            <div class="construction-create-grid">
                                <details class="inline-create-details record-entry-details"><summary>新增施工记录</summary><form method="post" enctype="multipart/form-data" asp-page-handler="Construction" asp-route-id="@item.Overview.Id" class="inline-edit-panel collection-entry-compact-form">
                                    <div class="collection-entry-compact-grid">
                                        <div class="collection-entry-row collection-entry-row--1">
                                            <label class="collection-entry-compact-field">类型<select asp-for="ConstructionEdit.RecordType" data-construction-type><option value="1">设备</option><option value="2">施工班组</option></select></label>
                                            <label class="collection-entry-compact-field">设备/施工班组<select asp-for="ConstructionEdit.SubjectId"><option value="">请选择</option><optgroup label="设备">@foreach (var option in Model.ConstructionWorkspace.Equipment) { <option value="@option.Id">@option.Label</option> }</optgroup><optgroup label="施工班组">@foreach (var option in Model.ConstructionWorkspace.Crews) { <option value="@option.Id">@option.Label</option> }</optgroup></select></label>
                                            <label class="collection-entry-compact-field">进场日期<input asp-for="ConstructionEdit.EntryDate" type="date" /></label>
                                            <div class="quantity-entry-attachment collection-entry-attachment" data-attachment-picker>
                                                <div class="quantity-entry-attachment-heading"><strong>附件</strong></div>
                                                <div class="quantity-entry-attachment-control"><input type="file" name="RecordAttachmentFile" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" /><div class="quantity-entry-attachment-preview" data-attachment-preview><strong data-attachment-name hidden></strong><small data-attachment-size hidden></small><a data-attachment-preview-link target="_blank" rel="noopener" hidden>预览附件</a><img data-attachment-image alt="附件预览" hidden /></div></div>
                                            </div>
                                        </div>
                                        <div class="collection-entry-row collection-entry-row--2">
                                            <label class="collection-entry-compact-field">退场日期<input asp-for="ConstructionEdit.ExitDate" type="date" /></label>
                                            <label class="collection-entry-compact-field">停工天数<input asp-for="ConstructionEdit.StopDays" type="number" min="0" /></label>
                                            <label class="collection-entry-compact-field" data-construction-equipment-only><span>项目总览</span><span class="compact-check"><input asp-for="ConstructionEdit.ShowInProjectOverview" type="checkbox" /> 显示在项目总览</span></label>
                                            <label class="collection-entry-compact-field">修改原因<input asp-for="ConstructionEdit.Reason" /></label>
                                        </div>
                                        <div class="collection-entry-row collection-entry-row--3"><label class="collection-entry-compact-field collection-entry-compact-field--notes">备注<textarea asp-for="ConstructionEdit.Notes" placeholder="施工说明或补充备注"></textarea></label></div>
                                    </div>
                                    <div class="inline-edit-actions"><button type="button" class="button button--secondary button--action" data-inline-edit-cancel>取消</button><button class="button button--primary button--action" type="submit">新增记录</button></div>
                                </form></details>
                                <details class="inline-create-details"><summary>新建设备主档</summary><form method="post" asp-page-handler="CreateEquipment" asp-route-id="@item.Overview.Id" class="inline-edit-panel"><div class="inline-edit-grid"><label>设备编号<input asp-for="NewEquipment.EquipmentNumber" /></label><label>设备名称<input asp-for="NewEquipment.Name" /></label><label>型号<input asp-for="NewEquipment.Model" /></label><label>分类<input asp-for="NewEquipment.Category" /></label><label>权属<select asp-for="NewEquipment.OwnershipType" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Equipment.EquipmentOwnershipType>()"></select></label><label>所属公司（自有）<select asp-for="NewEquipment.OwnerLegalEntityId"><option value="">请选择</option>@foreach (var option in Model.FinanceOptions.LegalEntities) { <option value="@option.Id">@option.Label</option> }</select></label><label>出租方（租赁）<select asp-for="NewEquipment.LessorBusinessPartnerId"><option value="">请选择</option>@foreach (var option in Model.FinanceOptions.BusinessPartners) { <option value="@option.Id">@option.Label</option> }</select></label><label>内部日租金<input asp-for="NewEquipment.InternalDailyRate" type="number" step="0.01" /></label><label class="inline-edit-span">创建原因<input asp-for="NewEquipment.Reason" /></label></div><button class="button button--primary" type="submit">创建并加入本项目</button></form></details>
                                <details class="inline-create-details"><summary>新建施工班组主档</summary><form method="post" asp-page-handler="CreateCrew" asp-route-id="@item.Overview.Id" class="inline-edit-panel"><div class="inline-edit-grid"><label>班组编号<input asp-for="NewCrew.PartnerNumber" /></label><label>班组名称<input asp-for="NewCrew.Name" /></label><label>联系人<input asp-for="NewCrew.ContactName" /></label><label>联系电话<input asp-for="NewCrew.ContactPhone" /></label><label class="inline-edit-span">创建原因<input asp-for="NewCrew.Reason" /></label></div><button class="button button--primary" type="submit">创建并加入本项目</button></form></details>
                            </div>
                        }
                        <div asp-validation-summary="All" class="panel-copy"></div>
                        <div class="table-wrap"><table class="data-table construction-inline-table construction-detail-table"><thead><tr><th>类型</th><th>设备/施工班组</th><th>项目总览</th><th>从哪个项目调入</th><th>进场日期</th><th>退场日期</th><th>总天数</th><th>停工天数</th><th>施工天数</th><th>退场到哪个项目</th><th>状态</th><th>附件</th><th class="quantity-notes-column">备注</th></tr></thead><tbody>
                        @{ var constructionEditIndex = 0; }
                        @foreach (var row in Model.ConstructionWorkspace.Records)
                        {
                            var editIndex = constructionEditIndex++;
                            <tr id="project-record-@row.Id" data-quantity-edit-row data-construction-row>
                                <td>@(row.RecordType == ProjectConstructionRecordType.Equipment ? "设备" : "施工班组")</td>
                                <td>@row.SubjectLabel</td>
                                <td><span data-inline-edit-value>@(row.ShowInProjectOverview ? "是" : "否")</span>@if (row.RecordType == ProjectConstructionRecordType.Equipment) { <label data-inline-edit-control hidden><input type="checkbox" name="ConstructionRowEdits[@editIndex].ShowInProjectOverview" value="true" form="construction-batch-form" checked="@(row.ShowInProjectOverview ? "checked" : null)" /> 显示</label> }</td>
                                <td>@(row.TransferFromProjectName ?? "-")</td>
                                <td><span data-inline-edit-value>@(row.EntryDate?.ToString("yyyy-MM-dd") ?? "-")</span><input class="inline-cell-control" name="ConstructionRowEdits[@editIndex].EntryDate" value="@row.EntryDate?.ToString("yyyy-MM-dd")" type="date" form="construction-batch-form" data-inline-edit-control hidden /></td>
                                <td><span data-inline-edit-value>@(row.ExitDate?.ToString("yyyy-MM-dd") ?? "-")</span><input class="inline-cell-control" name="ConstructionRowEdits[@editIndex].ExitDate" value="@row.ExitDate?.ToString("yyyy-MM-dd")" type="date" form="construction-batch-form" data-inline-edit-control hidden /></td>
                                <td>@row.TotalDays</td>
                                <td><span data-inline-edit-value>@row.StopDays</span><input class="inline-cell-control" name="ConstructionRowEdits[@editIndex].StopDays" value="@row.StopDays" type="number" form="construction-batch-form" data-inline-edit-control hidden /></td>
                                <td>@row.WorkDays</td>
                                <td>@(row.TransferToProjectName ?? "-")</td>
                                <td><span class="pill">@(row.IsDraft ? "待完善" : "正式")</span>
                                    <div class="construction-flow-actions" data-inline-edit-actions hidden>
                                        <form method="post" asp-page-handler="ConstructionFlow" asp-route-id="@item.Overview.Id" class="construction-flow-form">
                                            <input type="hidden" name="ConstructionFlow.RecordId" value="@row.Id" />
                                            <input type="hidden" name="ConstructionFlow.ConcurrencyStamp" value="@row.ConcurrencyStamp" />
                                            <input type="hidden" name="ConstructionFlow.Reason" value="项目管理页面调整施工流转" />
                                            <select name="ConstructionFlow.TargetProjectId" aria-label="流转目标项目"><option value="">选择目标项目</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id">@option.Label</option> }</select>
                                            <input type="date" name="ConstructionFlow.TargetEntryDate" aria-label="后续项目进场日期" title="关联后续项目时填写进场日期" />
                                            <button class="button button--secondary button--small" type="submit" name="ConstructionFlow.Action" value="previous">连接上一条</button>
                                            <button class="button button--secondary button--small" type="submit" name="ConstructionFlow.Action" value="next">关联后续项目</button>
                                            @if (row.TransferFromProjectId.HasValue || row.TransferToProjectId.HasValue) { <button class="button button--ghost button--small" type="submit" name="ConstructionFlow.Action" value="unlink">解除流转</button> }
                                        </form>
                                    </div>
                                </td>
                                <td class="record-attachment-column"><div class="record-attachment-tools">@if (Model.CanManage) { <form method="post" enctype="multipart/form-data" asp-page-handler="RecordAttachment" asp-route-id="@item.Overview.Id" asp-route-recordType="@ProjectRecordAttachmentType.Construction" asp-route-recordId="@row.Id" asp-route-tab="construction" data-auto-upload-picker><input type="file" name="RecordAttachmentFile" required data-auto-upload-input hidden /><button class="button button--secondary button--small" type="button" data-auto-upload-trigger>@(Model.RecordAttachments.ContainsKey(row.Id) ? "替换" : "上传")</button></form> }@if (Model.RecordAttachments.TryGetValue(row.Id, out var constructionAttachment)) { <a class="button button--secondary button--small" asp-page-handler="RecordAttachment" asp-route-id="@item.Overview.Id" asp-route-attachmentId="@constructionAttachment.Id" target="_blank" rel="noopener" title="@constructionAttachment.OriginalFileName">预览</a>@if (Model.CanManage) { <form method="post" asp-page-handler="DeleteRecordAttachment" asp-route-id="@item.Overview.Id" asp-route-recordType="@ProjectRecordAttachmentType.Construction" asp-route-recordId="@row.Id" asp-route-attachmentId="@constructionAttachment.Id" asp-route-tab="construction"><button class="button button--ghost button--small" type="submit">删除</button></form> } }</div></td>
                                <td class="quantity-notes-column">@if (string.IsNullOrWhiteSpace(row.Notes)) { <span data-inline-edit-value></span> } else { <span class="quantity-notes-value" data-inline-edit-value data-quantity-notes-anchor tabindex="0" aria-describedby="quantity-notes-comment"><span>@row.Notes</span><span data-quantity-notes-content hidden>@row.Notes</span></span> }<button class="quantity-notes-edit-trigger" type="button" data-quantity-notes-edit data-quantity-notes-title="编辑施工备注" data-inline-edit-actions hidden><span data-quantity-notes-button-text>@(string.IsNullOrWhiteSpace(row.Notes) ? "点击编辑备注" : row.Notes)</span></button><input type="hidden" name="ConstructionRowEdits[@editIndex].Notes" value="@row.Notes" form="construction-batch-form" data-quantity-notes-input hidden /><input type="hidden" name="ConstructionRowEdits[@editIndex].Id" value="@row.Id" form="construction-batch-form" /><input type="hidden" name="ConstructionRowEdits[@editIndex].RecordType" value="@row.RecordType" form="construction-batch-form" /><input type="hidden" name="ConstructionRowEdits[@editIndex].SubjectId" value="@row.SubjectId" form="construction-batch-form" /><input type="hidden" name="ConstructionRowEdits[@editIndex].ConcurrencyStamp" value="@row.ConcurrencyStamp" form="construction-batch-form" /><input type="hidden" name="ConstructionRowEdits[@editIndex].IsDirty" value="false" form="construction-batch-form" data-quantity-edit-dirty /><input type="hidden" name="ConstructionRowEdits[@editIndex].Reason" value="项目管理页面快捷修改施工详情" form="construction-batch-form" /></td>
                            </tr>
                        }
                        </tbody></table></div>
                    </article>
                </div>
            </section>
        </main>
        <aside class="project-activity-panel" aria-label="项目提示与修改记录"><div class="activity-panel-heading"><div><p class="eyebrow">动态</p><h2>提示与记录</h2></div><span>@item.Activities.Count</span></div><div class="activity-feed">@if (item.Activities.Count == 0) { <div class="empty-state"><strong>暂无动态</strong><p>编辑项目或录入业务后会在这里形成记录。</p></div> } @foreach (var activity in item.Activities) { <article class="activity-item activity-item--@activity.Tone"><span class="activity-dot"></span><div><p class="activity-meta">@activity.Category · @activity.OccurredAt.ToLocalTime().ToString("MM-dd HH:mm")</p><h3>@activity.Title</h3>@if (!string.IsNullOrWhiteSpace(activity.Detail)) { <p>@activity.Detail</p> }@if (!string.IsNullOrWhiteSpace(activity.UserName)) { <small>操作人：@activity.UserName</small> }</div></article> }</div></aside>
    </div>
}
