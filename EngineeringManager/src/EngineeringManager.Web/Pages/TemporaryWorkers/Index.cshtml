@page
@model EngineeringManager.Web.Pages.TemporaryWorkers.IndexModel
@{ ViewData["Title"] = "临时人员"; }
<section class="page-heading"><div><p class="eyebrow">公司直接临时聘用</p><h1>临时人员</h1><p class="page-lead">不属于自有员工和施工班组的临时人员单独建轻量档案，不计入正式员工统计。</p></div></section>
<section class="panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>姓名</th><th>身份证</th><th>手机号</th><th>工种</th><th>发放次数</th><th>历史发放合计</th><th>最近发放</th><th>操作</th></tr></thead><tbody>@foreach (var item in Model.Workers) { <tr><td>@item.Name @(item.HasPotentialDuplicate ? "· 疑似重名" : "")</td><td>@(item.IdentityNumber ?? "未填写")</td><td>@(item.Phone ?? "未填写")</td><td>@(item.Trade ?? "未填写")</td><td>@item.PaymentCount</td><td>@item.TotalPaidAmount.ToString("N2")</td><td>@(item.LastPaymentDate?.ToString() ?? "暂无")</td><td><a asp-page="/TemporaryWorkers/Details" asp-route-id="@item.Id">查看发放记录</a></td></tr> }</tbody></table></div>
@if (Model.CanManage) { <form method="post" class="form-grid"><label>姓名<input asp-for="Input.Name" required /></label><label>身份证号（选填）<input asp-for="Input.IdentityNumber" /></label><label>手机号<input asp-for="Input.Phone" /></label><label>银行卡号<input asp-for="Input.BankAccountNumber" /></label><label>开户行<input asp-for="Input.BankName" /></label><label>工种<input asp-for="Input.Trade" /></label><label>备注<input asp-for="Input.Notes" /></label><label>修改原因<input asp-for="Input.Reason" required /></label><button class="button button--primary" type="submit">新增临时人员</button></form> }</section>
