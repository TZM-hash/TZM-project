@model EngineeringManager.Application.Projects.ProjectConstructionRecordDto
<form method="post" asp-page-handler="Construction" class="record-value-editor">
    <input type="hidden" name="ProjectId" value="@Model.ProjectId" /><input type="hidden" name="Section" value="construction" />
    <input type="hidden" name="ConstructionEdit.Id" value="@Model.Id" /><input type="hidden" name="ConstructionEdit.RecordType" value="@Model.RecordType" />
    <input type="hidden" name="ConstructionEdit.SubjectId" value="@Model.SubjectId" /><input type="hidden" name="ConstructionEdit.TransferFromProjectId" value="@Model.TransferFromProjectId" />
    <input type="hidden" name="ConstructionEdit.TransferToProjectId" value="@Model.TransferToProjectId" /><input type="hidden" name="ConstructionEdit.ConcurrencyStamp" value="@Model.ConcurrencyStamp" />
    <label>进场日期<input type="date" name="ConstructionEdit.EntryDate" value="@Model.EntryDate?.ToString("yyyy-MM-dd")" /></label><label>退场日期<input type="date" name="ConstructionEdit.ExitDate" value="@Model.ExitDate?.ToString("yyyy-MM-dd")" /></label>
    <label>停工天数<input type="number" min="0" name="ConstructionEdit.StopDays" value="@Model.StopDays" /></label><label>备注<input name="ConstructionEdit.Notes" value="@Model.Notes" /></label>
    @if (Model.RecordType == EngineeringManager.Domain.Projects.ProjectConstructionRecordType.Equipment) { <label class="checkbox-row"><input type="checkbox" name="ConstructionEdit.ShowInProjectOverview" value="true" checked="@(Model.ShowInProjectOverview ? "checked" : null)" />显示在项目总览</label> }
    <label>修改原因<input name="ConstructionEdit.Reason" value="项目施工详情详细编辑" required /></label><button class="button button--primary button--small" type="submit">保存本项</button>
</form>
