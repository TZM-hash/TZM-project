@page
@model EngineeringManager.Web.Pages.Admin.FinanceYears.IndexModel
@{ ViewData["Title"] = "财务年度"; }
<section class="page-heading"><div><p class="eyebrow">系统设置</p><h1>财务年度</h1><p class="page-lead">所有自有公司、外部账本和内部账本统一使用同一套财务年度；项目全生命周期统计不受年度切割。</p></div></section>
@if (TempData["Success"] is string success) { <div class="alert alert--success">@success</div> }
@if (TempData["Error"] is string error) { <div class="alert alert--danger">@error</div> }
<section class="content-grid">
    <article class="panel"><div class="panel-heading"><div><p class="eyebrow">新增年度</p><h2>日期范围</h2></div></div><form method="post" asp-page-handler="Create" class="form-grid"><label>年度名称<input asp-for="Name" required /></label><label>开始日期<input asp-for="StartDate" type="date" required /></label><label>结束日期<input asp-for="EndDate" type="date" required /></label><div class="form-actions"><button class="button button--primary" type="submit">保存财务年度</button></div></form></article>
    <article class="panel"><div class="panel-heading"><div><p class="eyebrow">年度清单</p><h2>已配置年度</h2></div></div><div class="table-wrap"><table class="data-table"><thead><tr><th>名称</th><th>开始日期</th><th>结束日期</th><th>账本记录数</th><th>操作</th></tr></thead><tbody>@foreach (var item in Model.Items) { <tr><td>@item.Name</td><td>@item.StartDate</td><td>@item.EndDate</td><td>@item.RecordCount</td><td><form method="post" asp-page-handler="Delete" class="inline-form"><input type="hidden" name="DeleteId" value="@item.Id" /><input type="hidden" name="DeleteConcurrencyStamp" value="@item.ConcurrencyStamp" /><input name="DeleteReason" placeholder="填写删除原因" required /><button class="button button--danger" type="submit">删除</button></form></td></tr> }</tbody></table></div></article>
</section>
