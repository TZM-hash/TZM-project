@page
@using EngineeringManager.Domain.Equipment
@using EngineeringManager.Web.Workbenches
@model EngineeringManager.Web.Pages.Equipment.IndexModel
@{
    ViewData["Title"] = "设备管理";
    var workbench = DataWorkbenchPresets.Equipment with
    {
        InlineFilters = new DataWorkbenchFilterField[]
        {
            new("Keyword", "搜索", Model.Keyword, Placeholder: "搜索设备全部信息"),
            new("Status", "状态", Model.Status?.ToString(), DataWorkbenchFilterKind.Select,
                Enum.GetValues<EquipmentStatus>().Select(value => new DataWorkbenchFilterOption(value.ToString(), value.ToString())).ToArray())
        }
    };
}
<div data-equipment-dashboard>
    <section class="page-heading"><div><p class="eyebrow">设备与项目协同</p><h1>设备管理</h1><p class="page-lead">逐台管理自有和租赁设备、项目使用、施工/停工日期、租金及最终结算。</p></div><div class="button-row">@if(Model.CanManage){<a class="button button--primary" asp-page="Edit">新增设备</a>}<a class="button button--secondary" asp-page="Offline">现场离线记录</a></div></section>
    <section class="metric-grid" aria-label="设备指标"><article class="metric-card"><span class="metric-label">设备总数</span><strong class="metric-value">@Model.Dashboard.TotalCount</strong></article><article class="metric-card"><span class="metric-label">使用中</span><strong class="metric-value">@Model.Dashboard.InUseCount</strong></article><article class="metric-card"><span class="metric-label">租赁设备</span><strong class="metric-value">@Model.Dashboard.RentedCount</strong></article><article class="metric-card"><span class="metric-label">已结算金额</span><strong class="metric-value">@Model.Dashboard.SettledAmount.ToString("N2")</strong></article></section>
    <section class="panel chart-summary" data-chart data-chart-kind="progress-ring" data-chart-value="@(Model.Dashboard.TotalCount == 0 ? 0 : (decimal)Model.Dashboard.InUseCount / Model.Dashboard.TotalCount * 100m)" data-chart-label="设备使用率"><div class="panel-heading"><div><p class="eyebrow">图形摘要</p><h2>设备使用率</h2></div></div><div data-chart-canvas></div></section>
<section class="dashboard-grid"><article class="panel"><div class="panel-heading"><div><p class="eyebrow">状态分布</p><h2>设备状态</h2></div></div><div class="comparison-chart">@foreach(var item in Model.Dashboard.StatusDistribution){<div class="comparison-row"><div class="chart-label"><strong>@item.Key</strong><span>@item.Value 台</span></div></div>}</div></article><article class="panel"><div class="panel-heading"><div><p class="eyebrow">逐台档案</p><h2>设备列表</h2></div></div><partial name="_DataWorkbench" model="workbench" /><div class="table-wrap"><table class="data-table" id="equipment-table"><thead><tr><th data-column-key="number">编号</th><th data-column-key="name">名称</th><th data-column-key="model">型号</th><th data-column-key="ownership">权属</th><th data-column-key="status">状态</th><th data-column-key="notes">备注摘要</th><th data-column-key="actions">操作</th></tr></thead><tbody>@foreach(var item in Model.Dashboard.Items){<tr><td data-column-key="number">@item.EquipmentNumber</td><td data-column-key="name"><a asp-page="Details" asp-route-id="@item.Id">@item.Name</a></td><td data-column-key="model">@item.Model</td><td data-column-key="ownership">@item.OwnershipType</td><td data-column-key="status">@item.Status</td><td data-column-key="notes">@(string.IsNullOrWhiteSpace(item.Notes) ? "—" : item.Notes.Length > 40 ? item.Notes[..40] + "…" : item.Notes)</td><td data-column-key="actions"><a asp-page="Details" asp-route-id="@item.Id">查看</a>@if(Model.CanManage){<span> · </span><a asp-page="Edit" asp-route-id="@item.Id">编辑</a><span> · </span><a asp-page="Edit" asp-route-copyFrom="@item.Id">复制</a>}<span> · </span><a asp-page="Usage" asp-route-equipmentId="@item.Id">进退场</a></td></tr>}</tbody></table></div></article></section>
</div>
