@page "{id:guid}"
@model EngineeringManager.Web.Pages.Projects.DetailsModel
@using EngineeringManager.Application.Finance
@using EngineeringManager.Application.Projects
@using EngineeringManager.Application.DataExchange
@using EngineeringManager.Web.Pages.DataExchange
@using EngineeringManager.Domain.Finance
@using EngineeringManager.Domain.Projects
@using EngineeringManager.Web.Presentation
@{
    ViewData["Title"] = "项目详情";
    var activeTab = Model.Tab?.ToLowerInvariant();
}

@section Scripts {
    <script type="module">
        import { initAttachmentPickers } from "/js/components/attachment-picker.js";

        initAttachmentPickers();
        document.querySelectorAll("[data-quantity-create]").forEach((form) => {
            const quantity = form.querySelector("[data-quantity-value]");
            const price = form.querySelector("[data-quantity-price]");
            const subtotal = form.querySelector("[data-quantity-subtotal]");
            if (!quantity || !price || !subtotal) return;
            const updateSubtotal = () => {
                const quantityValue = Number.parseFloat(quantity.value) || 0;
                const priceValue = Number.parseFloat(price.value) || 0;
                subtotal.value = (quantityValue * priceValue).toFixed(4);
            };
            quantity.addEventListener("input", updateSubtotal);
            price.addEventListener("input", updateSubtotal);
            updateSubtotal();
        });
        document.querySelectorAll("[data-quantity-edit-row]").forEach((row) => {
            const dirty = row.querySelector("[data-quantity-edit-dirty]");
            if (!dirty) return;
            row.querySelectorAll("[data-inline-edit-control]").forEach((control) => {
                const markDirty = () => { dirty.value = "true"; };
                control.addEventListener("input", markDirty);
                control.addEventListener("change", markDirty);
            });
        });

        const noteDialog = document.querySelector("[data-quantity-notes-dialog]");
        const noteEditor = noteDialog?.querySelector("[data-quantity-notes-editor]");
        const noteSave = noteDialog?.querySelector("[data-quantity-notes-save]");
        const noteTitle = noteDialog?.querySelector("[data-quantity-notes-dialog-title]");
        let activeNoteInput = null;
        let activeNoteTrigger = null;
        if (noteDialog && noteEditor && noteSave) {
            document.querySelectorAll("[data-quantity-notes-edit]").forEach((trigger) => {
                trigger.addEventListener("click", () => {
                    const row = trigger.closest("[data-quantity-edit-row]");
                    const input = row?.querySelector("[data-quantity-notes-input]");
                    if (!input) return;
                    activeNoteInput = input;
                    activeNoteTrigger = trigger;
                    if (noteTitle) noteTitle.textContent = trigger.dataset.quantityNotesTitle || "编辑工程量备注";
                    noteEditor.value = input.value;
                    noteDialog.showModal();
                    noteEditor.focus();
                    noteEditor.setSelectionRange(noteEditor.value.length, noteEditor.value.length);
                });
            });
            noteDialog.querySelectorAll("[data-quantity-notes-cancel]").forEach((button) => {
                button.addEventListener("click", () => noteDialog.close());
            });
            noteSave.addEventListener("click", () => {
                if (!activeNoteInput || !activeNoteTrigger) return;
                activeNoteInput.value = noteEditor.value;
                const label = activeNoteTrigger.querySelector("[data-quantity-notes-button-text]");
                if (label) label.textContent = noteEditor.value.trim() || "点击编辑备注";
                const dirty = activeNoteTrigger.closest("[data-quantity-edit-row]")?.querySelector("[data-quantity-edit-dirty]");
                if (dirty) dirty.value = "true";
                noteDialog.close();
            });
            noteDialog.addEventListener("close", () => {
                activeNoteInput = null;
                activeNoteTrigger = null;
            });
        }

        const noteAnchors = [...document.querySelectorAll("[data-quantity-notes-anchor]")];
        if (noteAnchors.length > 0) {
            const tooltip = document.createElement("div");
            tooltip.id = "quantity-notes-comment";
            tooltip.className = "quantity-notes-comment";
            tooltip.setAttribute("role", "tooltip");
            tooltip.hidden = true;
            document.body.append(tooltip);

            let activeAnchor = null;
            const positionTooltip = () => {
                if (!activeAnchor || tooltip.hidden) return;
                const anchorRect = activeAnchor.getBoundingClientRect();
                const margin = 12;
                const gap = 8;
                const maximumLeft = Math.max(margin, window.innerWidth - tooltip.offsetWidth - margin);
                const left = Math.min(Math.max(anchorRect.right - tooltip.offsetWidth, margin), maximumLeft);
                const above = anchorRect.top - tooltip.offsetHeight - gap;
                const below = Math.min(anchorRect.bottom + gap, Math.max(margin, window.innerHeight - tooltip.offsetHeight - margin));
                tooltip.style.left = `${left}px`;
                tooltip.style.top = `${above >= margin ? above : below}px`;
            };
            const showTooltip = (event) => {
                const anchor = event.currentTarget;
                const content = anchor.querySelector("[data-quantity-notes-content]");
                if (!content || anchor.closest(".is-editing")) return;
                activeAnchor = anchor;
                tooltip.textContent = content.textContent?.trim() ?? "";
                tooltip.hidden = false;
                tooltip.style.visibility = "hidden";
                positionTooltip();
                tooltip.style.visibility = "visible";
            };
            const hideTooltip = () => {
                activeAnchor = null;
                tooltip.hidden = true;
            };

            noteAnchors.forEach((anchor) => {
                anchor.addEventListener("pointerenter", showTooltip);
                anchor.addEventListener("pointerleave", hideTooltip);
                anchor.addEventListener("focus", showTooltip);
                anchor.addEventListener("blur", hideTooltip);
            });
            window.addEventListener("resize", positionTooltip);
            document.addEventListener("scroll", positionTooltip, true);
            document.addEventListener("pointerdown", hideTooltip);
        }
    </script>
}

@if (Model.Workspace is null)
{
    <section class="panel"><h1>项目不存在</h1><p class="panel-copy">项目可能已归档或不在当前授权范围内。</p></section>
}
else
{
    var item = Model.Workspace;
    var collectionRate = item.FinanceSummary.ReceivableAmount == 0m ? 0m : item.FinanceSummary.CollectedAmount / item.FinanceSummary.ReceivableAmount * 100m;
    var invoiceRate = item.ProjectSummary.InvoiceRequiredAmount == 0m ? 0m : item.FinanceSummary.OutputInvoiceAmount / item.ProjectSummary.InvoiceRequiredAmount * 100m;
    var paymentRate = item.FinanceSummary.PayableAmount == 0m ? 0m : item.FinanceSummary.PaidAmount / item.FinanceSummary.PayableAmount * 100m;
    var collectionBar = Math.Clamp(collectionRate, 0m, 100m);
    var invoiceBar = Math.Clamp(invoiceRate, 0m, 100m);
    var paymentBar = Math.Clamp(paymentRate, 0m, 100m);
    var cashGap = item.FinanceSummary.CollectedAmount - item.FinanceSummary.PaidAmount;
    var taxConfigurations = item.Overview.TaxConfigurations?.Where(configuration => configuration.IsActive).ToArray() ?? [];

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert--info" role="status">@error</div>
    }
    var overviewEquipment = item.OverviewEquipment ?? [];
    var relatedParties = ProjectRelatedPartyBuilder.Build(item.Overview.GeneralContractorName, item.Partners ?? [], Model.ConstructionWorkspace.Records);
    var amountView = item.Overview.Stage is ProjectStage.PartiallySettled or ProjectStage.SettledArchived ? "settled" : "estimated";
    var amountLabel = amountView == "settled" ? "结算金额" : "暂估金额";
    <section class="page-heading project-heading compact-page-heading">
        <div><p class="eyebrow">@item.Overview.ProjectNumber</p><h1>@item.Overview.Name</h1><p class="page-lead">@(item.Overview.GeneralContractorName ?? "未填写总包单位") · @(item.Overview.ResponsibleUserName ?? "未设置负责人")</p></div>
        <div class="button-row"><span class="pill pill--success">@item.Overview.Stage.ToChinese()</span>@if (Model.CanExportWorkbook) { <form method="post" asp-page-handler="ExportWorkbook" asp-route-id="@item.Overview.Id" class="inline-form"><details class="selection-dropdown"><summary class="button button--secondary button--action">导出工作簿</summary><div class="selection-dropdown-menu">@if (Model.CanExportWorkbookAttachments) { <label class="check-label"><input asp-for="IncludeWorkbookAttachments" /> 包含附件</label> }@foreach (var sheet in Enum.GetValues<ProjectWorkbookSheet>().Where(sheet => Model.CanExportFullWorkbook || sheet != ProjectWorkbookSheet.ProjectSummary && sheet != ProjectWorkbookSheet.Attachments)) { <label class="check-label"><input type="checkbox" name="SelectedWorkbookSheets" value="@sheet" checked="@(Model.SelectedWorkbookSheets.Count == 0 || Model.SelectedWorkbookSheets.Contains(sheet) ? "checked" : null)" /> @DataExchangeLabels.ProjectSheet(sheet)</label> }<button class="button button--primary button--small" type="submit">生成</button></div></details></form> }@if (Model.CanManage) { <a class="button button--secondary button--action" asp-page="Edit" asp-route-copyFrom="@item.Overview.Id">复制</a> }</div>
    </section>

    <div class="project-workspace-shell">
        <main class="project-workspace-main">
            <section class="overview-strip project-detail-strip" aria-label="项目经营总览">
                <article class="is-accent"><span>当前工程金额 · @item.ProjectSummary.SettlementStatus.ToChinese()</span><strong>@item.ProjectSummary.CurrentAmount.ToString("N2")</strong></article>
                <article><span>应开票金额</span><strong>@item.ProjectSummary.InvoiceRequiredAmount.ToString("N2")</strong></article>
                <article><span>已开票</span><strong>@item.FinanceSummary.OutputInvoiceAmount.ToString("N2")</strong></article>
                <article class="is-success"><span>已收款</span><strong>@item.FinanceSummary.CollectedAmount.ToString("N2")</strong></article>
                <article><span>已付款</span><strong>@item.FinanceSummary.PaidAmount.ToString("N2")</strong></article>
                <article class="is-warning"><span>未收款</span><strong>@item.FinanceSummary.UncollectedAmount.ToString("N2")</strong></article>
                <article class="is-warning"><span>未付款</span><strong>@item.FinanceSummary.UnpaidAmount.ToString("N2")</strong></article>
                <article class="@(cashGap < 0 ? "is-danger" : "is-success")"><span>现金缺口</span><strong>@cashGap.ToString("N2")</strong></article>
            </section>

            <section class="panel project-overview-panel compact-detail-panel inline-edit-shell" data-inline-edit="project-overview" data-inline-cell-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-overview" ? "true" : "false")">
                <form method="post" asp-page-handler="QuickEdit" asp-route-id="@item.Overview.Id" id="project-overview-inline-form">
                    <div class="panel-heading"><div><p class="eyebrow">项目总览</p><h2>基础资料与金额口径</h2><small>更新于 @item.Overview.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--action" type="submit" data-inline-edit-actions hidden>保存</button></div> }</div>
                    <div asp-validation-summary="All" class="panel-copy"></div>
                    <dl class="detail-grid detail-grid--compact project-summary-grid">
                        <div><dt>项目编号</dt><dd><span data-inline-edit-value>@item.Overview.ProjectNumber</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ProjectNumber" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>项目名称</dt><dd><span data-inline-edit-value>@item.Overview.Name</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Name" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>项目阶段</dt><dd><span data-inline-edit-value>@item.Overview.Stage.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.Stage" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<ProjectStage>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
                        <div><dt>合同签订</dt><dd><span data-inline-edit-value>@item.Overview.ContractSigningStatus.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.ContractSigningStatus" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<ContractSigningStatus>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
                        <div><dt>总包单位</dt><dd><span data-inline-edit-value>@(item.Overview.GeneralContractorName ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.GeneralContractorName" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>总包联系人 / 电话</dt><dd><span data-inline-edit-value>@(string.IsNullOrWhiteSpace(item.Overview.GeneralContractorContact) && string.IsNullOrWhiteSpace(item.Overview.GeneralContractorPhone) ? "未设置" : $"{item.Overview.GeneralContractorContact ?? "-"} · {item.Overview.GeneralContractorPhone ?? "-"}")</span>@if (Model.CanManage) { <div class="inline-cell-control compact-contact-editor" data-inline-edit-control hidden><input asp-for="QuickEdit.GeneralContractorContact" placeholder="联系人" /><input asp-for="QuickEdit.GeneralContractorPhone" placeholder="联系电话" /></div> }</dd></div>
                        <div><dt>项目负责人</dt><dd><span data-inline-edit-value>@(item.Overview.ResponsibleUserName ?? "未设置")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.ResponsibleUserId" data-inline-edit-control hidden><option value="">未设置</option>@foreach (var option in Model.Options.ResponsibleUsers) { <option value="@option.Value">@option.Label</option> }</select> }</dd></div>
                        <div><dt>部门</dt><dd><span data-inline-edit-value>@(item.Overview.DepartmentName ?? "未设置")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.DepartmentId" data-inline-edit-control hidden><option value="">未设置</option>@foreach (var option in Model.Options.Departments) { <option value="@option.Value">@option.Label</option> }</select> }</dd></div>
                        <div class="project-quick-selection-cell"><dt>签约公司</dt><dd><span data-inline-edit-value>@(item.Overview.LegalEntities.Count == 0 ? "未设置" : string.Join("、", item.Overview.LegalEntities.Select(option => option.Label)))</span>@if (Model.CanManage) { <details class="selection-dropdown project-quick-selection project-legal-entity-selector" data-check-selector data-check-selector-empty-label="未选择" data-inline-edit-control hidden><summary class="selection-dropdown-toggle"><span>签约公司</span><strong data-check-selector-count></strong></summary><div class="selection-dropdown-menu"><div class="selection-dropdown-heading"><span>勾选签约公司</span><div><button type="button" data-check-selector-all>全选</button><button type="button" data-check-selector-clear>清空</button></div></div><div class="check-grid">@foreach (var option in Model.Options.LegalEntities) { var optionId = Guid.Parse(option.Value); var selected = Model.QuickEdit.LegalEntityIds.Contains(optionId); <label><input type="checkbox" name="QuickEdit.LegalEntityIds" value="@option.Value" checked="@(selected ? "checked" : null)" data-check-selector-option data-default="@selected.ToString().ToLowerInvariant()" /> <span>@option.Label</span></label> }</div></div></details> }</dd></div>
                        <div><dt>合作方式</dt><dd><span data-inline-edit-value>@item.Overview.AffiliationType.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.AffiliationType" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<ProjectAffiliationType>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
                        <div><dt>实际开工日期</dt><dd><span data-inline-edit-value>@(item.Overview.ActualStartDate?.ToString("yyyy-MM-dd") ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ActualStartDate" type="date" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>实际完工日期</dt><dd><span data-inline-edit-value>@(item.Overview.ActualCompletionDate?.ToString("yyyy-MM-dd") ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ActualCompletionDate" type="date" data-inline-edit-control hidden /> }</dd></div>
                        <div class="project-summary-half project-quick-selection-cell"><dt>税金</dt><dd><div class="project-tax-tags" data-inline-edit-value>@if (taxConfigurations.Length == 0) { <span>未配置</span> } else { @foreach (var configuration in taxConfigurations) { <span class="pill">@((configuration.TaxRate * 100m).ToString("0"))% @configuration.InvoiceType.ToChinese()</span> } }</div>@if (Model.CanManage) { <details class="selection-dropdown project-quick-selection project-tax-selector" data-check-selector data-check-selector-empty-label="未配置" data-project-tax-matrix data-inline-edit-control hidden><summary class="selection-dropdown-toggle"><span>税率与发票类型</span><strong data-check-selector-count></strong></summary><div class="selection-dropdown-menu"><div class="selection-dropdown-heading"><span>勾选需要启用的组合</span><div><button type="button" data-check-selector-all>全选</button><button type="button" data-check-selector-clear>清空</button></div></div><div class="project-tax-choice-grid">@foreach (var rate in ProjectTaxRules.AllowedRates) { var percent = decimal.ToInt32(rate * 100m); <fieldset><legend>@percent%</legend>@foreach (var invoiceType in Enum.GetValues<ProjectInvoiceType>()) { var token = $"{percent}|{(int)invoiceType}"; var selected = Model.QuickEdit.TaxConfigurationSelections.Contains(token); <label><input type="checkbox" name="QuickEdit.TaxConfigurationSelections" value="@token" checked="@(selected ? "checked" : null)" data-check-selector-option data-default="@selected.ToString().ToLowerInvariant()" /> <span>@invoiceType.ToChinese()</span></label> }</fieldset> }</div></div></details> }</dd></div>
                        <div class="project-summary-quarter project-overview-equipment"><dt>施工机械</dt><dd>@if (overviewEquipment.Count == 0) { <span>暂无标记为重要的施工机械</span> } else { <div class="project-equipment-list">@foreach (var equipment in overviewEquipment) { <a asp-page="Details" asp-route-id="@item.Overview.Id" asp-route-tab="construction" asp-route-recordId="@equipment.ConstructionRecordId"><strong>@equipment.EquipmentNumber · @equipment.EquipmentName</strong><span>@(equipment.EntryDate?.ToString("yyyy-MM-dd") ?? "未进场") 至 @(equipment.ExitDate?.ToString("yyyy-MM-dd") ?? "仍在场")</span></a> }</div> }</dd></div>
                        <div class="project-summary-quarter project-contract-editor" data-project-contracts>
                            <dt>合同</dt>
                            <dd>
                                <div class="project-contract-list" data-project-contract-list>
                                    @{
                                        var contractEdits = Model.QuickEdit.Contracts;
                                        if (contractEdits.Count == 0)
                                        {
                                            contractEdits = item.Contracts
                                                .OrderByDescending(contract => contract.ContractType == ContractType.MainContract)
                                                .ThenBy(contract => contract.ContractNumber)
                                                .Select(contract => new ProjectContractQuickEditInput(
                                                    contract.Id,
                                                    contract.Name,
                                                    contract.TotalAmount == 0m ? null : contract.TotalAmount,
                                                    contract.ConcurrencyStamp))
                                                .ToList();
                                        }
                                    }
                                    @for (var contractIndex = 0; contractIndex < contractEdits.Count; contractIndex++)
                                    {
                                        var contractEdit = contractEdits[contractIndex];
                                        var displayName = string.IsNullOrWhiteSpace(contractEdit.Name) ? "未命名合同" : contractEdit.Name;
                                        var displayAmount = contractEdit.TotalAmount.HasValue ? contractEdit.TotalAmount.Value.ToString("N2") : "未设置";
                                        var canRemoveContract = contractEdits.Count > 1;
                                        <div class="project-contract-row" data-project-contract-row>
                                            <div data-inline-edit-value class="project-contract-display"><strong>@displayName</strong><span>@displayAmount</span></div>
                                            @if (Model.CanManage)
                                            {
                                                <div class="project-contract-inputs compact-contact-editor inline-cell-control" data-inline-edit-control hidden>
                                                    @if (contractEdit.Id is Guid existingContractId && existingContractId != Guid.Empty) { <input type="hidden" name="QuickEdit.Contracts[@contractIndex].Id" value="@existingContractId" /> }
                                                    <input type="hidden" name="QuickEdit.Contracts[@contractIndex].ConcurrencyStamp" value="@contractEdit.ConcurrencyStamp" />
                                                    <input name="QuickEdit.Contracts[@contractIndex].Name" value="@contractEdit.Name" placeholder="合同名称" aria-label="合同名称" data-project-contract-name />
                                                    <input name="QuickEdit.Contracts[@contractIndex].TotalAmount" value="@(contractEdit.TotalAmount?.ToString(System.Globalization.CultureInfo.InvariantCulture))" type="number" step="0.01" min="0" placeholder="合同金额" aria-label="合同金额" data-project-contract-amount />
                                                </div>
                                                @if (canRemoveContract) { <button type="button" class="button button--secondary button--action project-contract-row-remove" data-project-contract-remove data-inline-edit-control hidden>删除</button> } else { <button type="button" class="button button--secondary button--action project-contract-row-remove" data-project-contract-remove data-inline-edit-control hidden disabled>删除</button> }
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="project-contract-total-line"><span>合同总额</span><strong data-project-contract-total>@item.ProjectSummary.ContractAmount.ToString("N2")</strong></div>
                                @if (Model.CanManage)
                                {
                                    <div class="project-contract-actions" data-inline-edit-control hidden>
                                        <button type="button" class="button button--secondary button--action" data-project-contract-add>添加合同</button>
                                        <span class="project-contract-hint">最多 3 份，至少保留 1 份</span>
                                    </div>
                                }
                            </dd>
                        </div>
                        <div><dt>收款比例</dt><dd><div class="mini-progress mini-progress--success"><div class="mini-progress-head"><span>已收 / 应收</span><strong>@collectionRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @collectionBar.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span></div></dd></div>
                        <div><dt>开票比例</dt><dd><div class="mini-progress"><div class="mini-progress-head"><span>已开 / 应开</span><strong>@invoiceRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @invoiceBar.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span></div></dd></div>
                        <div><dt>付款比例</dt><dd><div class="mini-progress mini-progress--warning"><div class="mini-progress-head"><span>已付 / 应付</span><strong>@paymentRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @paymentBar.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span></div></dd></div>
                        
                        <div class="project-amount-switch"><dt>工程金额</dt><dd><span class="project-amount-view-label" data-project-amount-view-label data-inline-edit-value><span>@amountLabel</span><strong>@item.ProjectSummary.CurrentAmount.ToString("N2")</strong></span>@if (Model.CanManage) { <div class="project-amount-edit-control" data-inline-edit-control hidden><select data-project-amount-view><option value="estimated" selected="@(amountView == "estimated" ? "selected" : null)">暂估金额</option><option value="settled" selected="@(amountView == "settled" ? "selected" : null)">结算金额</option></select><strong data-project-amount-estimated>@item.ProjectSummary.CurrentAmount.ToString("N2")</strong><strong data-project-amount-settled hidden>@item.ProjectSummary.CurrentAmount.ToString("N2")</strong></div> }</dd></div>
                        <div><dt>应付 / 已付 / 未付</dt><dd>@item.FinanceSummary.PayableAmount.ToString("N2") / @item.FinanceSummary.PaidAmount.ToString("N2") / @item.FinanceSummary.UnpaidAmount.ToString("N2")</dd></div>
                        <div class="project-summary-wide project-summary-notes"><dt>项目备注</dt><dd><span data-inline-edit-value>@(item.Overview.Notes ?? "暂无备注")</span>@if (Model.CanManage) { <textarea class="inline-cell-control" asp-for="QuickEdit.Notes" rows="5" data-inline-edit-control hidden></textarea> }</dd></div>
                    </dl>
                    @if (Model.CanManage) { <label class="inline-edit-reason" data-inline-edit-actions hidden>修改原因<input class="inline-cell-control" asp-for="QuickEdit.Reason" /></label><input type="hidden" asp-for="QuickEdit.ConcurrencyStamp" /> }
                </form>
            </section>

            <section class="content-grid project-related-overview" aria-label="项目关联资料">
                <article class="panel compact-detail-panel">
                    <div class="panel-heading"><h2>项目人员</h2><span>@(item.Assignments?.Count ?? 0)</span></div>
                    @if (item.Assignments is null || item.Assignments.Count == 0) { <p class="panel-copy">暂无项目人员分配。</p> }
                    else { <ul class="check-list">@foreach (var assignment in item.Assignments) { <li><strong>@assignment.UserName</strong> · @(assignment.AssignmentType == ProjectAssignmentType.Responsible ? "负责人" : "现场人员")<br /><span>@(assignment.Notes ?? "暂无备注")</span></li> }</ul> }
                </article>
                <article class="panel compact-detail-panel">
                    <div class="panel-heading"><h2>项目合作单位</h2><span>@relatedParties.Count</span></div>
                    @if (relatedParties.Count == 0) { <p class="panel-copy">暂无项目合作单位。</p> }
                    else { <ul class="check-list project-related-party-list">@foreach (var relatedParty in relatedParties) { <li><div><strong>@relatedParty.Name</strong><span class="project-related-party-roles">@foreach (var role in relatedParty.Roles) { <span class="pill">@role</span> }</span></div><span>@(relatedParty.Notes ?? "暂无备注")</span></li> }</ul> }
                </article>
            </section>

            <section class="panel project-tabs" data-project-tabs>
                <input type="radio" name="project-detail-tab" id="project-tab-quantity" checked="@(activeTab is null or "quantity" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-collection" checked="@(activeTab == "collection" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-invoice" checked="@(activeTab == "invoice" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-payment" checked="@(activeTab == "payment" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-construction" checked="@(activeTab == "construction" ? "checked" : null)" />
                <nav class="project-tab-list" aria-label="项目业务明细">
                    <label for="project-tab-quantity">工程量明细 <span>@item.Contracts.Sum(contract => contract.LineItems.Count)</span></label><label for="project-tab-collection">收款明细 <span>@item.Collections.Count</span></label><label for="project-tab-invoice">开票明细 <span>@item.Invoices.Count</span></label><label for="project-tab-payment">付款明细 <span>@item.Payments.Count</span></label><label for="project-tab-construction">施工详情 <span>@Model.ConstructionWorkspace.Records.Count</span></label>
                </nav>
                <div class="project-tab-panels">
                    <article class="project-tab-panel project-tab-panel--quantity inline-edit-shell" data-inline-edit="project-quantity" data-inline-cell-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-quantity" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>合同与工程量</h2><p>工程量按合同和清单行集中展示，可直接新增、上传附件并在原表格单元格中修改。</p></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><form id="quantity-batch-form" method="post" asp-page-handler="Quantities" asp-route-id="@item.Overview.Id" class="inline-form" data-inline-edit-actions hidden><button class="button button--primary button--action" type="submit">保存修改</button></form><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        <div asp-validation-summary="All" class="panel-copy"></div>
                        @if (Model.CanManage)
                        {
                            <details class="inline-create-details quantity-inline-create" open="@(Model.ActiveInlineEditor == "project-quantity-create" ? "open" : null)">
                                <summary>新增工程量明细</summary>
                                <form method="post" enctype="multipart/form-data" asp-page-handler="CreateQuantity" asp-route-id="@item.Overview.Id" class="inline-edit-panel quantity-entry-compact-form" data-quantity-create>
                                    <div class="quantity-entry-compact-grid">
                                        <div class="quantity-entry-row quantity-entry-row--1">
                                            <label class="quantity-entry-compact-field quantity-entry-compact-field--contract">所属合同<select asp-for="CreateQuantity.ContractId" required><option value="">请选择已有合同</option>@foreach (var contract in item.Contracts) { <option value="@contract.Id">@contract.ContractNumber · @contract.Name</option> }</select></label>
                                            <label class="quantity-entry-compact-field quantity-entry-compact-field--invoice">是否需要开票<select asp-for="CreateQuantity.RequiresInvoice"><option value="true">是</option><option value="false">否</option></select></label>
                                            <label class="quantity-entry-compact-field quantity-entry-compact-field--accounting">口径<select asp-for="CreateQuantity.AccountingLabel"><option value="暂估">暂估</option><option value="结算">结算</option></select></label>
                                            <div class="quantity-entry-attachment" data-attachment-picker>
                                                <div class="quantity-entry-attachment-heading"><strong>新增附件</strong></div>
                                                <div class="quantity-entry-attachment-control"><input asp-for="QuantityAttachmentFile" type="file" /><div class="quantity-entry-attachment-preview" data-attachment-preview><strong data-attachment-name hidden></strong><small data-attachment-size hidden></small><a data-attachment-preview-link target="_blank" rel="noopener" hidden>预览附件</a><img data-attachment-image alt="附件预览" hidden /></div></div>
                                            </div>
                                        </div>
                                        <div class="quantity-entry-row quantity-entry-row--2">
                                            <label class="quantity-entry-compact-field">编号<input asp-for="CreateQuantity.Code" placeholder="BOQ-01" required /></label>
                                            <label class="quantity-entry-compact-field">名称<input asp-for="CreateQuantity.Name" placeholder="工程量明细名称" required /></label>
                                            <label class="quantity-entry-compact-field">单位<input asp-for="CreateQuantity.Unit" placeholder="米、吨、项" required /></label>
                                            <label class="quantity-entry-compact-field">工程量<input asp-for="CreateQuantity.Quantity" type="number" step="0.0001" min="0" data-quantity-value /></label>
                                            <label class="quantity-entry-compact-field">单价<input asp-for="CreateQuantity.UnitPrice" type="number" step="0.0001" min="0" data-quantity-price /></label>
                                            <label class="quantity-entry-compact-field">小计预览<input type="text" readonly value="0.0000" data-quantity-subtotal /></label>
                                        </div>
                                        <div class="quantity-entry-row quantity-entry-row--3">
                                            <label class="quantity-entry-compact-field quantity-entry-compact-field--notes">备注<textarea asp-for="CreateQuantity.Notes" placeholder="施工范围、计量依据或补充说明"></textarea></label>
                                        </div>
                                    </div>
                                    @if (item.Contracts.Count == 0) { <p class="quantity-entry-empty">当前项目暂无合同，请先维护合同档案。</p> }
                                    <div class="inline-edit-actions"><button class="button button--primary" type="submit" disabled="@(item.Contracts.Count == 0 ? "disabled" : null)">保存工程量明细</button></div>
                                </form>
                            </details>
                        }
                        @if (item.Contracts.Count == 0) { <div class="empty-state"><strong>尚未录入合同与工程量</strong><p>建立合同后即可在此新增首条工程量。</p></div> }
                        @{ var quantityEditIndex = 0; }
                        @foreach (var contract in item.Contracts)
                        {
                            <section class="workspace-subsection"><div class="workspace-subheading"><h3>@contract.ContractNumber · @contract.Name</h3><span>合同额 @contract.TotalAmount.ToString("N2") · @(contract.Notes ?? "暂无合同备注")</span></div><div class="table-wrap"><table class="data-table quantity-inline-table"><thead><tr><th>编号</th><th>名称</th><th>单位</th><th>工程量</th><th>单价</th><th>小计</th><th>口径</th><th>是否开票</th><th class="quantity-upload-column">上传</th><th class="quantity-attachment-column">附件</th><th class="quantity-notes-column">备注</th></tr></thead><tbody>
                            @foreach (var line in contract.LineItems)
                            {
                                var editIndex = quantityEditIndex++;
                                var uploadFormId = $"quantity-upload-{line.Id:N}";
                                <tr id="quantity-line-@line.Id" data-quantity-edit-row>
                                    <td><span data-inline-edit-value>@line.Code</span><input class="inline-cell-control" name="QuantityEdits[@editIndex].Code" value="@line.Code" form="quantity-batch-form" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.Name</span><input class="inline-cell-control" name="QuantityEdits[@editIndex].Name" value="@line.Name" form="quantity-batch-form" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.Unit</span><input class="inline-cell-control" name="QuantityEdits[@editIndex].Unit" value="@line.Unit" form="quantity-batch-form" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.Quantity?.ToString("N2")</span><input class="inline-cell-control" name="QuantityEdits[@editIndex].Quantity" value="@line.Quantity" type="number" step="0.0001" form="quantity-batch-form" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.UnitPrice?.ToString("N2")</span><input class="inline-cell-control" name="QuantityEdits[@editIndex].UnitPrice" value="@line.UnitPrice" type="number" step="0.0001" form="quantity-batch-form" data-inline-edit-control hidden /></td>
                                    <td>@line.Amount.ToString("N2")</td>
                                    <td><span data-inline-edit-value>@(line.AccountingLabel ?? "-")</span><select class="inline-cell-control" name="QuantityEdits[@editIndex].AccountingLabel" form="quantity-batch-form" data-inline-edit-control hidden><option value="暂估" selected="@(line.AccountingLabel == "暂估" ? "selected" : null)">暂估</option><option value="结算" selected="@(line.AccountingLabel == "结算" ? "selected" : null)">结算</option></select></td>
                                    <td><span data-inline-edit-value>@(line.RequiresInvoice ? "是" : "否")</span><select class="inline-cell-control" name="QuantityEdits[@editIndex].RequiresInvoice" form="quantity-batch-form" data-inline-edit-control hidden><option value="true" selected="@(line.RequiresInvoice ? "selected" : null)">是</option><option value="false" selected="@(!line.RequiresInvoice ? "selected" : null)">否</option></select></td>
                                    <td class="quantity-upload-column"><div class="quantity-attachment-tools">@if (Model.CanManage) { <form id="@uploadFormId" method="post" enctype="multipart/form-data" asp-page-handler="QuantityAttachment" asp-route-id="@item.Overview.Id" asp-route-lineItemId="@line.Id" class="quantity-row-upload" data-auto-upload-picker><input type="file" name="QuantityAttachmentFile" required data-auto-upload-input hidden /><button class="button button--secondary button--small" type="button" data-auto-upload-trigger>上传附件</button></form> } else { <span>-</span> }</div></td>
                                    <td class="quantity-attachment-cell quantity-attachment-column"><div class="quantity-attachment-content">@if (Model.QuantityAttachments.TryGetValue(line.Id, out var attachment)) { <a class="button button--secondary button--small quantity-attachment-preview-link" asp-page-handler="QuantityAttachment" asp-route-id="@item.Overview.Id" asp-route-attachmentId="@attachment.Id" target="_blank" rel="noopener" title="@attachment.OriginalFileName">预览附件</a>@if (Model.CanManage) { <form method="post" asp-page-handler="DeleteQuantityAttachment" asp-route-id="@item.Overview.Id" asp-route-lineItemId="@line.Id" asp-route-attachmentId="@attachment.Id" class="inline-form"><button class="button button--ghost button--small" type="submit">删除附件</button></form> } }</div></td>
                                    <td class="quantity-notes-column">@if (string.IsNullOrWhiteSpace(line.Notes)) { <span data-inline-edit-value></span> } else { <span class="quantity-notes-value" data-inline-edit-value data-quantity-notes-anchor tabindex="0" aria-describedby="quantity-notes-comment"><span>@line.Notes</span><span data-quantity-notes-content hidden>@line.Notes</span></span> }<button class="quantity-notes-edit-trigger" type="button" data-quantity-notes-edit data-inline-edit-actions hidden><span data-quantity-notes-button-text>@(string.IsNullOrWhiteSpace(line.Notes) ? "点击编辑备注" : line.Notes)</span></button><input type="hidden" name="QuantityEdits[@editIndex].Notes" value="@line.Notes" form="quantity-batch-form" data-quantity-notes-input hidden /><input type="hidden" name="QuantityEdits[@editIndex].LineItemId" value="@line.Id" form="quantity-batch-form" /><input type="hidden" name="QuantityEdits[@editIndex].ConcurrencyStamp" value="@line.ConcurrencyStamp" form="quantity-batch-form" /><input type="hidden" name="QuantityEdits[@editIndex].IsDirty" value="false" form="quantity-batch-form" data-quantity-edit-dirty /></td>
                                </tr>
                            }
                            </tbody></table></div></section>
                        }
                        @if (Model.CanManageFinance)
                        {
                            <dialog class="workbench-dialog quantity-notes-dialog" data-quantity-notes-dialog aria-labelledby="quantity-notes-dialog-title">
                                <div class="workbench-dialog-heading"><div><strong id="quantity-notes-dialog-title" data-quantity-notes-dialog-title>编辑工程量备注</strong><span>填写完整备注后先保存到当前快捷编辑内容，再使用顶部“保存修改”统一提交。</span></div><button class="dialog-close" type="button" data-quantity-notes-cancel aria-label="关闭备注编辑">×</button></div>
                                <div class="quantity-notes-dialog-body"><label>备注内容<textarea rows="8" data-quantity-notes-editor></textarea></label></div>
                                <div class="workbench-dialog-actions"><button class="button button--secondary" type="button" data-quantity-notes-cancel>取消</button><button class="button button--primary" type="button" data-quantity-notes-save>保存</button></div>
                            </dialog>
                        }
                    </article>

                    <article class="project-tab-panel project-tab-panel--collection inline-edit-shell" data-inline-edit="project-collection" data-inline-cell-edit data-project-finance-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-collection" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>收款明细</h2><p>应收金额以工程量明细汇总为准，到账记录自动按应收顺序分摊。</p></div>@if (Model.CanManageFinance) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><form id="collection-batch-form" method="post" asp-page-handler="Collections" asp-route-id="@item.Overview.Id" class="inline-form" data-inline-edit-actions hidden><button class="button button--primary button--action" type="submit">保存修改</button></form><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        @if (Model.CanManageFinance)
                        {
                            <details class="inline-create-details record-entry-details"><summary>新增收款明细</summary><form method="post" enctype="multipart/form-data" asp-page-handler="Collection" asp-route-id="@item.Overview.Id" class="inline-edit-panel collection-entry-compact-form" data-collection-entry>
                                <div asp-validation-summary="All" class="panel-copy"></div><div class="collection-entry-compact-grid">
                                    <div class="collection-entry-row collection-entry-row--1">
                                        <label class="collection-entry-compact-field">合同<select asp-for="CollectionEdit.ContractId" data-collection-contract><option value="" data-business-partner-id="">不指定合同</option>@foreach (var contract in item.Contracts) { <option value="@contract.Id" data-business-partner-id="@contract.BusinessPartnerId">@contract.ContractNumber · @contract.Name</option> }</select></label>
                                        <label class="collection-entry-compact-field">签约公司<select asp-for="CollectionEdit.LegalEntityId"><option value="">请选择</option>@foreach (var company in item.Overview.LegalEntities) { <option value="@company.Value">@company.Label</option> }</select></label>
                                        <label class="collection-entry-compact-field">付款方<select asp-for="CollectionEdit.BusinessPartnerId" data-collection-payer><option value="">未指定</option>@foreach (var partner in Model.FinanceOptions.BusinessPartners) { <option value="@partner.Id">@partner.Label</option> }</select></label>
                                        <div class="quantity-entry-attachment collection-entry-attachment" data-attachment-picker>
                                            <div class="quantity-entry-attachment-heading"><strong>附件</strong></div>
                                            <div class="quantity-entry-attachment-control"><input asp-for="RecordAttachmentFile" type="file" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" /><div class="quantity-entry-attachment-preview" data-attachment-preview><strong data-attachment-name hidden></strong><small data-attachment-size hidden></small><a data-attachment-preview-link target="_blank" rel="noopener" hidden>预览附件</a><img data-attachment-image alt="附件预览" hidden /></div></div>
                                        </div>
                                    </div>
                                    <div class="collection-entry-row collection-entry-row--2">
                                        <label class="collection-entry-compact-field">收款账户<select asp-for="CollectionEdit.AccountId"><option value="">请选择</option>@foreach (var account in Model.FinanceOptions.Accounts) { <option value="@account.Id">@account.Label</option> }</select></label>
                                        <label class="collection-entry-compact-field">收款方式<input asp-for="CollectionEdit.PaymentMethod" placeholder="例如：银行转账、现金" /></label>
                                        <label class="collection-entry-compact-field">收款金额<input asp-for="CollectionEdit.Amount" type="number" step="0.01" /></label>
                                        <label class="collection-entry-compact-field">收款日期<input asp-for="CollectionEdit.EntryDate" type="date" /></label>
                                    </div>
                                    <div class="collection-entry-row collection-entry-row--3"><label class="collection-entry-compact-field collection-entry-compact-field--notes">备注<textarea asp-for="CollectionEdit.Description" placeholder="收款用途、到账说明或补充备注"></textarea></label></div>
                                </div><div class="inline-edit-actions"><button type="button" class="button button--secondary button--action" data-inline-edit-cancel>取消</button><button type="submit" class="button button--primary button--action">保存</button></div>
                            </form></details>
                        }
                        <div class="finance-summary-strip"><span>工程量应收 @item.FinanceSummary.ReceivableAmount.ToString("N2")</span><span>已收 @item.FinanceSummary.CollectedAmount.ToString("N2")</span><span>未收 @item.FinanceSummary.UncollectedAmount.ToString("N2")</span></div>
                        <div><h3>收款记录</h3><div class="table-wrap"><table class="data-table collection-inline-table"><thead><tr><th>收款日期</th><th>合同</th><th>签约公司</th><th>付款方</th><th>收款账户</th><th>收款金额</th><th>收款方式</th><th>附件</th><th>备注</th></tr></thead><tbody>
                        @{ var collectionEditIndex = 0; }
                        @foreach (var row in item.Collections)
                        {
                            var editIndex = collectionEditIndex++;
                            <tr id="project-record-@row.Id" data-quantity-edit-row>
                                <td><span data-inline-edit-value>@row.CollectionDate</span><input class="inline-cell-control" name="CollectionRowEdits[@editIndex].EntryDate" value="@row.CollectionDate.ToString("yyyy-MM-dd")" type="date" form="collection-batch-form" data-inline-edit-control hidden /></td>
                                <td><span data-inline-edit-value>@(row.ContractNumber ?? "-")</span><select class="inline-cell-control" name="CollectionRowEdits[@editIndex].ContractId" form="collection-batch-form" data-inline-edit-control hidden><option value="">不指定合同</option>@foreach (var contract in item.Contracts) { <option value="@contract.Id" selected="@(contract.Id == row.ContractId ? "selected" : null)">@contract.ContractNumber · @contract.Name</option> }</select></td>
                                <td><span data-inline-edit-value>@row.LegalEntityName</span><select class="inline-cell-control" name="CollectionRowEdits[@editIndex].LegalEntityId" form="collection-batch-form" data-inline-edit-control hidden>@foreach (var company in item.Overview.LegalEntities) { <option value="@company.Value" selected="@(company.Value == row.LegalEntityId.ToString() ? "selected" : null)">@company.Label</option> }</select></td>
                                <td><span data-inline-edit-value>@(row.BusinessPartnerName ?? "-")</span><select class="inline-cell-control" name="CollectionRowEdits[@editIndex].BusinessPartnerId" form="collection-batch-form" data-inline-edit-control hidden><option value="">未指定</option>@foreach (var partner in Model.FinanceOptions.BusinessPartners) { <option value="@partner.Id" selected="@(partner.Id == row.BusinessPartnerId ? "selected" : null)">@partner.Label</option> }</select></td>
                                <td><span data-inline-edit-value>@row.AccountName</span><select class="inline-cell-control" name="CollectionRowEdits[@editIndex].AccountId" form="collection-batch-form" data-inline-edit-control hidden>@foreach (var account in Model.FinanceOptions.Accounts) { <option value="@account.Id" selected="@(account.Id == row.AccountId ? "selected" : null)">@account.Label</option> }</select></td>
                                <td><span data-inline-edit-value>@row.Amount.ToString("N2")</span><input class="inline-cell-control" name="CollectionRowEdits[@editIndex].Amount" value="@row.Amount" type="number" step="0.01" form="collection-batch-form" data-inline-edit-control hidden /></td>
                                <td><span data-inline-edit-value>@(row.PaymentMethod ?? "-")</span><input class="inline-cell-control" name="CollectionRowEdits[@editIndex].CollectionPaymentMethod" value="@row.PaymentMethod" form="collection-batch-form" data-inline-edit-control hidden /></td>
                                <td class="record-attachment-column"><div class="record-attachment-tools">@if (Model.CanManageFinance) { <form method="post" enctype="multipart/form-data" asp-page-handler="RecordAttachment" asp-route-id="@item.Overview.Id" asp-route-recordType="@ProjectRecordAttachmentType.Cash" asp-route-recordId="@row.Id" asp-route-tab="collection" data-auto-upload-picker><input type="file" name="RecordAttachmentFile" required data-auto-upload-input hidden /><button class="button button--secondary button--small" type="button" data-auto-upload-trigger>@(Model.RecordAttachments.ContainsKey(row.Id) ? "替换" : "上传")</button></form> }@if (Model.RecordAttachments.TryGetValue(row.Id, out var collectionAttachment)) { <a class="button button--secondary button--small" asp-page-handler="RecordAttachment" asp-route-id="@item.Overview.Id" asp-route-attachmentId="@collectionAttachment.Id" target="_blank" rel="noopener" title="@collectionAttachment.OriginalFileName">预览</a>@if (Model.CanManageFinance) { <form method="post" asp-page-handler="DeleteRecordAttachment" asp-route-id="@item.Overview.Id" asp-route-recordType="@ProjectRecordAttachmentType.Cash" asp-route-recordId="@row.Id" asp-route-attachmentId="@collectionAttachment.Id" asp-route-tab="collection"><button class="button button--ghost button--small" type="submit">删除</button></form> } }</div></td>
                                <td class="quantity-notes-column">@if (string.IsNullOrWhiteSpace(row.Notes)) { <span data-inline-edit-value></span> } else { <span class="quantity-notes-value" data-inline-edit-value data-quantity-notes-anchor tabindex="0" aria-describedby="quantity-notes-comment"><span>@row.Notes</span><span data-quantity-notes-content hidden>@row.Notes</span></span> }<button class="quantity-notes-edit-trigger" type="button" data-quantity-notes-edit data-quantity-notes-title="编辑收款备注" data-inline-edit-actions hidden><span data-quantity-notes-button-text>@(string.IsNullOrWhiteSpace(row.Notes) ? "点击编辑备注" : row.Notes)</span></button><input type="hidden" name="CollectionRowEdits[@editIndex].Description" value="@row.Notes" form="collection-batch-form" data-quantity-notes-input hidden /><input type="hidden" name="CollectionRowEdits[@editIndex].Id" value="@row.Id" form="collection-batch-form" /><input type="hidden" name="CollectionRowEdits[@editIndex].ConcurrencyStamp" value="@row.ConcurrencyStamp" form="collection-batch-form" /><input type="hidden" name="CollectionRowEdits[@editIndex].IsDirty" value="false" form="collection-batch-form" data-quantity-edit-dirty /></td>
                            </tr>
                        }
                        </tbody></table></div></div>
                    </article>

                                        <article class="project-tab-panel project-tab-panel--invoice inline-edit-shell" data-inline-edit="project-invoice" data-inline-cell-edit data-project-finance-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-invoice" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>发票明细</h2><p>项目内只登记销项发票。</p></div>@if (Model.CanManageFinance) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><form id="invoice-batch-form" method="post" asp-page-handler="Invoices" asp-route-id="@item.Overview.Id" class="inline-form" data-inline-edit-actions hidden><button class="button button--primary button--action" type="submit">保存修改</button></form><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        @if (Model.CanManageFinance)
                        {
                            <details class="inline-create-details record-entry-details"><summary>新增开票明细</summary><form method="post" enctype="multipart/form-data" asp-page-handler="Invoice" asp-route-id="@item.Overview.Id" class="inline-edit-panel collection-entry-compact-form">
                                <div asp-validation-summary="All" class="panel-copy"></div>
                                <div class="collection-entry-compact-grid">
                                    <div class="collection-entry-row collection-entry-row--1">
