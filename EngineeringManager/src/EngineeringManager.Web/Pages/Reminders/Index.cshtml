@page
@model EngineeringManager.Web.Pages.Reminders.IndexModel
@{
    ViewData["Title"] = "提醒中心";
}
<section class="page-heading"><div><p class="eyebrow">风险与任务</p><h1>提醒中心</h1><p class="page-lead">显示项目节点、未收未付、未开票、工资未发和导入/备份失败；第一阶段不发送外部通知。</p></div></section>
<section class="panel"><partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.Reminders" />@if (Model.Reminders.Count == 0) { <p class="panel-copy">当前没有待处理提醒。</p> } else { <div class="table-wrap"><table class="data-table" id="reminders-table"><thead><tr><th data-column-key="severity">级别</th><th data-column-key="type">类型</th><th data-column-key="title">标题</th><th data-column-key="message">说明</th><th data-column-key="actions">操作</th></tr></thead><tbody>@foreach (var item in Model.Reminders) { <tr><td data-column-key="severity">@item.Severity</td><td data-column-key="type">@item.Type</td><td data-column-key="title">@item.Title</td><td data-column-key="message">@item.Message</td><td data-column-key="actions"><form method="post" asp-page-handler="Read" style="display:inline"><input type="hidden" name="id" value="@item.Id" /><button class="button button--secondary" type="submit">已读</button></form> <form method="post" asp-page-handler="Resolve" style="display:inline"><input type="hidden" name="id" value="@item.Id" /><button class="button button--secondary" type="submit">处理</button></form></td></tr> }</tbody></table></div> }</section>
