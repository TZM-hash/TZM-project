@page "{id:guid}"
@model EngineeringManager.Web.Pages.Companies.DetailsModel
@using EngineeringManager.Domain.Finance
@{ ViewData["Title"] = Model.Company.Name; }

<section class="page-heading compact-page-heading"><div><p class="eyebrow">@Model.Company.Code · @(Model.Company.CompanyCategoryName ?? "未分类")</p><h1>@Model.Company.Name</h1><p class="page-lead">@Model.Company.ShortName · 法人/经营者：@(Model.Company.LegalRepresentative ?? "未填写")</p></div>@if (Model.CanManage) { <div class="button-row"><a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@Model.Company.Id">详细编辑</a><a class="button button--secondary button--action" asp-page="Edit" asp-route-copyFrom="@Model.Company.Id">复制</a></div> }</section>
<section class="overview-strip"><article class="is-accent"><span>合同额</span><strong>@Model.Dashboard.ContractAmount.ToString("N2")</strong></article><article><span>应收 / 已收</span><strong>@Model.Dashboard.ReceivableAmount.ToString("N2") / @Model.Dashboard.CollectedAmount.ToString("N2")</strong></article><article><span>应付 / 已付</span><strong>@Model.Dashboard.PayableAmount.ToString("N2") / @Model.Dashboard.PaidAmount.ToString("N2")</strong></article><article><span>账户余额</span><strong>@Model.Dashboard.AccountBalance.ToString("N2")</strong></article></section>

<section class="content-grid">
    <article class="panel compact-detail-panel inline-edit-shell" data-inline-edit="company-details" data-inline-cell-edit data-inline-edit-active="@(Model.QuickEditOpen ? "true" : "false")">
        <form method="post" asp-page-handler="QuickEdit">
            <div class="panel-heading"><h2>基础与开票资料</h2>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑公司</button><a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@Model.Company.Id">进入详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--action" type="submit" data-inline-edit-actions hidden>保存</button></div> }</div>
            <div asp-validation-summary="All" class="panel-copy"></div>
            <dl class="detail-grid project-summary-grid">
                <div><dt>公司编码</dt><dd><span data-inline-edit-value>@Model.Company.Code</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Code" data-inline-edit-control hidden required /> }</dd></div>
                <div><dt>公司名称</dt><dd><span data-inline-edit-value>@Model.Company.Name</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Name" data-inline-edit-control hidden required /> }</dd></div>
                <div><dt>简称</dt><dd><span data-inline-edit-value>@Model.Company.ShortName</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ShortName" data-inline-edit-control hidden required /> }</dd></div>
                <div><dt>组合分类</dt><dd><span data-inline-edit-value>@(Model.Company.CompanyCategoryName ?? "未分类")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.CompanyCategoryId" data-inline-edit-control hidden><option value="">未分类</option>@foreach (var category in Model.Categories) { <option value="@category.Id">@category.Name</option> }</select> }</dd></div>
                <div><dt>法人/经营者</dt><dd><span data-inline-edit-value>@(Model.Company.LegalRepresentative ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.LegalRepresentative" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>统一社会信用代码</dt><dd><span data-inline-edit-value>@(Model.Company.UnifiedSocialCreditCode ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.UnifiedSocialCreditCode" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>联系电话</dt><dd><span data-inline-edit-value>@(Model.Company.Phone ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Phone" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>开票抬头</dt><dd><span data-inline-edit-value>@(Model.Company.InvoiceTitle ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.InvoiceTitle" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>注册地址</dt><dd><span data-inline-edit-value>@(Model.Company.RegisteredAddress ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.RegisteredAddress" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>经营地址</dt><dd><span data-inline-edit-value>@(Model.Company.BusinessAddress ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.BusinessAddress" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>备注</dt><dd><span data-inline-edit-value>@(Model.Company.Notes ?? "未填写")</span>@if (Model.CanManage) { <textarea class="inline-cell-control" asp-for="QuickEdit.Notes" rows="2" data-inline-edit-control hidden></textarea> }</dd></div>
            </dl>
            @if (Model.CanManage) { <label class="inline-edit-reason" data-inline-edit-actions hidden>修改原因<input class="inline-cell-control" asp-for="QuickEdit.Reason" required /></label><input type="hidden" asp-for="QuickEdit.ConcurrencyStamp" /> }
        </form>
    </article>
    <article class="panel compact-detail-panel"><div class="panel-heading"><h2>证书资料</h2><a class="button button--secondary button--action" asp-page="/Companies/Certificates/Index" asp-route-CompanyId="@Model.Company.Id">证书管理</a></div><p class="panel-copy">证书 @Model.Company.Certificates.Count 项。</p><ul class="check-list">@foreach (var certificate in Model.Company.Certificates) { <li>@certificate.CertificateType · @(certificate.CertificateNumber ?? "未编号") · @(certificate.ExpiresOn?.ToString("yyyy-MM-dd") ?? "长期")</li> }</ul></article>
</section>

<section class="panel" id="company-accounts" data-company-account-table>
    <div class="panel-heading"><div><h2>公司账户</h2><p class="panel-copy">当前启用 @Model.Company.Accounts.Count(account => account.IsActive) 个，共 @Model.Company.Accounts.Count 个。</p></div></div>
    <div asp-validation-summary="All" class="panel-copy"></div>
    @if (Model.Company.Accounts.Count == 0)
    {
        <p class="panel-copy">还没有维护公司账户。</p>
    }
    else
    {
        <div class="table-wrap"><table class="data-table company-account-table"><thead><tr><th>账户名称</th><th>账号</th><th>开户行</th><th>账户类型</th><th>期初余额</th><th>默认用途</th><th>状态</th><th>账户备注</th>@if (Model.CanManage) { <th>操作</th> }</tr></thead><tbody>
        @foreach (var account in Model.Company.Accounts)
        {
            var accountFormId = $"company-account-{account.Id:N}";
            var accountTypeLabel = account.AccountType switch
            {
                nameof(FinancialAccountType.Bank) => "银行",
                nameof(FinancialAccountType.Cash) => "现金",
                _ => "其他"
            };
            var defaultLabels = new List<string>();
            if (account.IsDefaultCollection) defaultLabels.Add("收款");
            if (account.IsDefaultPayment) defaultLabels.Add("付款");
            if (account.IsDefaultInvoice) defaultLabels.Add("开票");
            <tr data-inline-edit="company-account-@account.Id" data-inline-cell-edit>
                <td><span data-inline-edit-value>@account.AccountName</span>@if (Model.CanManage) { <input class="inline-cell-control" name="Account.Name" value="@account.AccountName" form="@accountFormId" data-inline-edit-control hidden required /> }</td>
                <td><span data-inline-edit-value>@(account.AccountNumber ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="Account.Number" value="@account.AccountNumber" form="@accountFormId" data-inline-edit-control hidden /> }</td>
                <td><span data-inline-edit-value>@(account.BankName ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="Account.BankName" value="@account.BankName" form="@accountFormId" data-inline-edit-control hidden /> }</td>
                <td><span data-inline-edit-value>@accountTypeLabel</span>@if (Model.CanManage) { <select class="inline-cell-control" name="Account.AccountType" form="@accountFormId" data-inline-edit-control hidden><option value="1" selected="@(account.AccountType == nameof(FinancialAccountType.Bank) ? "selected" : null)">银行</option><option value="2" selected="@(account.AccountType == nameof(FinancialAccountType.Cash) ? "selected" : null)">现金</option><option value="3" selected="@(account.AccountType == nameof(FinancialAccountType.Other) ? "selected" : null)">其他</option></select> }</td>
                <td><span data-inline-edit-value>@account.OpeningBalance.ToString("N2")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="Account.OpeningBalance" value="@account.OpeningBalance" type="number" step="0.01" form="@accountFormId" data-inline-edit-control hidden /> }</td>
                <td><span data-inline-edit-value>@(defaultLabels.Count == 0 ? "无" : string.Join("、", defaultLabels))</span>@if (Model.CanManage) { <div class="company-account-defaults" data-inline-edit-control hidden><label><input type="checkbox" name="Account.DefaultCollection" value="true" checked="@(account.IsDefaultCollection ? "checked" : null)" form="@accountFormId" />收款</label><label><input type="checkbox" name="Account.DefaultPayment" value="true" checked="@(account.IsDefaultPayment ? "checked" : null)" form="@accountFormId" />付款</label><label><input type="checkbox" name="Account.DefaultInvoice" value="true" checked="@(account.IsDefaultInvoice ? "checked" : null)" form="@accountFormId" />开票</label></div> }</td>
                <td><span data-inline-edit-value>@(account.IsActive ? "启用" : "已停用")</span></td>
                <td><span data-inline-edit-value>@(account.Notes ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="Account.Notes" value="@account.Notes" form="@accountFormId" data-inline-edit-control hidden /> }</td>
                @if (Model.CanManage)
                {
                    <td class="table-actions"><form id="@accountFormId" method="post" asp-page-handler="Account" asp-route-id="@Model.Company.Id" class="inline-form"><input type="hidden" name="Account.Id" value="@account.Id" /><input type="hidden" name="Account.ConcurrencyStamp" value="@account.ConcurrencyStamp" /><input type="hidden" name="Account.IsActive" value="@account.IsActive.ToString().ToLowerInvariant()" /><button class="button button--secondary button--small" type="button" data-inline-edit-open>编辑</button><button class="button button--secondary button--small" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--small" type="submit" data-inline-edit-actions hidden>保存</button></form><form method="post" asp-page-handler="AccountStatus" asp-route-id="@Model.Company.Id" class="inline-form" data-inline-edit-value><input type="hidden" name="accountId" value="@account.Id" /><input type="hidden" name="concurrencyStamp" value="@account.ConcurrencyStamp" /><input type="hidden" name="isActive" value="@(!account.IsActive ? "true" : "false")" /><button class="button button--ghost button--small" type="submit" onclick="return confirm('@(account.IsActive ? "确认删除这个账户吗？已关联的历史记录会保留。" : "确认恢复这个账户吗？")')">@(account.IsActive ? "删除" : "恢复")</button></form></td>
                }
            </tr>
        }
        </tbody></table></div>
    }
</section>

@if (Model.CanManage)
{
    <section class="content-grid"><article class="panel"><div class="panel-heading"><h2>新增公司账户</h2></div><form method="post" asp-page-handler="Account" class="form-grid"><input asp-for="Account.IsActive" type="hidden" value="true" /><label>账户名称<input asp-for="Account.Name" required /></label><label>账户类型<select asp-for="Account.AccountType"><option value="1">银行</option><option value="2">现金</option><option value="3">其他</option></select></label><label>账号<input asp-for="Account.Number" /></label><label>开户行<input asp-for="Account.BankName" /></label><label>期初余额<input asp-for="Account.OpeningBalance" /></label><label>账户备注<textarea asp-for="Account.Notes"></textarea></label><label class="checkbox-row"><input asp-for="Account.DefaultCollection" />默认收款</label><label class="checkbox-row"><input asp-for="Account.DefaultPayment" />默认付款</label><label class="checkbox-row"><input asp-for="Account.DefaultInvoice" />默认开票</label><button class="button button--primary button--action" type="submit">保存账户</button></form></article><article class="panel"><div class="panel-heading"><h2>新增公司证照</h2></div><form method="post" asp-page-handler="Certificate" class="form-grid"><label>资料类型<input asp-for="Certificate.Type" required /></label><label>资料编号<input asp-for="Certificate.Number" /></label><label>签发日期<input asp-for="Certificate.IssuedOn" type="date" /></label><label>有效期<input asp-for="Certificate.ExpiresOn" type="date" /></label><label class="form-span">备注<textarea asp-for="Certificate.Notes"></textarea></label><button class="button button--primary button--action" type="submit">保存证照</button></form></article></section>
}
