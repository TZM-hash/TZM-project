@page
@model EngineeringManager.Web.Pages.Partners.IndexModel
@{
    ViewData["Title"] = "合作单位";
}

<section class="page-heading">
    <div><p class="eyebrow">统一档案</p><h1>合作单位</h1><p class="page-lead">同一家单位可以同时作为甲方/总包、施工班组、材料供应商或零星供应商。</p></div>
    <a class="button button--secondary" asp-page="/Partners/Create">新增合作单位</a>
</section>

<section class="panel">
    <div class="panel-heading"><div><p class="eyebrow">单位主档</p><h2>当前合作单位</h2></div></div>
    <partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.Partners" />
    @if (Model.Partners.Count == 0)
    {
        <p class="panel-copy">还没有合作单位档案。</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table" id="partners-table">
<thead><tr><th data-column-key="number">编号</th><th data-column-key="name">单位名称</th><th data-column-key="roles">角色</th><th data-column-key="contact">主要联系人</th><th data-column-key="projects">参与项目</th><th data-column-key="actions">操作</th></tr></thead>
                <tbody>
                @foreach (var partner in Model.Partners)
                {
                    <tr>
<td data-column-key="number">@partner.PartnerNumber</td><td data-column-key="name"><a asp-page="/Partners/Create" asp-route-id="@partner.Id">@partner.Name</a></td>
                        <td data-column-key="roles">@string.Join("、", partner.Roles.Select(role => role.RoleType))</td>
                        <td data-column-key="contact">@(partner.Contacts.FirstOrDefault(contact => contact.IsPrimary)?.Name ?? "未设置")</td>
<td data-column-key="projects">@partner.ProjectCount</td><td data-column-key="actions"><a asp-page="/Partners/Create" asp-route-id="@partner.Id">编辑</a> · <a asp-page="/Partners/Create" asp-route-copyFrom="@partner.Id">复制</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
