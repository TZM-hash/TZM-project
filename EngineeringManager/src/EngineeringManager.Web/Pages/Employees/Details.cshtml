@page
@model EngineeringManager.Web.Pages.Employees.DetailsModel
@using EngineeringManager.Domain.Employees
@using EngineeringManager.Domain.Finance
@using EngineeringManager.Domain.Certificates
@using EngineeringManager.Web.Presentation
@{
    ViewData["Title"] = "员工详情";
    var affiliation = Model.Employee.Affiliations.FirstOrDefault(item => item.IsPrimary);
    var wageType = Model.WageSubtab switch { "attendance" => EmployeeWageEntryType.Attendance, "overtime" => EmployeeWageEntryType.Overtime, "bonus" => EmployeeWageEntryType.Bonus, "penalty" => EmployeeWageEntryType.Penalty, "other" => EmployeeWageEntryType.Other, _ => (EmployeeWageEntryType?)null };
    var wageRows = wageType.HasValue ? Model.WageEntries.Where(item => item.EntryType == wageType.Value).ToArray() : Model.WageEntries;
    var paymentCategory = Model.PaymentSubtab == "wage" ? PayrollPaymentCategory.Wage : Model.PaymentSubtab == "other" ? PayrollPaymentCategory.Other : (PayrollPaymentCategory?)null;
    var paymentRows = Model.Ledger?.ReceiptLines.Where(item => !paymentCategory.HasValue || item.PaymentCategory == paymentCategory.Value).ToArray() ?? [];
    var dividendType = Model.DividendSubtab switch { "dividend" => EmployeeLedgerEntryType.Dividend, "interest" => EmployeeLedgerEntryType.Interest, "other" => EmployeeLedgerEntryType.Other, _ => (EmployeeLedgerEntryType?)null };
    var otherRows = dividendType.HasValue ? Model.OtherPayables.Where(item => item.EntryType == dividendType.Value).ToArray() : Model.OtherPayables.ToArray();
}

<section class="page-heading employee-detail-heading">
    <div><p class="eyebrow">@Model.Employee.EmployeeNumber</p><h1>@Model.Employee.Name</h1><p class="page-lead">@Model.Employee.EmployeeType.ToChinese() · @(Model.Employee.PositionTitle ?? affiliation?.PositionTitle ?? "未设置岗位") · @(affiliation?.LegalEntityName ?? "未归属公司") · @(affiliation?.DepartmentName ?? "未归属部门")</p></div>
    <div class="page-actions-inline"><span class="status-chip @(Model.Employee.IsActive ? "status-chip--success" : "status-chip--muted")">@(Model.Employee.IsActive ? "启用" : "停用")</span><a class="button button--secondary button--action" asp-page="/Employees/Create" asp-route-id="@Model.Id">详细编辑</a><a class="button button--secondary button--action" asp-page="/Employees/Create" asp-route-copyFrom="@Model.Id">复制员工</a></div>
</section>

<form method="get" class="employee-year-picker"><input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="tab" value="@Model.Tab" /><label>业务年度<select name="businessYearId" onchange="this.form.submit()">@foreach (var year in Model.BusinessYears) { <option value="@year.Id" selected="@(year.Id == Model.BusinessYearId ? "selected" : null)">@year.Name</option> }</select></label></form>

@if (Model.Ledger is not null)
{
    <section class="overview-strip employee-detail-overview" aria-label="员工年度总账"><article><span>往年结转</span><strong>@Model.Ledger.Summary.PriorYearCarryForward.ToString("N2")</strong></article><article><span>工资应付</span><strong>@Model.Ledger.Summary.CurrentYearWagePayable.ToString("N2")</strong></article><article><span>报销应付</span><strong>@Model.Ledger.Summary.ExpensePayable.ToString("N2")</strong></article><article><span>利息分红及其他应付</span><strong>@Model.Ledger.Summary.OtherPayable.ToString("N2")</strong></article><article><span>本年应付合计</span><strong>@Model.Ledger.Summary.CurrentYearNewPayable.ToString("N2")</strong></article><article><span>已付款</span><strong>@Model.Ledger.Summary.ReceivedAmount.ToString("N2")</strong></article><article class="is-warning"><span>未付款</span><strong>@Model.Ledger.Summary.CurrentBalance.ToString("N2")</strong></article><article><span>结算进度</span><strong>@Model.Ledger.Summary.SettlementProgressPercent.ToString("N2")%</strong></article></section>
}

<section class="panel employee-profile-panel inline-edit-shell" data-inline-edit="employee-profile" data-inline-cell-edit>
    <div class="panel-heading"><div><p class="eyebrow">基础资料</p><h2>员工档案</h2></div>@if (Model.CanManageEmployee) { <button class="button button--secondary button--action" type="button" data-inline-edit-open>快捷编辑</button> }</div>
    <div class="detail-grid employee-profile-grid"><div><span>员工编号</span><strong data-inline-edit-value>@Model.Employee.EmployeeNumber</strong><input data-inline-edit-control class="inline-cell-control" name="EmployeeInput.EmployeeNumber" value="@Model.Employee.EmployeeNumber" hidden form="employee-profile-form" /></div><div><span>姓名</span><strong data-inline-edit-value>@Model.Employee.Name</strong><input data-inline-edit-control class="inline-cell-control" name="EmployeeInput.Name" value="@Model.Employee.Name" hidden form="employee-profile-form" /></div><div><span>员工类型</span><strong data-inline-edit-value>@Model.Employee.EmployeeType.ToChinese()</strong><select data-inline-edit-control class="inline-cell-control" name="EmployeeInput.EmployeeType" hidden form="employee-profile-form"><option value="1" selected="@(Model.Employee.EmployeeType == EmployeeType.Formal ? "selected" : null)">正式员工</option><option value="2" selected="@(Model.Employee.EmployeeType == EmployeeType.Labor ? "selected" : null)">劳务员工</option><option value="3" selected="@(Model.Employee.EmployeeType == EmployeeType.Temporary ? "selected" : null)">特殊临时人员</option></select></div><div><span>岗位</span><strong data-inline-edit-value>@(Model.Employee.PositionTitle ?? "未填写")</strong><input data-inline-edit-control class="inline-cell-control" name="EmployeeInput.PositionTitle" value="@Model.Employee.PositionTitle" hidden form="employee-profile-form" /></div><div><span>电话</span><strong data-inline-edit-value>@(Model.Employee.Phone ?? "未填写")</strong><input data-inline-edit-control class="inline-cell-control" name="EmployeeInput.Phone" value="@Model.Employee.Phone" hidden form="employee-profile-form" /></div><div><span>身份证</span><strong>@(Model.Employee.IdentityNumber ?? "未填写")</strong></div><div><span>银行卡</span><strong>@(Model.Employee.BankAccountNumber ?? "未填写")</strong></div><div><span>开户行</span><strong>@(Model.Employee.BankName ?? "未填写")</strong></div><div><span>入职日期</span><strong>@(Model.Employee.HireDate?.ToString("yyyy-MM-dd") ?? "未填写")</strong></div><div><span>当前公司</span><strong>@(affiliation?.LegalEntityName ?? "未归属")</strong></div><div><span>当前部门</span><strong>@(affiliation?.DepartmentName ?? "未归属")</strong></div><div><span>当前项目</span><strong>@(affiliation?.ProjectName ?? "未归属")</strong></div></div>
    @if (Model.CanManageEmployee) { <form id="employee-profile-form" method="post" asp-page-handler="UpdateEmployee" class="inline-edit-actions" data-inline-edit-actions hidden><input type="hidden" name="Id" value="@Model.Id" /><input type="hidden" name="BusinessYearId" value="@Model.BusinessYearId" /><input type="hidden" name="Tab" value="@Model.Tab" /><input type="hidden" name="EmployeeInput.IdentityNumber" value="@Model.Employee.IdentityNumber" /><input type="hidden" name="EmployeeInput.BankAccountNumber" value="@Model.Employee.BankAccountNumber" /><input type="hidden" name="EmployeeInput.BankName" value="@Model.Employee.BankName" /><input type="hidden" name="EmployeeInput.HireDate" value="@Model.Employee.HireDate?.ToString("yyyy-MM-dd")" /><input type="hidden" name="EmployeeInput.LeaveDate" value="@Model.Employee.LeaveDate?.ToString("yyyy-MM-dd")" /><input type="hidden" name="EmployeeInput.DefaultLegalEntityId" value="@Model.Employee.DefaultLegalEntityId" /><input type="hidden" name="EmployeeInput.DefaultMonthlySalary" value="@Model.Employee.DefaultMonthlySalary" /><input type="hidden" name="EmployeeInput.DefaultDailyRate" value="@Model.Employee.DefaultDailyRate" /><input type="hidden" name="EmployeeInput.DefaultHourlyRate" value="@Model.Employee.DefaultHourlyRate" /><input type="hidden" name="EmployeeInput.DefaultPieceworkRate" value="@Model.Employee.DefaultPieceworkRate" /><input type="hidden" name="EmployeeInput.IsActive" value="@Model.Employee.IsActive" /><input type="hidden" name="EmployeeInput.ConcurrencyStamp" value="@Model.Employee.ConcurrencyStamp" /><input type="hidden" name="EmployeeInput.Reason" value="快捷编辑员工资料" /><button class="button button--secondary button--small" type="button" data-inline-edit-cancel>取消</button><button class="button button--primary button--small" type="submit">保存</button></form> }
</section>

<div class="employee-detail-layout"><main>
    <nav class="page-tabs employee-main-tabs" aria-label="员工详情标签">
        <a data-employee-main-tab class="@(Model.Tab == "wages" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages">工资明细</a>
        <a data-employee-main-tab class="@(Model.Tab == "expenses" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="expenses">报销明细</a>
        <a data-employee-main-tab class="@(Model.Tab == "dividends" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="dividends">利息分红</a>
        <a data-employee-main-tab class="@(Model.Tab == "payments" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="payments">付款记录</a>
        <a data-employee-main-tab class="@(Model.Tab == "certificates" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="certificates">证书管理</a>
    </nav>

    <section class="panel employee-tab-panel" data-employee-tab-panel="wages" hidden="@(Model.Tab == "wages" ? null : "hidden")">
        <div class="subtabs" role="tablist"><a class="@(Model.WageSubtab == "all" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages" asp-route-wageSubtab="all">全部</a><a class="@(Model.WageSubtab == "attendance" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages" asp-route-wageSubtab="attendance">考勤工资</a><a class="@(Model.WageSubtab == "overtime" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages" asp-route-wageSubtab="overtime">加班工资</a><a class="@(Model.WageSubtab == "bonus" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages" asp-route-wageSubtab="bonus">奖金</a><a class="@(Model.WageSubtab == "penalty" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages" asp-route-wageSubtab="penalty">罚款</a><a class="@(Model.WageSubtab == "other" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages" asp-route-wageSubtab="other">其他</a></div>
        <div class="overview-strip employee-wage-summary"><article><span>工资应付合计</span><strong>@wageRows.Sum(item => item.FinalAmount).ToString("N2")</strong></article><article><span>系统自动记录</span><strong>@wageRows.Count(item => item.IsSystemGenerated)</strong></article></div>
        @if (Model.CanEditFinancial) { <details class="workspace-create"><summary class="button button--secondary">新增工资明细</summary><form method="post" enctype="multipart/form-data" asp-page-handler="AddWage" class="form-grid"><label>开始日期<input asp-for="WageInput.StartDate" type="date" /></label><label>结束日期<input asp-for="WageInput.EndDate" type="date" /></label><label>分类<select asp-for="WageInput.EntryType"><option value="1">考勤工资</option><option value="2">加班工资</option><option value="3">奖金</option><option value="4">罚款</option><option value="5">其他</option></select></label><label>工资性质<select asp-for="WageInput.WageCategory"><option value="1">社保工资</option><option value="2">民工工资</option><option value="3">其他工资</option></select></label><label>单位<input asp-for="WageInput.Unit" /></label><label>手工金额<input asp-for="WageInput.ManualAmount" type="number" step="0.01" /></label><label>公司<select asp-for="WageInput.LegalEntityId"><option value="">未归属</option>@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>项目<select asp-for="WageInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>劳务公司<select asp-for="WageInput.LaborBusinessPartnerId"><option value="">未填写</option>@foreach (var item in Model.LaborPartners) { <option value="@item.Id">@item.Name</option> }</select></label><label>附件<input asp-for="WageInput.Attachment" type="file" /></label><label>备注<textarea asp-for="WageInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存</button></form></details> }
        <div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>分类</th><th>工资性质</th><th>公司</th><th>项目/劳务公司</th><th>金额</th><th>附件</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var row in wageRows) { <tr class="@(row.IsSystemGenerated ? "is-system-generated" : null)" data-inline-edit data-inline-cell-edit><td>@row.StartDate - @row.EndDate</td><td>@EmployeeDisplayText.WageEntryType(row.EntryType)</td><td>@EmployeeDisplayText.WageCategory(row.WageCategory)</td><td>@(row.LegalEntityName ?? "未归属")</td><td>@(row.ProjectName ?? row.LaborBusinessPartnerName ?? "未归属")</td><td class="numeric-cell">@row.FinalAmount.ToString("N2")</td><td>@(row.AttachmentFileName ?? "无")</td><td>@(row.Notes ?? "")</td><td>@if (row.IsSystemGenerated && row.SourcePersonalAdvanceBatchId.HasValue) { <a asp-page="/Payroll/Edit" asp-route-id="@row.SourcePersonalAdvanceBatchId" asp-route-returnUrl="@($"/Employees/Details?id={Model.Id}&businessYearId={Model.BusinessYearId}&tab=wages")">查看来源批次</a> } else if (Model.CanEditFinancial) { <button class="button button--secondary button--small" type="button" data-inline-edit-open>编辑</button><form method="post" asp-page-handler="UpdateWage" class="inline-row-form" data-inline-edit-actions hidden><input type="hidden" name="WageEdit.Id" value="@row.Id" /><input type="hidden" name="WageEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input type="hidden" name="WageEdit.StartDate" value="@row.StartDate.ToString("yyyy-MM-dd")" /><input type="hidden" name="WageEdit.EndDate" value="@row.EndDate.ToString("yyyy-MM-dd")" /><input type="hidden" name="WageEdit.EntryType" value="@row.EntryType" /><input type="hidden" name="WageEdit.WageCategory" value="@row.WageCategory" /><input type="hidden" name="WageEdit.CalculationMethod" value="1" /><input type="hidden" name="WageEdit.Nature" value="@row.Nature" /><input type="hidden" name="WageEdit.ManualAmount" value="@Math.Abs(row.FinalAmount)" /><input type="hidden" name="WageEdit.LegalEntityId" value="@row.LegalEntityId" /><input type="hidden" name="WageEdit.ProjectId" value="@row.ProjectId" /><input type="hidden" name="WageEdit.LaborBusinessPartnerId" value="@row.LaborBusinessPartnerId" /><input type="hidden" name="WageEdit.AdjustmentAmount" value="0" /><input name="WageEdit.Notes" value="@row.Notes" /><input name="WageEdit.Reason" value="修改工资明细" /><button class="button button--secondary button--small" type="button" data-inline-edit-cancel>取消</button><button class="button button--primary button--small" type="submit">保存</button></form> }</td></tr> }</tbody></table></div>
    </section>

    <section class="panel employee-tab-panel" data-employee-tab-panel="expenses" hidden="@(Model.Tab == "expenses" ? null : "hidden")"><div class="overview-strip"><article class="is-accent"><span>报销总金额</span><strong>@Model.Expenses.Sum(item => item.Amount).ToString("N2")</strong></article></div>@if (Model.CanEditFinancial) { <details class="workspace-create"><summary class="button button--secondary">新增报销</summary><form method="post" enctype="multipart/form-data" asp-page-handler="AddExpense" class="form-grid"><label>报销日期<input asp-for="ExpenseInput.ExpenseDate" type="date" /></label><label>报销金额<input asp-for="ExpenseInput.Amount" type="number" step="0.01" /></label><label>项目<select asp-for="ExpenseInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>公司<select asp-for="ExpenseInput.LegalEntityId">@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>票据号<input asp-for="ExpenseInput.ReceiptNumber" /></label><label>附件<input asp-for="ExpenseInput.Attachment" type="file" /></label><label>备注<textarea asp-for="ExpenseInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存</button></form></details> }<div class="table-wrap"><table class="data-table"><thead><tr><th>报销日期</th><th>报销金额</th><th>项目</th><th>票据号</th><th>附件</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var row in Model.Expenses) { <tr data-inline-edit data-inline-cell-edit><td>@row.ExpenseDate</td><td class="numeric-cell">@row.Amount.ToString("N2")</td><td>@(row.ProjectName ?? "未归属")</td><td>@(row.ReceiptNumber ?? "")</td><td>@(row.AttachmentFileName ?? "无")</td><td>@(row.Description ?? "")</td><td>@if (Model.CanEditFinancial) { <button class="button button--secondary button--small" type="button" data-inline-edit-open>编辑</button><form method="post" asp-page-handler="UpdateExpense" class="inline-row-form" data-inline-edit-actions hidden><input type="hidden" name="ExpenseEdit.Id" value="@row.Id" /><input type="hidden" name="ExpenseEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input type="hidden" name="ExpenseEdit.ExpenseDate" value="@row.ExpenseDate.ToString("yyyy-MM-dd")" /><input name="ExpenseEdit.Amount" value="@row.Amount" type="number" step="0.01" /><input type="hidden" name="ExpenseEdit.ProjectId" value="@row.ProjectId" /><input name="ExpenseEdit.ReceiptNumber" value="@row.ReceiptNumber" /><input name="ExpenseEdit.Description" value="@row.Description" /><input name="ExpenseEdit.Reason" value="修改报销金额" /><button class="button button--secondary button--small" type="button" data-inline-edit-cancel>取消</button><button class="button button--primary button--small" type="submit">保存</button></form> }</td></tr> }</tbody></table></div></section>

    <section class="panel employee-tab-panel" data-employee-tab-panel="dividends" hidden="@(Model.Tab == "dividends" ? null : "hidden")"><div class="subtabs" role="tablist"><a class="@(Model.DividendSubtab == "all" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="dividends" asp-route-dividendSubtab="all">全部</a><a class="@(Model.DividendSubtab == "dividend" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="dividends" asp-route-dividendSubtab="dividend">分红</a><a class="@(Model.DividendSubtab == "interest" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="dividends" asp-route-dividendSubtab="interest">利息</a><a class="@(Model.DividendSubtab == "other" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="dividends" asp-route-dividendSubtab="other">其他应付</a></div>@if (Model.CanEditFinancial) { <details class="workspace-create"><summary class="button button--secondary">新增利息分红</summary><form method="post" asp-page-handler="AddOtherPayable" class="form-grid"><label>日期<input asp-for="OtherInput.EntryDate" type="date" /></label><label>类型<select asp-for="OtherInput.EntryType"><option value="4">分红</option><option value="5">利息</option><option value="6">其他应付</option></select></label><label>金额<input asp-for="OtherInput.Amount" type="number" step="0.01" /></label><label>公司<select asp-for="OtherInput.LegalEntityId">@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>项目<select asp-for="OtherInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>备注<textarea asp-for="OtherInput.Description"></textarea></label><button class="button button--primary" type="submit">保存</button></form></details> }<div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>类型</th><th>金额</th><th>公司</th><th>项目</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var row in otherRows) { <tr data-inline-edit data-inline-cell-edit><td>@row.EntryDate</td><td>@(row.EntryType == EmployeeLedgerEntryType.Dividend ? "分红" : row.EntryType == EmployeeLedgerEntryType.Interest ? "利息" : "其他应付")</td><td class="numeric-cell">@row.Amount.ToString("N2")</td><td>@row.LegalEntityName</td><td>@(row.ProjectName ?? "未归属")</td><td>@(row.Description ?? "")</td><td>@if (Model.CanEditFinancial) { <button class="button button--secondary button--small" type="button" data-inline-edit-open>编辑</button><form method="post" asp-page-handler="UpdateOtherPayable" class="inline-row-form" data-inline-edit-actions hidden><input type="hidden" name="OtherEdit.Id" value="@row.Id" /><input type="hidden" name="OtherEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input type="hidden" name="OtherEdit.EntryDate" value="@row.EntryDate.ToString("yyyy-MM-dd")" /><input name="OtherEdit.Amount" value="@row.Amount" type="number" step="0.01" /><input name="OtherEdit.EntryType" value="@row.EntryType" /><input type="hidden" name="OtherEdit.LegalEntityId" value="@row.LegalEntityId" /><input type="hidden" name="OtherEdit.ProjectId" value="@row.ProjectId" /><input name="OtherEdit.Description" value="@row.Description" /><input name="OtherEdit.Reason" value="修改利息分红" /><button class="button button--secondary button--small" type="button" data-inline-edit-cancel>取消</button><button class="button button--primary button--small" type="submit">保存</button></form> }</td></tr> }</tbody></table></div></section>

    <section class="panel employee-tab-panel" data-employee-tab-panel="payments" hidden="@(Model.Tab == "payments" ? null : "hidden")"><div class="subtabs" role="tablist"><a class="@(Model.PaymentSubtab == "all" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="payments" asp-route-paymentSubtab="all">全部</a><a class="@(Model.PaymentSubtab == "wage" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="payments" asp-route-paymentSubtab="wage">工资</a><a class="@(Model.PaymentSubtab == "other" ? "is-active" : null)" asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="payments" asp-route-paymentSubtab="other">其他</a></div><p class="panel-copy">付款记录由工资台账和中央账本维护，本页只供查看。</p><div class="table-wrap"><table class="data-table"><thead><tr><th>付款日期</th><th>类别</th><th>来源</th><th>收款人</th><th>金额</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var row in paymentRows) { <tr><td>@row.ReceiptDate</td><td>@EmployeeDisplayText.PaymentCategory(row.PaymentCategory)</td><td>@row.SourceType</td><td>@(row.Recipient ?? "未填写")</td><td class="numeric-cell">@row.Amount.ToString("N2")</td><td>@(row.Notes ?? "")</td><td>@if (row.PayrollBatchId.HasValue) { <a asp-page="/Payroll/Edit" asp-route-id="@row.PayrollBatchId" asp-route-lineId="@row.PayrollPaymentId" asp-route-returnUrl="@($"/Employees/Details?id={Model.Id}&businessYearId={Model.BusinessYearId}&tab=payments")">查看来源批次</a> }</td></tr> }</tbody></table></div></section>

    <section class="panel employee-tab-panel" data-employee-tab-panel="certificates" hidden="@(Model.Tab == "certificates" ? null : "hidden")"><div class="panel-heading"><div><p class="eyebrow">证书资料</p><h2>证书管理</h2></div>@if (Model.CanManageEmployee) { <a class="button button--secondary button--action" asp-page="/Employees/Certificates/Edit" asp-route-employeeId="@Model.Id">新增证书</a> }</div><div class="overview-strip certificate-summary" aria-label="证书摘要"><article><span>证书摘要</span><strong>@Model.Certificates.Count</strong></article><article><span>已过期</span><strong>@Model.Certificates.Count(item => item.State == CertificateExpiryState.Expired)</strong></article><article><span>三个月内到期</span><strong>@Model.Certificates.Count(item => item.State is CertificateExpiryState.Info or CertificateExpiryState.Warning or CertificateExpiryState.Critical)</strong></article></div><div class="table-wrap"><table class="data-table"><thead><tr><th>证书</th><th>编号</th><th>有效期</th><th>状态</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var certificate in Model.Certificates) { <tr><td>@certificate.CertificateType</td><td>@certificate.CertificateNumber</td><td>@(certificate.ExpiresOn?.ToString("yyyy-MM-dd") ?? "长期有效")</td><td>@(certificate.State switch { CertificateExpiryState.LongTerm => "长期有效", CertificateExpiryState.Normal => "有效", CertificateExpiryState.Info => "轻度提醒", CertificateExpiryState.Warning => "中度提醒", CertificateExpiryState.Critical => "重度提醒", CertificateExpiryState.Expired => "已过期", _ => "未知" })</td><td>@certificate.Notes</td><td>@if (Model.CanManageEmployee) { <a asp-page="/Employees/Certificates/Edit" asp-route-id="@certificate.Id">编辑</a> }</td></tr> }</tbody></table></div></section>
</main>
<aside class="panel employee-activity-rail"><div class="panel-heading"><div><p class="eyebrow">动态</p><h2>历史记录</h2></div></div><ol class="activity-list">@foreach (var item in (Model.Ledger?.PayableLines.Where(item => item.Category == AnnualLedgerEntryCategory.Adjustment || item.Category == AnnualLedgerEntryCategory.OpeningBalance).OrderByDescending(item => item.EntryDate).Take(8) ?? [])) { <li><time>@item.EntryDate</time><strong>@item.SourceType</strong><span>@item.Description</span><em>@item.Amount.ToString("N2")</em></li> } @foreach (var item in Model.WageEntries.Where(item => item.IsSystemGenerated).Take(8)) { <li><time>@item.StartDate</time><strong>个人垫付来源</strong><span>@item.Notes</span><em>@item.FinalAmount.ToString("N2")</em></li> }</ol></aside></div>
