@page
@model EngineeringManager.Web.Areas.Identity.Pages.Account.LoginModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "登录";
}

<section class="page-heading"><div><p class="eyebrow">安全访问</p><h1>内部账号登录</h1><p class="page-lead">系统仅供公司内部使用，不开放公开注册。账号由系统管理员或应用管理员创建。</p></div></section>
<section class="content-grid public-home"><article class="panel login-panel"><div class="panel-heading"><div><p class="eyebrow">工程项目经营管理系统</p><h2>登录系统</h2></div></div><form method="post" class="form-stack"><input type="hidden" name="returnUrl" value="@Model.ReturnUrl" /><label asp-for="Input.Email"></label><input asp-for="Input.Email" autocomplete="username" /><span asp-validation-for="Input.Email" class="validation-message"></span><label asp-for="Input.Password"></label><input asp-for="Input.Password" autocomplete="current-password" /><span asp-validation-for="Input.Password" class="validation-message"></span><label class="checkbox-row"><input asp-for="Input.RememberMe" /> <span>保持登录</span></label><div asp-validation-summary="ModelOnly" class="validation-summary"></div><button class="button button--primary" type="submit">登录</button></form></article><article class="panel"><p class="eyebrow">账号管理</p><h2>无法登录？</h2><p class="panel-copy">请联系系统管理员或应用管理员检查账号状态、重置密码或调整权限。系统不提供自助注册入口。</p><a class="button button--secondary" asp-page="/Index" asp-area="">返回首页</a></article></section>
