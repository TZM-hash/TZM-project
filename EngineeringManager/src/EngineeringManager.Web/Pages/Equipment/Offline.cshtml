@page
@model EngineeringManager.Web.Pages.Equipment.OfflineModel
@{ ViewData["Title"] = "设备现场离线记录"; }
<section class="page-heading"><div><p class="eyebrow">有限离线 · 设备现场</p><h1>设备现场离线记录</h1><p class="page-lead">可离线填写进退场、施工/停工日期段、备注和照片；租金、最终结算与财务数据必须联网操作。</p></div><div class="pwa-badge">本机草稿</div></section>
<section class="offline-workspace" data-offline-equipment data-user-id="@Model.CurrentUserId"><form class="panel form-grid" data-equipment-draft-form>@Html.AntiForgeryToken()<input type="hidden" name="clientDraftId" /><label>设备 ID<input name="equipmentId" required /></label><label>项目 ID<input name="projectId" required /></label><label>签约公司 ID<input name="legalEntityId" required /></label><label>进场日期<input name="entryDate" type="date" required /></label><label>退场日期<input name="exitDate" type="date" /></label><div class="form-span panel" data-equipment-period><p class="eyebrow">施工/停工日期段</p><label>开始<input name="periodStart" type="date" /></label><label>结束<input name="periodEnd" type="date" /></label><label>类型<select name="periodType"><option value="1">施工</option><option value="2">停工</option></select></label><label class="checkbox-field"><input name="periodChargeable" type="checkbox" />停工计租</label><label>备注<input name="periodNotes" /></label></div><label class="form-span">现场备注<textarea name="notes" rows="3"></textarea></label><label class="form-span">照片（最多 20 张、单张 3 MB）<input type="file" accept="image/jpeg,image/png,image/webp" capture="environment" multiple data-equipment-photos /></label><div class="form-span button-row"><button class="button button--primary">保存到本机</button><button type="button" class="button button--danger" data-equipment-clear>清除当前用户本机数据</button></div></form><aside class="panel"><p class="eyebrow">同步状态</p><h2>设备草稿队列</h2><p class="panel-copy" data-equipment-offline-message>草稿按当前登录用户隔离保存。</p></aside></section>
@section Scripts { <script src="~/js/offline-equipment.js" asp-append-version="true"></script> }
