@page
@model EngineeringManager.Web.Pages.Payroll.EditModel
@using EngineeringManager.Domain.Employees
@using EngineeringManager.Domain.Finance
@{ ViewData["Title"] = Model.Id.HasValue ? "编辑工资批次" : "新建工资批次"; }

<section class="page-heading"><div><p class="eyebrow">统一发放明细</p><h1>@ViewData["Title"]</h1><p class="page-lead">一个批次对应一个日期、一个公司、一个账户和至多一个项目；全部人员金额必须与实际发放总额核对。</p></div><a class="button button--secondary" asp-page="/Payroll/Index">返回工资台账</a></section>
<form method="post" class="payroll-editor" data-payroll-editor>
    <div asp-validation-summary="All" class="panel-copy"></div><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="LineId" /><input type="hidden" asp-for="ReturnUrl" /><input type="hidden" asp-for="Input.ConcurrencyStamp" />
    <section class="panel form-section"><h2 class="section-heading">批次基本信息</h2><div class="form-grid"><label>批次编号<input asp-for="Input.BatchNumber" required /></label><label>批次名称<input asp-for="Input.Name" required /></label><label>发放日期<input asp-for="Input.PaymentDate" type="date" /></label><label>发放项目<select asp-for="Input.ProjectId"><option value="">暂未填写</option>@foreach (var item in Model.Projects) { <option value="@item.Id">@item.Label</option> }</select></label><label>发放公司<select asp-for="Input.LegalEntityId"><option value="">暂未填写</option>@foreach (var item in Model.Companies) { <option value="@item.Id">@item.Label</option> }</select></label><label>付款账户<select asp-for="Input.AccountId"><option value="">暂未填写</option>@foreach (var item in Model.Accounts) { <option value="@item.Id">@item.Label</option> }</select></label><label>实际发放总金额<input asp-for="Input.ActualAmount" type="number" step="0.01" data-payroll-actual /></label><label>支付方式<select asp-for="Input.PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select></label><label>付款凭证号<input asp-for="Input.VoucherNumber" /></label><label>状态<select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<PayrollBatchStatus>()"></select></label><label class="form-grid-span">备注<textarea asp-for="Input.Notes"></textarea></label><label class="form-grid-span">修改原因<input asp-for="Input.Reason" required /></label></div></section>
    <section class="panel"><div class="panel-heading"><div><p class="eyebrow">内部人员</p><h2>自有员工</h2></div></div><div class="table-wrap"><table class="data-table payroll-line-table"><thead><tr><th>选择</th><th>员工</th><th>实际金额</th><th>说明</th></tr></thead><tbody>@for (var i = 0; i < Model.Input.EmployeeLines.Count; i++) { var line = Model.Input.EmployeeLines[i]; <tr data-payroll-line-id="@line.PaymentId" class="@(Model.LineId == line.PaymentId ? "is-highlighted" : null)"><td><input asp-for="Input.EmployeeLines[i].Selected" /><input type="hidden" asp-for="Input.EmployeeLines[i].PaymentId" /><input type="hidden" asp-for="Input.EmployeeLines[i].PersonId" /><input type="hidden" asp-for="Input.EmployeeLines[i].Label" /></td><td>@line.Label</td><td><input asp-for="Input.EmployeeLines[i].Amount" type="number" step="0.01" data-payroll-amount /></td><td><input asp-for="Input.EmployeeLines[i].Notes" /></td></tr> }</tbody></table></div></section>
    <section class="panel"><div class="panel-heading"><div><p class="eyebrow">工程款代发</p><h2>施工班组人员</h2><small>班组人员金额按班组自动汇总为项目工程款。</small></div><a class="button button--secondary button--small" asp-page="/Crews/Index">管理班组名册</a></div><div class="table-wrap"><table class="data-table payroll-line-table"><thead><tr><th>选择</th><th>施工班组</th><th>人员</th><th>实际金额</th><th>说明</th></tr></thead><tbody>@for (var i = 0; i < Model.Input.CrewLines.Count; i++) { var line = Model.Input.CrewLines[i]; <tr data-payroll-line-id="@line.PaymentId" class="@(Model.LineId == line.PaymentId ? "is-highlighted" : null)"><td><input asp-for="Input.CrewLines[i].Selected" /><input type="hidden" asp-for="Input.CrewLines[i].PaymentId" /><input type="hidden" asp-for="Input.CrewLines[i].PersonId" /><input type="hidden" asp-for="Input.CrewLines[i].CrewBusinessPartnerId" /><input type="hidden" asp-for="Input.CrewLines[i].CrewName" /><input type="hidden" asp-for="Input.CrewLines[i].Label" /></td><td>@line.CrewName</td><td>@line.Label</td><td><input asp-for="Input.CrewLines[i].Amount" type="number" step="0.01" data-payroll-amount /></td><td><input asp-for="Input.CrewLines[i].Notes" /></td></tr> }</tbody></table></div></section>
    <section class="panel payroll-reconciliation"><div><span>人员明细合计</span><strong data-payroll-detail-total>0.00</strong></div><div><span>实际发放总额</span><strong data-payroll-actual-total>@Model.Input.ActualAmount.ToString("N2")</strong></div><div><span>批次差额</span><strong data-payroll-difference>0.00</strong></div></section>
    <div class="sticky-actions"><a class="button button--secondary" asp-page="/Payroll/Index">取消</a><button class="button button--primary" type="submit">保存工资批次</button></div>
</form>
@section Scripts { <script>document.addEventListener('input',function(){const root=document.querySelector('[data-payroll-editor]');if(!root)return;let sum=0;root.querySelectorAll('[data-payroll-amount]').forEach(function(input){const row=input.closest('tr');const selected=row?.querySelector('input[type=checkbox]');if(selected?.checked)sum+=Number(input.value||0);});const actual=Number(root.querySelector('[data-payroll-actual]')?.value||0);root.querySelector('[data-payroll-detail-total]').textContent=sum.toFixed(2);root.querySelector('[data-payroll-actual-total]').textContent=actual.toFixed(2);root.querySelector('[data-payroll-difference]').textContent=(actual-sum).toFixed(2);});document.dispatchEvent(new Event('input'));</script> }
