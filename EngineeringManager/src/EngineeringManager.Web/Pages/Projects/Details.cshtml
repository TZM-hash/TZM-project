                                    <label><input asp-for="ConstructionEdit.AutoConnectPrevious" type="checkbox" /> 自动连接上个项目</label><label class="inline-edit-span">备注<input asp-for="ConstructionEdit.Notes" /></label><label class="inline-edit-span">修改原因<input asp-for="ConstructionEdit.Reason" /></label>
                                </div><div class="inline-edit-actions"><button class="button button--primary" type="submit">新增记录</button></div></form></details>
                                <details class="inline-create-details"><summary>新建设备主档</summary><form method="post" asp-page-handler="CreateEquipment" class="inline-edit-panel"><div class="inline-edit-grid"><label>设备编号<input asp-for="NewEquipment.EquipmentNumber" /></label><label>设备名称<input asp-for="NewEquipment.Name" /></label><label>型号<input asp-for="NewEquipment.Model" /></label><label>分类<input asp-for="NewEquipment.Category" /></label><label>权属<select asp-for="NewEquipment.OwnershipType" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Equipment.EquipmentOwnershipType>()"></select></label><label>所属公司（自有）<select asp-for="NewEquipment.OwnerLegalEntityId"><option value="">请选择</option>@foreach (var option in Model.FinanceOptions.LegalEntities) { <option value="@option.Id">@option.Label</option> }</select></label><label>出租方（租赁）<select asp-for="NewEquipment.LessorBusinessPartnerId"><option value="">请选择</option>@foreach (var option in Model.FinanceOptions.BusinessPartners) { <option value="@option.Id">@option.Label</option> }</select></label><label>内部日租金<input asp-for="NewEquipment.InternalDailyRate" type="number" step="0.01" /></label><label class="inline-edit-span">创建原因<input asp-for="NewEquipment.Reason" /></label></div><button class="button button--primary" type="submit">创建并加入本项目</button></form></details>
                                <details class="inline-create-details"><summary>新建施工班组主档</summary><form method="post" asp-page-handler="CreateCrew" class="inline-edit-panel"><div class="inline-edit-grid"><label>班组编号<input asp-for="NewCrew.PartnerNumber" /></label><label>班组名称<input asp-for="NewCrew.Name" /></label><label>联系人<input asp-for="NewCrew.ContactName" /></label><label>联系电话<input asp-for="NewCrew.ContactPhone" /></label><label class="inline-edit-span">创建原因<input asp-for="NewCrew.Reason" /></label></div><button class="button button--primary" type="submit">创建并加入本项目</button></form></details>
                            </div>
                        }
                        <div asp-validation-summary="All" class="panel-copy"></div>
                        <div class="table-wrap"><table class="data-table construction-detail-table"><thead><tr><th>类型</th><th>设备/施工班组</th><th>从哪个项目调入</th><th>进场日期</th><th>退场日期</th><th>总天数</th><th>停工天数</th><th>施工天数</th><th>退场到哪个项目</th><th>备注</th><th>操作</th></tr></thead><tbody>
                        @foreach (var row in Model.ConstructionWorkspace.Records)
                        {
                            var formId = $"construction-row-{row.Id:N}";
                            <tr data-construction-row><td><span data-inline-edit-value>@(row.RecordType == ProjectConstructionRecordType.Equipment ? "设备" : "施工班组")</span><select class="inline-cell-control" name="ConstructionEdit.RecordType" form="@formId" data-inline-edit-control hidden><option value="1" selected="@(row.RecordType == ProjectConstructionRecordType.Equipment ? "selected" : null)">设备</option><option value="2" selected="@(row.RecordType == ProjectConstructionRecordType.ConstructionCrew ? "selected" : null)">施工班组</option></select></td><td><span data-inline-edit-value>@row.SubjectLabel</span><select class="inline-cell-control" name="ConstructionEdit.SubjectId" form="@formId" data-inline-edit-control hidden>@foreach (var option in (row.RecordType == ProjectConstructionRecordType.Equipment ? Model.ConstructionWorkspace.Equipment : Model.ConstructionWorkspace.Crews)) { <option value="@option.Id" selected="@(option.Id == row.SubjectId ? "selected" : null)">@option.Label</option> }</select></td><td><span data-inline-edit-value>@(row.TransferFromProjectName ?? "-")</span><select class="inline-cell-control" name="ConstructionEdit.TransferFromProjectId" form="@formId" data-inline-edit-control hidden><option value="">留空</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id" selected="@(option.Id == row.TransferFromProjectId ? "selected" : null)">@option.Label</option> }</select></td><td><span data-inline-edit-value>@row.EntryDate?.ToString("yyyy-MM-dd")</span><input class="inline-cell-control" name="ConstructionEdit.EntryDate" value="@row.EntryDate?.ToString("yyyy-MM-dd")" type="date" form="@formId" data-construction-entry data-inline-edit-control hidden /></td><td><span data-inline-edit-value>@row.ExitDate?.ToString("yyyy-MM-dd")</span><input class="inline-cell-control" name="ConstructionEdit.ExitDate" value="@row.ExitDate?.ToString("yyyy-MM-dd")" type="date" form="@formId" data-construction-exit data-inline-edit-control hidden /></td><td><span data-construction-total>@row.TotalDays</span></td><td><span data-inline-edit-value>@row.StopDays</span><input class="inline-cell-control" name="ConstructionEdit.StopDays" value="@row.StopDays" type="number" min="0" form="@formId" data-construction-stop data-inline-edit-control hidden /></td><td><span data-construction-work>@row.WorkDays</span></td><td><span data-inline-edit-value>@(row.TransferToProjectName ?? "-")</span><select class="inline-cell-control" name="ConstructionEdit.TransferToProjectId" form="@formId" data-inline-edit-control hidden><option value="">留空</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id" selected="@(option.Id == row.TransferToProjectId ? "selected" : null)">@option.Label</option> }</select></td><td><span data-inline-edit-value>@row.Notes</span><input class="inline-cell-control" name="ConstructionEdit.Notes" value="@row.Notes" form="@formId" data-inline-edit-control hidden /></td><td><form id="@formId" method="post" asp-page-handler="Construction"><input type="hidden" name="ConstructionEdit.Id" value="@row.Id" /><input type="hidden" name="ConstructionEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input class="inline-cell-control" name="ConstructionEdit.Reason" value="项目管理页面快捷修改施工详情" data-inline-edit-actions hidden /><button class="button button--secondary button--small" type="submit" name="ConstructionEdit.AutoConnectPrevious" value="true" data-inline-edit-actions hidden>自动连接上个项目</button><button class="button button--secondary button--small" type="submit" data-inline-edit-actions hidden>自动连接下个项目</button><button class="button button--primary button--small" type="submit" data-inline-edit-actions hidden>保存本行</button><span class="pill">@(row.IsDraft ? "待完善" : "正式")</span></form></td></tr>
                        }
                        </tbody></table></div>
                    </article>
                </div>
            </section>
        </main>
        <aside class="project-activity-panel" aria-label="项目提示与修改记录"><div class="activity-panel-heading"><div><p class="eyebrow">动态</p><h2>提示与记录</h2></div><span>@item.Activities.Count</span></div><div class="activity-feed">@if (item.Activities.Count == 0) { <div class="empty-state"><strong>暂无动态</strong><p>编辑项目或录入业务后会在这里形成记录。</p></div> } @foreach (var activity in item.Activities) { <article class="activity-item activity-item--@activity.Tone"><span class="activity-dot"></span><div><p class="activity-meta">@activity.Category · @activity.OccurredAt.ToLocalTime().ToString("MM-dd HH:mm")</p><h3>@activity.Title</h3>@if (!string.IsNullOrWhiteSpace(activity.Detail)) { <p>@activity.Detail</p> }@if (!string.IsNullOrWhiteSpace(activity.UserName)) { <small>操作人：@activity.UserName</small> }</div></article> }</div></aside>
    </div>
}
