@page
@model EngineeringManager.Web.Areas.Identity.Pages.Account.LoginModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "登录";
}

<section class="auth-page">
    <div class="auth-brand-panel"><span class="brand-mark" aria-hidden="true">工</span><p class="eyebrow">工程项目经营管理系统</p><h1>经营数据清晰，现场资料不断线</h1><p>内部项目、合同、财务、员工与设备数据统一管理。</p></div>
    <article class="panel auth-card"><div class="panel-heading"><div><p class="eyebrow">安全访问</p><h2>内部账号登录</h2></div></div><form method="post" class="form-stack"><input type="hidden" name="returnUrl" value="@Model.ReturnUrl" /><label asp-for="Input.Email"></label><input asp-for="Input.Email" autocomplete="username" /><span asp-validation-for="Input.Email" class="validation-message"></span><label asp-for="Input.Password"></label><input asp-for="Input.Password" autocomplete="current-password" /><span asp-validation-for="Input.Password" class="validation-message"></span><label class="checkbox-row"><input asp-for="Input.RememberMe" /> <span>保持登录</span></label><div asp-validation-summary="ModelOnly" class="validation-summary"></div><button class="button button--primary" type="submit">登录</button></form><p class="auth-help">无法登录时，请联系系统管理员检查账号状态、重置密码或调整权限。</p><a class="button button--secondary" asp-page="/Index" asp-area="">返回首页</a></article>
</section>
