@page "{id:guid}"
@model EngineeringManager.Web.Pages.Projects.DetailsModel
@using EngineeringManager.Application.Finance
@using EngineeringManager.Domain.Finance
@using EngineeringManager.Domain.Projects
@using EngineeringManager.Web.Presentation
@{
    ViewData["Title"] = "项目详情";
    var activeTab = Model.Tab?.ToLowerInvariant();
}

@if (Model.Workspace is null)
{
    <section class="panel"><h1>项目不存在</h1><p class="panel-copy">项目可能已归档或不在当前授权范围内。</p></section>
}
else
{
    var item = Model.Workspace;
    var collectionRate = item.FinanceSummary.ReceivableAmount == 0m ? 0m : item.FinanceSummary.CollectedAmount / item.FinanceSummary.ReceivableAmount * 100m;
    var invoiceRate = item.FinanceSummary.ReceivableAmount == 0m ? 0m : item.FinanceSummary.OutputInvoiceAmount / item.FinanceSummary.ReceivableAmount * 100m;
    var paymentRate = item.FinanceSummary.PayableAmount == 0m ? 0m : item.FinanceSummary.PaidAmount / item.FinanceSummary.PayableAmount * 100m;
    var collectionBar = Math.Clamp(collectionRate, 0m, 100m);
    var invoiceBar = Math.Clamp(invoiceRate, 0m, 100m);
    var paymentBar = Math.Clamp(paymentRate, 0m, 100m);
    <section class="page-heading project-heading compact-page-heading">
        <div><p class="eyebrow">@item.Overview.ProjectNumber</p><h1>@item.Overview.Name</h1><p class="page-lead">@(item.Overview.GeneralContractorName ?? "未填写总包单位") · @(item.Overview.ResponsibleUserName ?? "未设置负责人")</p></div>
        <div class="button-row"><span class="pill pill--success">@item.Overview.Stage.ToChinese()</span>@if (Model.CanManage) { <a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@item.Overview.Id">详细编辑</a><a class="button button--secondary button--action" asp-page="Edit" asp-route-copyFrom="@item.Overview.Id">复制</a> }</div>
    </section>

    <div class="project-workspace-shell">
        <main class="project-workspace-main">
            <section class="overview-strip project-detail-strip" aria-label="项目经营总览">
                <article class="is-accent"><span>当前工程金额 · @item.ProjectSummary.SettlementStatus.ToChinese()</span><strong>@item.ProjectSummary.CurrentAmount.ToString("N2")</strong></article>
                <article><span>应收款</span><strong>@item.FinanceSummary.ReceivableAmount.ToString("N2")</strong></article>
                <article class="is-success"><span>已收款</span><strong>@item.FinanceSummary.CollectedAmount.ToString("N2")</strong></article>
                <article class="is-warning"><span>未收款</span><strong>@item.FinanceSummary.UncollectedAmount.ToString("N2")</strong></article>
                <article><span>已开票</span><strong>@item.FinanceSummary.OutputInvoiceAmount.ToString("N2")</strong></article>
                <article><span>未开票</span><strong>@item.FinanceSummary.UninvoicedAmount.ToString("N2")</strong></article>
            </section>

            <section class="panel project-overview-panel compact-detail-panel inline-edit-shell" data-inline-edit="project-overview" data-inline-cell-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-overview" ? "true" : "false")">
                <form method="post" asp-page-handler="QuickEdit" id="project-overview-inline-form">
                    <div class="panel-heading"><div><p class="eyebrow">项目总览</p><h2>基础资料与金额口径</h2><small>更新于 @item.Overview.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@item.Overview.Id">进入详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--action" type="submit" data-inline-edit-actions hidden>保存</button></div> }</div>
                    <div asp-validation-summary="All" class="panel-copy"></div>
                    <dl class="detail-grid detail-grid--compact project-summary-grid">
                        <div><dt>项目编号</dt><dd><span data-inline-edit-value>@item.Overview.ProjectNumber</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ProjectNumber" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>项目名称</dt><dd><span data-inline-edit-value>@item.Overview.Name</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Name" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>项目阶段</dt><dd><span data-inline-edit-value>@item.Overview.Stage.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.Stage" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<ProjectStage>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
                        <div><dt>总包单位</dt><dd><span data-inline-edit-value>@(item.Overview.GeneralContractorName ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.GeneralContractorName" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>总包联系人</dt><dd><span data-inline-edit-value>@(item.Overview.GeneralContractorContact ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.GeneralContractorContact" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>联系电话</dt><dd><span data-inline-edit-value>@(item.Overview.GeneralContractorPhone ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.GeneralContractorPhone" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>项目负责人</dt><dd><span data-inline-edit-value>@(item.Overview.ResponsibleUserName ?? "未设置")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.ResponsibleUserId" data-inline-edit-control hidden><option value="">未设置</option>@foreach (var option in Model.Options.ResponsibleUsers) { <option value="@option.Value">@option.Label</option> }</select> }</dd></div>
                        <div><dt>部门</dt><dd><span data-inline-edit-value>@(item.Overview.DepartmentName ?? "未设置")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.DepartmentId" data-inline-edit-control hidden><option value="">未设置</option>@foreach (var option in Model.Options.Departments) { <option value="@option.Value">@option.Label</option> }</select> }</dd></div>
                        <div><dt>签约公司</dt><dd><span data-inline-edit-value>@(item.Overview.LegalEntities.Count == 0 ? "未设置" : string.Join("、", item.Overview.LegalEntities.Select(option => option.Label)))</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.LegalEntityIds" multiple size="3" data-inline-edit-control hidden>@foreach (var option in Model.Options.LegalEntities) { var optionId = Guid.Parse(option.Value); <option value="@option.Value" selected="@(Model.QuickEdit.LegalEntityIds.Contains(optionId) ? "selected" : null)">@option.Label</option> }</select> }</dd></div>
                        <div><dt>合作方式</dt><dd><span data-inline-edit-value>@item.Overview.AffiliationType.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.AffiliationType" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<ProjectAffiliationType>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
                        <div><dt>归档状态</dt><dd><span data-inline-edit-value>@item.Overview.ArchiveStatus.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.ArchiveStatus" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<ArchiveStatus>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
                        <div><dt>实际开工日期</dt><dd><span data-inline-edit-value>@(item.Overview.ActualStartDate?.ToString("yyyy-MM-dd") ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ActualStartDate" type="date" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>实际完工日期</dt><dd><span data-inline-edit-value>@(item.Overview.ActualCompletionDate?.ToString("yyyy-MM-dd") ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ActualCompletionDate" type="date" data-inline-edit-control hidden /> }</dd></div>
                        <div><dt>项目备注</dt><dd><span data-inline-edit-value>@(item.Overview.Notes ?? "暂无备注")</span>@if (Model.CanManage) { <textarea class="inline-cell-control" asp-for="QuickEdit.Notes" data-inline-edit-control hidden></textarea> }</dd></div>
                        <div><dt>收款比例</dt><dd><div class="mini-progress mini-progress--success"><div class="mini-progress-head"><span>已收 / 应收</span><strong>@collectionRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @collectionBar.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span></div></dd></div>
                        <div><dt>开票比例</dt><dd><div class="mini-progress"><div class="mini-progress-head"><span>已开 / 应收</span><strong>@invoiceRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @invoiceBar.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span></div></dd></div>
                        <div><dt>付款比例</dt><dd><div class="mini-progress mini-progress--warning"><div class="mini-progress-head"><span>已付 / 应付</span><strong>@paymentRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @paymentBar.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span></div></dd></div>
                        <div><dt>合同金额</dt><dd>@item.ProjectSummary.ContractAmount.ToString("N2")</dd></div>
                        <div><dt>暂估金额</dt><dd>@item.ProjectSummary.EstimatedAmount.ToString("N2")</dd></div><div><dt>结算金额</dt><dd>@item.ProjectSummary.SettledAmount.ToString("N2")</dd></div>
                        <div><dt>应付 / 已付 / 未付</dt><dd>@item.FinanceSummary.PayableAmount.ToString("N2") / @item.FinanceSummary.PaidAmount.ToString("N2") / @item.FinanceSummary.UnpaidAmount.ToString("N2")</dd></div>
                    </dl>
                    @if (Model.CanManage) { <label class="inline-edit-reason" data-inline-edit-actions hidden>修改原因<input class="inline-cell-control" asp-for="QuickEdit.Reason" /></label><input type="hidden" asp-for="QuickEdit.ConcurrencyStamp" /> }
                </form>
            </section>

            <section class="content-grid project-related-overview" aria-label="项目关联资料">
                <article class="panel compact-detail-panel">
                    <div class="panel-heading"><h2>项目里程碑</h2><span>@(item.Milestones?.Count ?? 0)</span></div>
                    @if (item.Milestones is null || item.Milestones.Count == 0) { <p class="panel-copy">暂无项目里程碑。</p> }
                    else { <ul class="check-list">@foreach (var milestone in item.Milestones) { <li><strong>@milestone.Name</strong> · @(milestone.PlannedDate?.ToString("yyyy-MM-dd") ?? "未定日期") · @(milestone.IsCompleted ? "已完成" : "未完成")<br /><span>@(milestone.Notes ?? "暂无备注")</span></li> }</ul> }
                </article>
                <article class="panel compact-detail-panel">
                    <div class="panel-heading"><h2>项目人员</h2><span>@(item.Assignments?.Count ?? 0)</span></div>
                    @if (item.Assignments is null || item.Assignments.Count == 0) { <p class="panel-copy">暂无项目人员分配。</p> }
                    else { <ul class="check-list">@foreach (var assignment in item.Assignments) { <li><strong>@assignment.UserName</strong> · @(assignment.AssignmentType == ProjectAssignmentType.Responsible ? "负责人" : "现场人员")<br /><span>@(assignment.Notes ?? "暂无备注")</span></li> }</ul> }
                </article>
                <article class="panel compact-detail-panel">
                    <div class="panel-heading"><h2>项目合作单位</h2><span>@(item.Partners?.Count ?? 0)</span></div>
                    @if (item.Partners is null || item.Partners.Count == 0) { <p class="panel-copy">暂无项目合作单位。</p> }
                    else { <ul class="check-list">@foreach (var partner in item.Partners) { <li><strong>@partner.PartnerName</strong> · @partner.RoleType.ToChinese() @if (partner.IsPrimary) { <span>· 主要合作方</span> }<br /><span>@(partner.Notes ?? "暂无备注")</span></li> }</ul> }
                </article>
            </section>

            <section class="panel project-tabs" data-project-tabs>
                <input type="radio" name="project-detail-tab" id="project-tab-quantity" checked="@(activeTab is null or "quantity" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-collection" checked="@(activeTab == "collection" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-invoice" checked="@(activeTab == "invoice" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-payment" checked="@(activeTab == "payment" ? "checked" : null)" /><input type="radio" name="project-detail-tab" id="project-tab-construction" checked="@(activeTab == "construction" ? "checked" : null)" />
                <nav class="project-tab-list" aria-label="项目业务明细">
                    <label for="project-tab-quantity">工程量明细 <span>@item.Contracts.Sum(contract => contract.LineItems.Count)</span></label><label for="project-tab-collection">收款明细 <span>@item.Collections.Count</span></label><label for="project-tab-invoice">开票明细 <span>@item.Invoices.Count</span></label><label for="project-tab-payment">付款明细 <span>@item.Payments.Count</span></label><label for="project-tab-construction">施工详情 <span>@Model.ConstructionWorkspace.Records.Count</span></label>
                </nav>
                <div class="project-tab-panels">
                    <article class="project-tab-panel project-tab-panel--quantity inline-edit-shell" data-inline-edit="project-quantity" data-inline-cell-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-quantity" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>合同与工程量</h2><p>工程量按合同和清单行集中展示，可在原表格单元格中修改。</p></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><a class="button button--secondary button--action" asp-page="/Projects/Contracts/Edit" asp-route-projectId="@item.Overview.Id">进入详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        <div asp-validation-summary="All" class="panel-copy"></div>
                        @if (item.Contracts.Count == 0) { <div class="empty-state"><strong>尚未录入合同与工程量</strong><p>请先进入详细编辑新增合同和首条工程量。</p></div> }
                        @foreach (var contract in item.Contracts)
                        {
                            <section class="workspace-subsection"><div class="workspace-subheading"><h3>@contract.ContractNumber · @contract.Name</h3><span>合同额 @contract.TotalAmount.ToString("N2") · @(contract.Notes ?? "暂无合同备注")</span></div><div class="table-wrap"><table class="data-table quantity-inline-table"><thead><tr><th>编码</th><th>名称</th><th>单位</th><th>暂估工程量</th><th>暂估单价</th><th>暂估小计</th><th>结算工程量</th><th>结算单价</th><th>结算小计</th><th>口径</th><th>备注</th><th data-inline-edit-actions hidden>操作</th></tr></thead><tbody>
                            @foreach (var line in contract.LineItems)
                            {
                                var formId = $"quantity-line-{line.Id:N}";
                                <tr>
                                    <td><span data-inline-edit-value>@line.Code</span><input class="inline-cell-control" name="QuantityEdit.Code" value="@line.Code" form="@formId" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.Name</span><input class="inline-cell-control" name="QuantityEdit.Name" value="@line.Name" form="@formId" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.Unit</span><input class="inline-cell-control" name="QuantityEdit.Unit" value="@line.Unit" form="@formId" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.EstimatedQuantity?.ToString("N2")</span><input class="inline-cell-control" name="QuantityEdit.EstimatedQuantity" value="@line.EstimatedQuantity" type="number" step="0.0001" form="@formId" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.EstimatedUnitPrice?.ToString("N2")</span><input class="inline-cell-control" name="QuantityEdit.EstimatedUnitPrice" value="@line.EstimatedUnitPrice" type="number" step="0.0001" form="@formId" data-inline-edit-control hidden /></td>
                                    <td>@line.EstimatedAmount.ToString("N2")</td>
                                    <td><span data-inline-edit-value>@line.SettledQuantity?.ToString("N2")</span><input class="inline-cell-control" name="QuantityEdit.SettledQuantity" value="@line.SettledQuantity" type="number" step="0.0001" form="@formId" data-inline-edit-control hidden /></td>
                                    <td><span data-inline-edit-value>@line.SettledUnitPrice?.ToString("N2")</span><input class="inline-cell-control" name="QuantityEdit.SettledUnitPrice" value="@line.SettledUnitPrice" type="number" step="0.0001" form="@formId" data-inline-edit-control hidden /></td>
                                    <td>@line.SettledAmount.ToString("N2")</td>
                                    <td><span data-inline-edit-value><span class="pill @(line.IsSettlementConfirmed ? "pill--success" : null)">@(line.IsSettlementConfirmed ? "结算" : "暂估")</span></span><select class="inline-cell-control" name="QuantityEdit.IsSettlementConfirmed" form="@formId" data-inline-edit-control hidden><option value="false" selected="@(!line.IsSettlementConfirmed ? "selected" : null)">暂估</option><option value="true" selected="@(line.IsSettlementConfirmed ? "selected" : null)">结算</option></select></td>
                                    <td><span data-inline-edit-value>@line.Notes</span><input class="inline-cell-control" name="QuantityEdit.Notes" value="@line.Notes" form="@formId" data-inline-edit-control hidden /></td><td data-inline-edit-actions hidden><form id="@formId" method="post" asp-page-handler="Quantity"><input type="hidden" name="QuantityEdit.LineItemId" value="@line.Id" /><input type="hidden" name="QuantityEdit.ConcurrencyStamp" value="@line.ConcurrencyStamp" /><button class="button button--primary button--small" type="submit">保存本行</button></form></td>
                                </tr>
                            }
                            </tbody></table></div></section>
                        }
                    </article>

                    <article class="project-tab-panel project-tab-panel--collection inline-edit-shell" data-inline-edit="project-collection" data-inline-cell-edit data-project-finance-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-collection" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>应收与实际收款</h2><p>应收计划和每次到账分开记录，自动计算已收与未收。</p></div>@if (Model.CanManageFinance) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><a class="button button--secondary button--action" asp-page="/Finance/Entries/Create" asp-route-EntryKind="@FinanceEntryKind.Receivable" asp-route-ProjectId="@item.Overview.Id" asp-route-ReturnUrl="@Request.Path">详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        @if (Model.CanManageFinance)
                        {
                            <details class="inline-create-details"><summary>新增应收或收款记录</summary><form method="post" asp-page-handler="Collection" class="inline-edit-panel">
                                <div asp-validation-summary="All" class="panel-copy"></div><div class="inline-edit-grid">
                                    <label>业务类型<select asp-for="CollectionEdit.Kind" data-inline-edit-kind-select><option value="1">新增应收</option><option value="2">登记收款</option></select></label>
                                    <label>合同<select asp-for="CollectionEdit.ContractId"><option value="">不指定合同</option>@foreach (var contract in item.Contracts) { <option value="@contract.Id">@contract.ContractNumber · @contract.Name</option> }</select></label>
                                    <label>签约公司<select asp-for="CollectionEdit.LegalEntityId"><option value="">请选择</option>@foreach (var company in item.Overview.LegalEntities) { <option value="@company.Value">@company.Label</option> }</select></label>
                                    <label>付款方<select asp-for="CollectionEdit.BusinessPartnerId"><option value="">未指定</option>@foreach (var partner in Model.FinanceOptions.BusinessPartners) { <option value="@partner.Id">@partner.Label</option> }</select></label>
                                    <label>业务日期<input asp-for="CollectionEdit.EntryDate" type="date" /></label><label data-kind="1">到期日期<input asp-for="CollectionEdit.DueDate" type="date" /></label>
                                    <label data-kind="2">关联应收<select asp-for="CollectionEdit.RelatedEntryId"><option value="">不关联</option>@foreach (var row in Model.FinanceOptions.Receivables) { <option value="@row.Id">@row.Label</option> }</select></label>
                                    <label data-kind="2">收款账户<select asp-for="CollectionEdit.AccountId"><option value="">请选择</option>@foreach (var account in Model.FinanceOptions.Accounts) { <option value="@account.Id">@account.Label</option> }</select></label>
                                    <label data-kind="2">收款方式<select asp-for="CollectionEdit.PaymentMethod">@foreach (var value in Enum.GetValues<PaymentMethod>()) { <option value="@value">@value.ToChinese()</option> }</select></label>
                                    <label>金额<input asp-for="CollectionEdit.Amount" type="number" step="0.01" /></label><label class="inline-edit-span">说明/备注<input asp-for="CollectionEdit.Description" /></label>
                                </div><div class="inline-edit-actions"><a class="button button--secondary button--action inline-edit-detail" asp-page="/Finance/Entries/Create" asp-route-EntryKind="@FinanceEntryKind.Receivable" asp-route-ProjectId="@item.Overview.Id" asp-route-ReturnUrl="@Request.Path">进入详细编辑</a><button type="button" class="button button--secondary button--action" data-inline-edit-cancel>取消</button><button type="submit" class="button button--primary button--action">保存</button></div>
                            </form></details>
                        }
                        <div><h3>应收记录</h3><div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>到期日</th><th>合同</th><th>签约公司</th><th>付款方</th><th>金额</th><th>说明</th><th>状态</th><th data-inline-edit-actions hidden>操作</th></tr></thead><tbody>
                        @foreach (var row in item.Receivables)
                        {
                            var formId = $"receivable-row-{row.Id:N}";
