@using EngineeringManager.Infrastructure.Data
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<div class="account-menu">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="account-avatar" aria-hidden="true">@(User.Identity?.Name?.FirstOrDefault() ?? '用')</span>
        <span class="account-name">@(User.Identity?.Name ?? "内部用户")</span>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post"><button class="account-action" type="submit">退出</button></form>
    }
    else
    {
        <a class="button button--primary" asp-area="Identity" asp-page="/Account/Login">登录</a>
    }
</div>
