@page "{id:guid}"
@model EngineeringManager.Web.Pages.Companies.DetailsModel
@{ ViewData["Title"] = Model.Company.Name; }

<section class="page-heading compact-page-heading"><div><p class="eyebrow">@Model.Company.Code · @(Model.Company.CompanyCategoryName ?? "未分类")</p><h1>@Model.Company.Name</h1><p class="page-lead">@Model.Company.ShortName · 法人/经营者：@(Model.Company.LegalRepresentative ?? "未填写")</p></div>@if (Model.CanManage) { <div class="button-row"><a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@Model.Company.Id">详细编辑</a><a class="button button--secondary button--action" asp-page="Edit" asp-route-copyFrom="@Model.Company.Id">复制</a></div> }</section>
<section class="overview-strip"><article class="is-accent"><span>合同额</span><strong>@Model.Dashboard.ContractAmount.ToString("N2")</strong></article><article><span>应收 / 已收</span><strong>@Model.Dashboard.ReceivableAmount.ToString("N2") / @Model.Dashboard.CollectedAmount.ToString("N2")</strong></article><article><span>应付 / 已付</span><strong>@Model.Dashboard.PayableAmount.ToString("N2") / @Model.Dashboard.PaidAmount.ToString("N2")</strong></article><article><span>账户余额</span><strong>@Model.Dashboard.AccountBalance.ToString("N2")</strong></article></section>

<section class="content-grid">
    <article class="panel compact-detail-panel inline-edit-shell" data-inline-edit="company-details" data-inline-cell-edit data-inline-edit-active="@(Model.QuickEditOpen ? "true" : "false")">
        <form method="post" asp-page-handler="QuickEdit">
            <div class="panel-heading"><h2>基础与开票资料</h2>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑公司</button><a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@Model.Company.Id">进入详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--action" type="submit" data-inline-edit-actions hidden>保存</button></div> }</div>
            <div asp-validation-summary="All" class="panel-copy"></div>
            <dl class="detail-grid project-summary-grid">
                <div><dt>公司编码</dt><dd><span data-inline-edit-value>@Model.Company.Code</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Code" data-inline-edit-control hidden required /> }</dd></div>
                <div><dt>公司名称</dt><dd><span data-inline-edit-value>@Model.Company.Name</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Name" data-inline-edit-control hidden required /> }</dd></div>
                <div><dt>简称</dt><dd><span data-inline-edit-value>@Model.Company.ShortName</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.ShortName" data-inline-edit-control hidden required /> }</dd></div>
                <div><dt>组合分类</dt><dd><span data-inline-edit-value>@(Model.Company.CompanyCategoryName ?? "未分类")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.CompanyCategoryId" data-inline-edit-control hidden><option value="">未分类</option>@foreach (var category in Model.Categories) { <option value="@category.Id">@category.Name</option> }</select> }</dd></div>
                <div><dt>法人/经营者</dt><dd><span data-inline-edit-value>@(Model.Company.LegalRepresentative ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.LegalRepresentative" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>统一社会信用代码</dt><dd><span data-inline-edit-value>@(Model.Company.UnifiedSocialCreditCode ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.UnifiedSocialCreditCode" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>联系电话</dt><dd><span data-inline-edit-value>@(Model.Company.Phone ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Phone" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>开票抬头</dt><dd><span data-inline-edit-value>@(Model.Company.InvoiceTitle ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.InvoiceTitle" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>注册地址</dt><dd><span data-inline-edit-value>@(Model.Company.RegisteredAddress ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.RegisteredAddress" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>经营地址</dt><dd><span data-inline-edit-value>@(Model.Company.BusinessAddress ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.BusinessAddress" data-inline-edit-control hidden /> }</dd></div>
                <div><dt>备注</dt><dd><span data-inline-edit-value>@(Model.Company.Notes ?? "未填写")</span>@if (Model.CanManage) { <textarea class="inline-cell-control" asp-for="QuickEdit.Notes" rows="2" data-inline-edit-control hidden></textarea> }</dd></div>
            </dl>
            @if (Model.CanManage) { <label class="inline-edit-reason" data-inline-edit-actions hidden>修改原因<input class="inline-cell-control" asp-for="QuickEdit.Reason" required /></label><input type="hidden" asp-for="QuickEdit.ConcurrencyStamp" /> }
        </form>
    </article>
    <article class="panel compact-detail-panel"><div class="panel-heading"><h2>账户与证书</h2><a class="button button--secondary button--action" asp-page="/Companies/Certificates/Index" asp-route-CompanyId="@Model.Company.Id">证书管理</a></div><p class="panel-copy">账户 @Model.Company.Accounts.Count 个，证书 @Model.Company.Certificates.Count 项。</p><ul class="check-list">@foreach (var account in Model.Company.Accounts) { <li>@account.AccountName @if (account.IsDefaultCollection) { <span>· 默认收款</span> } @if (account.IsDefaultPayment) { <span>· 默认付款</span> } @if (account.IsDefaultInvoice) { <span>· 默认开票</span> } @if (!string.IsNullOrWhiteSpace(account.Notes)) { <span>· @account.Notes</span> }</li> } @foreach (var certificate in Model.Company.Certificates) { <li>@certificate.CertificateType · @(certificate.CertificateNumber ?? "未编号") · @(certificate.ExpiresOn?.ToString("yyyy-MM-dd") ?? "长期")</li> }</ul></article>
</section>

@if (Model.CanManage)
{
    <section class="content-grid"><article class="panel"><div class="panel-heading"><h2>新增公司账户</h2></div><form method="post" asp-page-handler="Account" class="form-stack"><label>账户名称<input asp-for="Account.Name" required /></label><label>账户类型<select asp-for="Account.AccountType"><option value="1">银行</option><option value="2">现金</option><option value="3">其他</option></select></label><label>账号<input asp-for="Account.Number" /></label><label>开户行<input asp-for="Account.BankName" /></label><label>期初余额<input asp-for="Account.OpeningBalance" /></label><label>备注<textarea asp-for="Account.Notes"></textarea></label><label class="checkbox-row"><input asp-for="Account.DefaultCollection" />默认收款</label><label class="checkbox-row"><input asp-for="Account.DefaultPayment" />默认付款</label><label class="checkbox-row"><input asp-for="Account.DefaultInvoice" />默认开票</label><button class="button button--primary button--action" type="submit">保存账户</button></form></article><article class="panel"><div class="panel-heading"><h2>新增公司证照</h2></div><form method="post" asp-page-handler="Certificate" class="form-stack"><label>资料类型<input asp-for="Certificate.Type" required /></label><label>资料编号<input asp-for="Certificate.Number" /></label><label>签发日期<input asp-for="Certificate.IssuedOn" type="date" /></label><label>有效期<input asp-for="Certificate.ExpiresOn" type="date" /></label><label>备注<textarea asp-for="Certificate.Notes"></textarea></label><button class="button button--primary button--action" type="submit">保存证照</button></form></article></section>
}
