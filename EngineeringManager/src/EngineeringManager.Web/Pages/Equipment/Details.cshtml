@page "{id:guid}"
@using EngineeringManager.Domain.Equipment
@using EngineeringManager.Web.Presentation
@model EngineeringManager.Web.Pages.Equipment.DetailsModel
@{ ViewData["Title"] = Model.Equipment.Name; }

<section class="page-heading compact-page-heading"><div><p class="eyebrow">@Model.Equipment.EquipmentNumber · 设备详情</p><h1>@Model.Equipment.Name</h1><p class="page-lead">@(Model.Equipment.Model ?? "未填写型号") · @(Model.Equipment.Category ?? "未分类") · @Model.Equipment.Status.ToChinese()</p></div><div class="button-row">@if (Model.CanManage) { <a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@Model.Equipment.Id">详细编辑</a> }<a class="button button--secondary button--action" asp-page="Usage" asp-route-equipmentId="@Model.Equipment.Id">登记进退场</a>@if (Model.CanManage) { <a class="button button--secondary button--action" asp-page="Edit" asp-route-copyFrom="@Model.Equipment.Id">复制</a> }</div></section>

<section class="overview-strip"><article class="is-accent"><span>当前状态</span><strong>@Model.Equipment.Status.ToChinese()</strong></article><article><span>权属</span><strong>@Model.Equipment.OwnershipType.ToChinese()</strong></article><article><span>内部参考日价</span><strong>@(Model.Equipment.InternalDailyRate?.ToString("N2") ?? "-")</strong></article><article><span>型号 / 分类</span><strong>@(Model.Equipment.Model ?? "-") / @(Model.Equipment.Category ?? "-")</strong></article></section>

<section class="panel compact-detail-panel inline-edit-shell" data-inline-edit="equipment-details" data-inline-cell-edit data-inline-edit-active="@(Model.QuickEditOpen ? "true" : "false")">
    <form method="post" asp-page-handler="QuickEdit">
        <div class="panel-heading"><div><p class="eyebrow">设备档案</p><h2>常用资料</h2></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑设备</button><a class="button button--secondary button--action" asp-page="Edit" asp-route-id="@Model.Equipment.Id">进入详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--action" type="submit" data-inline-edit-actions hidden>保存</button></div> }</div>
        <div asp-validation-summary="All" class="panel-copy"></div>
        <dl class="detail-grid project-summary-grid">
            <div><dt>设备编号</dt><dd><span data-inline-edit-value>@Model.Equipment.EquipmentNumber</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.EquipmentNumber" data-inline-edit-control hidden required /> }</dd></div>
            <div><dt>设备名称</dt><dd><span data-inline-edit-value>@Model.Equipment.Name</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Name" data-inline-edit-control hidden required /> }</dd></div>
            <div><dt>型号</dt><dd><span data-inline-edit-value>@(Model.Equipment.Model ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Model" data-inline-edit-control hidden /> }</dd></div>
            <div><dt>分类</dt><dd><span data-inline-edit-value>@(Model.Equipment.Category ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.Category" data-inline-edit-control hidden /> }</dd></div>
            <div><dt>权属</dt><dd><span data-inline-edit-value>@Model.Equipment.OwnershipType.ToChinese()</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.OwnershipType" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<EquipmentOwnershipType>()) { <option value="@value">@value.ToChinese()</option> }</select> }</dd></div>
            <div><dt>内部参考日价</dt><dd><span data-inline-edit-value>@(Model.Equipment.InternalDailyRate?.ToString("N2") ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" asp-for="QuickEdit.InternalDailyRate" type="number" step="0.01" data-inline-edit-control hidden /> }</dd></div>
            <div><dt>所属公司</dt><dd><span data-inline-edit-value>@(Model.Companies.FirstOrDefault(item => item.Id == Model.Equipment.OwnerLegalEntityId)?.ShortName ?? "不适用")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.OwnerLegalEntityId" data-inline-edit-control hidden><option value="">不适用</option>@foreach (var company in Model.Companies) { <option value="@company.Id">@company.Code · @company.ShortName</option> }</select> }</dd></div>
            <div><dt>出租方</dt><dd><span data-inline-edit-value>@(Model.Lessors.FirstOrDefault(item => item.Id == Model.Equipment.LessorBusinessPartnerId)?.ShortName ?? "不适用")</span>@if (Model.CanManage) { <select class="inline-cell-control" asp-for="QuickEdit.LessorBusinessPartnerId" data-inline-edit-control hidden><option value="">不适用</option>@foreach (var lessor in Model.Lessors) { <option value="@lessor.Id">@lessor.PartnerNumber · @lessor.ShortName</option> }</select> }</dd></div>
            <div><dt>备注</dt><dd><span data-inline-edit-value>@(Model.Equipment.Notes ?? "未填写")</span>@if (Model.CanManage) { <textarea class="inline-cell-control" asp-for="QuickEdit.Notes" rows="3" data-inline-edit-control hidden></textarea> }</dd></div>
        </dl>
        @if (Model.CanManage) { <label class="inline-edit-reason" data-inline-edit-actions hidden>修改原因<input class="inline-cell-control" asp-for="QuickEdit.Reason" required /></label><input type="hidden" asp-for="QuickEdit.ConcurrencyStamp" /> }
    </form>
</section>
