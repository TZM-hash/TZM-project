@page
@model EngineeringManager.Web.Pages.Crews.DetailsModel
@{ ViewData["Title"] = "施工班组详情"; }
<section class="page-heading"><div><p class="eyebrow">施工班组</p><h1>@Model.Details.Crew.Name</h1><p class="page-lead">人员名册、项目关系和民工工资代发工程款使用同一班组主档。</p></div><a class="button button--secondary" asp-page="/Crews/Index">返回施工班组</a></section>
<section class="overview-strip"><article><span>当前人员</span><strong>@Model.Details.Crew.CurrentWorkerCount</strong></article><article><span>参与项目</span><strong>@Model.Details.Crew.ProjectCount</strong></article><article><span>累计代发工程款</span><strong>@Model.Details.Crew.TotalPaidAmount.ToString("N2")</strong></article></section>
<section class="panel" style="margin-top:var(--space-3)"><div class="panel-heading"><div><h2>人员名册</h2><p>身份证号为选填，退出或转组不会改写历史工资记录。</p></div></div><div class="table-wrap"><table class="data-table"><thead><tr><th>姓名</th><th>身份证</th><th>电话</th><th>工种</th><th>加入</th><th>退出</th><th>操作</th></tr></thead><tbody>@foreach (var worker in Model.Details.Workers) { <tr><td>@worker.Name</td><td>@(worker.IdentityNumber ?? "未填写")</td><td>@(worker.Phone ?? "未填写")</td><td>@(worker.Trade ?? "未填写")</td><td>@worker.StartDate</td><td>@(worker.EndDate?.ToString() ?? "在组")</td><td>@if (Model.CanManage && !worker.EndDate.HasValue) { <form method="post" asp-page-handler="TransferWorker" class="table-inline-form"><input type="hidden" name="Transfer.WorkerId" value="@worker.Id" /><select name="Transfer.NewCrewId">@foreach (var crew in Model.CrewOptions.Where(item => item.Id != Model.Id)) { <option value="@crew.Id">@crew.Name</option> }</select><input type="date" name="Transfer.TransferDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" /><input name="Transfer.Reason" value="施工班组人员转组" /><button class="button button--secondary button--small" type="submit">转组</button></form> }</td></tr> }</tbody></table></div>
@if (Model.CanManage) { <form method="post" asp-page-handler="AddWorker" class="form-grid"><label>姓名<input asp-for="NewWorker.Name" required /></label><label>身份证号（选填）<input asp-for="NewWorker.IdentityNumber" /></label><label>手机号<input asp-for="NewWorker.Phone" /></label><label>银行卡号<input asp-for="NewWorker.BankAccountNumber" /></label><label>开户行<input asp-for="NewWorker.BankName" /></label><label>工种<input asp-for="NewWorker.Trade" /></label><label>加入日期<input asp-for="NewWorker.StartDate" type="date" /></label><label>备注<input asp-for="NewWorker.Notes" /></label><label>修改原因<input asp-for="NewWorker.Reason" required /></label><button class="button button--primary" type="submit">加入人员名册</button></form> }</section>
<section class="panel" style="margin-top:var(--space-3)"><div class="panel-heading"><div><h2>民工工资发放记录</h2><p>每批工程款可倒查具体人员，金额修改统一回到来源工资批次。</p></div></div><div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>批次</th><th>项目</th><th>人数</th><th>工程款金额</th><th>人员明细</th><th>操作</th></tr></thead><tbody>@foreach (var batch in Model.Details.PaymentBatches) { <tr><td>@batch.PaymentDate</td><td>@batch.BatchNumber</td><td>@(batch.ProjectName ?? "未归属")</td><td>@batch.WorkerCount</td><td>@batch.Amount.ToString("N2")</td><td><details><summary>查看 @batch.WorkerCount 人</summary><table class="data-table"><thead><tr><th>姓名</th><th>身份证</th><th>工种</th><th>金额</th><th>来源</th></tr></thead><tbody>@foreach (var line in batch.Lines) { <tr><td>@line.RecipientName</td><td>@(line.IdentityNumber ?? "未填写")</td><td>@(line.Trade ?? "未填写")</td><td>@line.Amount.ToString("N2")</td><td><a asp-page="/Payroll/Edit" asp-route-id="@batch.PayrollBatchId" asp-route-lineId="@line.PayrollPaymentId" asp-route-returnUrl="@($"/Crews/Details?id={Model.Id}")">查看此人明细</a></td></tr> }</tbody></table></details></td><td><a asp-page="/Payroll/Edit" asp-route-id="@batch.PayrollBatchId" asp-route-returnUrl="@($"/Crews/Details?id={Model.Id}")">查看来源批次</a></td></tr> }</tbody></table></div></section>
