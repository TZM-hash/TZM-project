@page
@model EngineeringManager.Web.Pages.Backups.IndexModel
@{
    ViewData["Title"] = "备份管理";
}
<section class="page-heading"><div><p class="eyebrow">数据安全</p><h1>备份管理</h1><p class="page-lead">每次任务同时生成 SQL Server 数据库备份和附件 ZIP，任务失败会进入提醒中心。</p></div><form method="post"><button class="button button--secondary" type="submit">立即备份</button></form></section>
<section class="panel"><partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.Backups" /><div class="table-wrap"><table class="data-table" id="backups-table"><thead><tr><th data-column-key="created">时间</th><th data-column-key="status">状态</th><th data-column-key="database">数据库文件</th><th data-column-key="attachments">附件文件</th><th data-column-key="error">错误</th></tr></thead><tbody>@foreach (var item in Model.Tasks) { <tr><td data-column-key="created">@item.CreatedAt.LocalDateTime</td><td data-column-key="status">@item.Status</td><td data-column-key="database">@item.DatabaseBackupPath</td><td data-column-key="attachments">@item.AttachmentArchivePath</td><td data-column-key="error">@item.ErrorMessage</td></tr> }</tbody></table></div></section>
