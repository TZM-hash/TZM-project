@page
@model EngineeringManager.Web.Pages.Companies.IndexModel
@using EngineeringManager.Web.Workbenches
@{
    ViewData["Title"] = "自有公司";
    var dashboard = Model.Dashboard;
    var uncollected = dashboard.ReceivableAmount - dashboard.CollectedAmount;
    var collectionRate = dashboard.ReceivableAmount <= 0m
        ? 0d
        : (double)Math.Clamp(dashboard.CollectedAmount / dashboard.ReceivableAmount * 100m, 0m, 100m);
    var paymentRate = dashboard.PayableAmount <= 0m
        ? 0d
        : (double)Math.Clamp(dashboard.PaidAmount / dashboard.PayableAmount * 100m, 0m, 100m);
    var invoiceRate = dashboard.OutputInvoiceAmount <= 0m
        ? 0d
        : (double)Math.Clamp(dashboard.InputInvoiceAmount / dashboard.OutputInvoiceAmount * 100m, 0m, 100m);
    var costTotal = dashboard.PayrollCost + dashboard.EquipmentCost;
    var payrollShare = costTotal <= 0m
        ? 0d
        : (double)Math.Clamp(dashboard.PayrollCost / costTotal * 100m, 0m, 100m);
    var workbench = DataWorkbenchPresets.Companies with
    {
        InlineFilters = new DataWorkbenchFilterField[]
        {
            new("Search", "搜索", Model.Search, Placeholder: "搜索公司全部信息"),
            new("CompanyId", "范围", Model.CompanyId?.ToString(), DataWorkbenchFilterKind.Select,
                Model.Companies.Select(company => new DataWorkbenchFilterOption(company.Id.ToString(), company.Name)).ToArray())
        }
    };
}

<div class="company-workspace" data-company-dashboard>
    <section class="page-heading company-workspace-heading">
        <div>
            <p class="eyebrow">公司维度经营统计</p>
            <h1>自有公司</h1>
            <p class="page-lead">在同一工作台查看各公司经营汇总、档案与业务入口。</p>
        </div>
        <div class="company-workspace-actions">
            <partial name="_CompanyScopeSwitcher" model="(Model.Companies, (Guid?)null, (string?)null)" />
            @if (Model.CanManage)
            {
                <a class="button button--primary" asp-page="Edit">新增公司</a>
            }
        </div>
    </section>

    <section class="metric-grid company-metric-grid" aria-label="公司关键指标">
        <article class="metric-card company-metric-card">
            <span class="metric-label">公司数量</span>
            <strong class="metric-value">@dashboard.CompanyCount</strong>
            <span class="metric-hint">权限范围内可见公司</span>
        </article>
        <article class="metric-card company-metric-card company-metric-card--accent">
            <span class="metric-label">未收款</span>
            <strong class="metric-value">@uncollected.ToString("N2")</strong>
            <span class="metric-hint">已收 @dashboard.CollectedAmount.ToString("N2") / 应收 @dashboard.ReceivableAmount.ToString("N2")</span>
            <div class="company-mini-progress" aria-hidden="true">
                <span class="progress-track"><span class="progress-fill" style="width:@collectionRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span>
                <small>回款进度 @collectionRate.ToString("0.#")%</small>
            </div>
        </article>
    </section>

    <section class="dashboard-grid company-dashboard-grid">
        <article class="panel company-panel" data-company-money-chart data-chart data-chart-kind="progress-ring" data-chart-value="@collectionRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" data-chart-label="公司收款完成率">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">金额对比</p>
                    <h2>收款、付款与开票</h2>
                </div>
                <div class="company-chart-ring"><span>收款完成率</span><div data-chart-canvas></div></div>
            </div>
            <div class="comparison-chart company-comparison-chart">
                <div class="comparison-row">
                    <div class="chart-label"><strong>应收 / 已收</strong><span>@dashboard.ReceivableAmount.ToString("N2") / @dashboard.CollectedAmount.ToString("N2")</span></div>
                    <div class="progress-track"><span class="progress-fill" style="width:@collectionRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></div>
                </div>
                <div class="comparison-row">
                    <div class="chart-label"><strong>应付 / 已付</strong><span>@dashboard.PayableAmount.ToString("N2") / @dashboard.PaidAmount.ToString("N2")</span></div>
                    <div class="progress-track"><span class="progress-fill progress-fill--stage" style="width:@paymentRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></div>
                </div>
                <div class="comparison-row">
                    <div class="chart-label"><strong>销项 / 进项发票</strong><span>@dashboard.OutputInvoiceAmount.ToString("N2") / @dashboard.InputInvoiceAmount.ToString("N2")</span></div>
                    <div class="progress-track"><span class="progress-fill" style="width:@invoiceRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></div>
                </div>
                <div class="comparison-row">
                    <div class="chart-label"><strong>工资 / 设备成本</strong><span>@dashboard.PayrollCost.ToString("N2") / @dashboard.EquipmentCost.ToString("N2")</span></div>
                    <div class="progress-track"><span class="progress-fill progress-fill--stage" style="width:@payrollShare.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></div>
                </div>
            </div>
        </article>
        <article class="panel company-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">公司档案</p>
                    <h2>公司列表</h2>
                </div>
            </div>
            <partial name="_DataWorkbench" model="workbench" />
            @if (Model.Companies.Count == 0)
            {
                <p class="panel-copy company-empty-copy">当前权限范围内没有自有公司。</p>
            }
            else
            {
                <div class="table-wrap company-table-wrap">
                    <table class="data-table" id="companies-table">
                        <thead>
                            <tr>
                                <th data-column-key="code">编码</th>
                                <th data-column-key="company">公司</th>
                                <th data-column-key="category">分类</th>
                                <th data-column-key="representative">法人/经营者</th>
                                <th data-column-key="accounts">账户</th>
                                <th data-column-key="notes">备注摘要</th>
                                <th data-column-key="status">状态</th>
                                <th data-column-key="actions">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var company in Model.Companies)
                        {
                            <tr>
                                <td data-column-key="code">@company.Code</td>
                                <td data-column-key="company"><a class="company-name-link" asp-page="Details" asp-route-id="@company.Id">@company.Name</a></td>
                                <td data-column-key="category">@(company.CategoryName ?? "未分类")</td>
                                <td data-column-key="representative">@(string.IsNullOrWhiteSpace(company.LegalRepresentative) ? "—" : company.LegalRepresentative)</td>
                                <td data-column-key="accounts">
                                    <a asp-page="Details" asp-route-id="@company.Id" asp-route-tab="accounts">
                                        @company.ActiveAccountCount 个启用
                                        @if (company.TotalAccountCount > company.ActiveAccountCount)
                                        {
                                            <span class="company-muted">（共 @company.TotalAccountCount 个）</span>
                                        }
                                    </a>
                                </td>
                                <td data-column-key="notes">@(string.IsNullOrWhiteSpace(company.Notes) ? "—" : company.Notes.Length > 40 ? company.Notes[..40] + "…" : company.Notes)</td>
                                <td data-column-key="status">
                                    <span class="pill @(company.IsActive ? "pill--success" : "pill--warning")">@(company.IsActive ? "启用" : "停用")</span>
                                </td>
                                <td data-column-key="actions">
                                    <div class="company-row-actions">
                                        <a asp-page="Details" asp-route-id="@company.Id">查看</a>
                                        @if (Model.CanManage)
                                        {
                                            <a asp-page="Edit" asp-route-id="@company.Id">编辑</a>
                                            <a asp-page="Edit" asp-route-copyFrom="@company.Id">复制</a>
                                        }
                                        <a asp-page="/Companies/Certificates/Index" asp-route-CompanyId="@company.Id">证书</a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    </section>

    @if (Model.CanManage)
    {
        <section class="panel company-panel company-category-panel">
            <div class="panel-heading"><div><p class="eyebrow">主数据</p><h2>组合分类维护</h2></div></div>
            <form method="post" asp-page-handler="Category" class="form-grid company-category-form">
                <label>分类编码<input asp-for="Category.Code" required /></label>
                <label>分类名称<input asp-for="Category.Name" required /></label>
                <label>排序<input asp-for="Category.SortOrder" type="number" /></label>
                <button class="button button--secondary" type="submit">保存分类</button>
            </form>
            @if (Model.Categories.Count > 0)
            {
                <div class="table-wrap company-table-wrap">
                    <table class="data-table">
                        <thead><tr><th>编码</th><th>分类名称</th><th>排序</th><th>状态</th></tr></thead>
                        <tbody>
                        @foreach (var category in Model.Categories)
                        {
                            <tr>
                                <td>@category.Code</td>
                                <td>@category.Name</td>
                                <td>@category.SortOrder</td>
                                <td><span class="pill @(category.IsActive ? "pill--success" : "pill--warning")">@(category.IsActive ? "启用" : "停用")</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>
