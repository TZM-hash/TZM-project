@page
@using EngineeringManager.Domain.Finance
@model EngineeringManager.Web.Pages.Ledger.Reconciliations.IndexModel
@{
    ViewData["Title"] = "中央账本对账";
}
<section class="page-heading"><div><h1>中央账本对账</h1><p class="page-lead">对账不锁定历史；修改后显示快照差异。后续发现异常可继续修正，系统保留修改和删除记录。</p></div></section>
@if (TempData["Success"] is string success) { <div class="alert alert--success">@success</div> } @if (TempData["Error"] is string error) { <div class="alert alert--danger">@error</div> }
<section class="panel"><form method="get" class="ledger-filter-grid"><label>账本<select asp-for="Scope"><option value="External">外部账本</option><option value="Internal">内部账本</option></select></label><label>财务年度<select asp-for="FinanceBusinessYearId"><option value="">自定义日期</option>@foreach (var item in Model.Years) { <option value="@item.Id">@item.Name</option> }</select></label><label>开始日期<input asp-for="StartDate" type="date" /></label><label>截止日期<input asp-for="AsOfDate" type="date" /></label><label>自有公司<select asp-for="LegalEntityId"><option value="">全部公司</option>@foreach (var item in Model.Options.LegalEntities) { <option value="@item.Id">@item.Label</option> }</select></label><label>合作单位<select asp-for="BusinessPartnerId"><option value="">全部单位</option>@foreach (var item in Model.Options.BusinessPartners) { <option value="@item.Id">@item.Label</option> }</select></label><div class="ledger-filter-actions"><button class="button button--secondary" type="submit">筛选历史</button></div></form></section>
@if (Model.CanManage) { <section class="panel"><div class="panel-heading"><div><h2>生成新版本快照</h2><p>相同范围再次对账会新增版本，不覆盖旧快照。</p></div></div><form method="post" asp-page-handler="Create" class="inline-form"><input type="hidden" asp-for="Scope" /><input type="hidden" asp-for="FinanceBusinessYearId" /><input type="hidden" asp-for="LegalEntityId" /><input type="hidden" asp-for="BusinessPartnerId" /><input type="hidden" asp-for="StartDate" /><input type="hidden" asp-for="AsOfDate" /><select asp-for="ReconciliationScope"><option value="WholeLedger">整个账本</option><option value="LegalEntity">自有公司</option><option value="BusinessPartner">合作单位</option></select><button class="button button--primary" type="submit">生成对账快照</button></form></section> }
<section class="panel data-work-surface"><div class="panel-heading"><div><h2>历史快照</h2></div></div><div class="table-wrap"><table class="data-table"><thead><tr><th>截止日期</th><th>范围</th><th>版本</th><th>快照实际金额</th><th>创建时间</th><th>创建人</th><th>操作</th></tr></thead><tbody>@foreach (var item in Model.Items) { <tr><td>@item.AsOfDate</td><td>@item.ReconciliationScope</td><td>V@item.Version</td><td>@item.SnapshotMetrics.ActualAmount.ToString("N2")</td><td>@item.CreatedAt.ToLocalTime()</td><td>@item.CreatedByUserName</td><td><a class="button button--secondary" asp-page="/Ledger/Reconciliations/Details" asp-route-id="@item.Id">查看差异</a>@if (Model.CanManage) { <form method="post" asp-page-handler="Delete" class="inline-form"><input type="hidden" name="DeleteId" value="@item.Id" /><input type="hidden" name="DeleteConcurrencyStamp" value="@item.ConcurrencyStamp" /><input name="DeleteReason" placeholder="删除原因" required /><button class="button button--danger" type="submit">删除</button></form> }</td></tr> }</tbody></table></div></section>
