@page
@model EngineeringManager.Web.Pages.Companies.Certificates.EditModel
@{ ViewData["Title"] = Model.Input.Id.HasValue ? "编辑公司证书" : "新增公司证书"; }
<datalist id="company-certificate-types"><option value="营业执照"></option><option value="安全生产许可证"></option><option value="资质证书"></option><option value="开户许可证"></option><option value="行业许可证"></option></datalist>
<section class="page-heading"><div><p class="eyebrow">企业证照台账</p><h1>@ViewData["Title"]</h1><p class="page-lead">一家自有公司可以维护多本同类型资质证书；到期日期留空即视为长期有效。</p></div><a class="button button--ghost" asp-page="Index">返回列表</a></section>
<form method="post" enctype="multipart/form-data" class="panel form-grid certificate-edit-form"><input type="hidden" asp-for="Input.Id" /><input type="hidden" asp-for="Input.ConcurrencyStamp" /><input type="hidden" asp-for="Input.ExistingAttachmentFileName" /><label>所属公司<select asp-for="Input.LegalEntityId" required><option value="">请选择公司</option>@foreach (var company in Model.Companies) { <option value="@company.Id">@company.Code · @company.Name</option> }</select><span asp-validation-for="Input.LegalEntityId"></span></label><label>证书类型<input asp-for="Input.CertificateType" list="company-certificate-types" required /><span asp-validation-for="Input.CertificateType"></span></label><label>证书编号<input asp-for="Input.CertificateNumber" /></label><label>专业/等级/资质范围<input asp-for="Input.SpecialtyLevelScope" /></label><label>发证机关<input asp-for="Input.IssuingAuthority" /></label><label>签发日期<input asp-for="Input.IssuedOn" type="date" /></label><label>到期日期<input asp-for="Input.ExpiresOn" type="date" /><small>留空表示长期有效</small></label><label class="form-span">附件<input asp-for="Input.Attachment" type="file" /><small>单个附件最大 20MB。当前：@(Model.Input.ExistingAttachmentFileName ?? "无")</small></label>@if (!string.IsNullOrWhiteSpace(Model.Input.ExistingAttachmentFileName)) { <label class="checkbox-row form-span"><input asp-for="Input.RemoveAttachment" />删除当前附件</label> }<label class="form-span">备注<textarea asp-for="Input.Notes"></textarea></label><label class="form-span">修改原因<input asp-for="Input.Reason" required /></label><div asp-validation-summary="ModelOnly" class="form-span validation-summary"></div><div class="form-span button-row"><button class="button button--primary" type="submit">保存证书</button><a class="button button--secondary" asp-page="Index">取消</a></div></form>
<partial name="_ValidationScriptsPartial" />
