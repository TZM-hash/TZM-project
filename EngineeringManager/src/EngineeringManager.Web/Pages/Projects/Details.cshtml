l" name="FinanceRowEdit.InvoiceStatus" form="@formId" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<InvoiceStatus>()) { <option value="@value" selected="@(value == row.Status ? "selected" : null)">@value.ToChinese()</option> }</select></td><td data-inline-edit-actions hidden><form id="@formId" method="post" asp-page-handler="FinanceRow"><input type="hidden" name="FinanceRowEdit.Id" value="@row.Id" /><input type="hidden" name="FinanceRowEdit.Kind" value="@FinanceEntryKind.Invoice" /><input type="hidden" name="FinanceRowEdit.Tab" value="invoice" /><input type="hidden" name="FinanceRowEdit.ContractId" value="@row.ContractId" /><input type="hidden" name="FinanceRowEdit.LegalEntityId" value="@row.LegalEntityId" /><input type="hidden" name="FinanceRowEdit.BusinessPartnerId" value="@row.BusinessPartnerId" /><input type="hidden" name="FinanceRowEdit.InvoiceType" value="@row.InvoiceType" /><input type="hidden" name="FinanceRowEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input class="inline-cell-control" name="FinanceRowEdit.Reason" value="项目管理页面快捷修改发票" aria-label="修改原因" /><button class="button button--primary button--small" type="submit">保存本行</button></form></td></tr>
