@page
@model EngineeringManager.Web.Pages.Projects.IndexModel
@using EngineeringManager.Web.Presentation
@using EngineeringManager.Application.DataExchange
@using EngineeringManager.Web.Pages.DataExchange
@{
    ViewData["Title"] = "项目管理";
}

<section class="page-heading project-index-heading">
    <div>
        <p class="eyebrow">项目经营台账</p>
        <h1>项目管理</h1>
        <p class="page-lead">项目主档、工程金额、收付款和开票数据统一在这里查看与处理。</p>
    </div>
    <div class="page-actions-inline">
        @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator") || User.IsInRole("Finance"))
        {
            <a class="button button--secondary" asp-page="/Finance/Accounts">资金账户</a><a class="button button--secondary" asp-page="/Finance/Entries/Create">录入经营数据</a>
        }
        @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator") || User.IsInRole("ProjectManager"))
        {
            <a class="button button--primary" asp-page="/Projects/Edit">新建项目</a>
        }
    </div>
</section>

<section class="overview-strip project-overview-strip" aria-label="项目经营汇总">
    <article><span>项目数</span><strong>@Model.Result.Aggregate.ProjectCount</strong></article>
    <article><span>合同金额</span><strong>@Model.Result.Aggregate.ContractAmount.ToString("N2")</strong></article>
    <article class="is-accent"><span>当前工程金额</span><strong>@Model.Result.Aggregate.CurrentAmount.ToString("N2")</strong></article>
    <article><span>应收款</span><strong>@Model.FinanceTotal.ReceivableAmount.ToString("N2")</strong></article>
    <article class="is-success"><span>已收款</span><strong>@Model.FinanceTotal.CollectedAmount.ToString("N2")</strong></article>
    <article class="is-warning"><span>未收款</span><strong>@Model.FinanceTotal.UncollectedAmount.ToString("N2")</strong></article>
    <article><span>已开票</span><strong>@Model.FinanceTotal.OutputInvoiceAmount.ToString("N2")</strong></article>
    <article><span>未开票</span><strong>@Model.FinanceTotal.UninvoicedAmount.ToString("N2")</strong></article>
    <article><span>未付款</span><strong>@Model.FinanceTotal.UnpaidAmount.ToString("N2")</strong></article>
</section>

<section class="panel data-work-surface">
    <div class="panel-heading"><div><p class="eyebrow">项目清单</p><h2>当前项目</h2></div><span class="result-count">共 @Model.Result.TotalCount 个项目</span></div>
    @if (Model.CanExportWorkbook)
    {
    <form id="projects-table-workbook-export-form" method="post" asp-page-handler="ExportWorkbook" class="panel compact-form-grid project-workbook-export-form" data-project-export-scope>
        <input type="hidden" asp-for="Search" /><input type="hidden" asp-for="LegalEntityId" /><input type="hidden" asp-for="ResponsibleUserId" /><input type="hidden" asp-for="AffiliationType" /><input type="hidden" asp-for="MinimumCurrentAmount" /><input type="hidden" asp-for="MaximumCurrentAmount" /><input type="hidden" asp-for="SortKey" /><input type="hidden" asp-for="SortDescending" />
        @foreach (var stage in Model.Stages) { <input type="hidden" name="Stages" value="@stage" /> }
        <label class="check-label"><input asp-for="SelectAllMatching" data-project-export-all-matching /> 导出当前筛选命中的全部项目（共 @Model.Result.TotalCount 个）</label>
        @if (Model.CanExportWorkbookAttachments) { <label class="check-label"><input asp-for="IncludeWorkbookAttachments" data-project-export-attachments /> 包含附件并生成 ZIP</label> }
        <details class="selection-dropdown"><summary>选择项目工作簿细项</summary><div class="check-grid">@foreach (var sheet in Enum.GetValues<ProjectWorkbookSheet>().Where(sheet => Model.CanExportFullWorkbook || sheet != ProjectWorkbookSheet.ProjectSummary && sheet != ProjectWorkbookSheet.Attachments)) { <label><input type="checkbox" name="SelectedWorkbookSheets" value="@sheet" checked="@(Model.SelectedWorkbookSheets.Count == 0 || Model.SelectedWorkbookSheets.Contains(sheet) ? "checked" : null)" data-project-workbook-sheet="@sheet" /> @DataExchangeLabels.ProjectSheet(sheet)</label> }</div></details>
        <button class="button button--primary" type="submit">导出项目工作簿</button>
    </form>
    }
    <partial name="_DataWorkbench" model="Model.Workbench" />
    <form id="projects-table-export-form" method="post" asp-page-handler="Export" hidden>
        <input type="hidden" asp-for="Search" /><input type="hidden" asp-for="LegalEntityId" /><input type="hidden" asp-for="ResponsibleUserId" /><input type="hidden" asp-for="AffiliationType" />
        <input type="hidden" asp-for="MinimumCurrentAmount" /><input type="hidden" asp-for="MaximumCurrentAmount" />
        <input type="hidden" asp-for="SortKey" /><input type="hidden" asp-for="SortDescending" /><input type="hidden" asp-for="PageSize" />
        @foreach (var stage in Model.Stages) { <input type="hidden" name="Stages" value="@stage" /> }
        <input type="hidden" name="SelectedFields" value="serial_number" data-export-column-key="serial_number" />
        <input type="hidden" name="SelectedFields" value="project_number" data-export-column-key="project_number" />
        <input type="hidden" name="SelectedFields" value="project_name" data-export-column-key="project_name" />
        <input type="hidden" name="SelectedFields" value="stage" data-export-column-key="stage" />
        <input type="hidden" name="SelectedFields" value="contract_signing_status" data-export-column-key="contract_signing_status" />
        <input type="hidden" name="SelectedFields" value="affiliation_type" data-export-column-key="affiliation_type" />
        <input type="hidden" name="SelectedFields" value="parent_project" data-export-column-key="parent_project" />
        <input type="hidden" name="SelectedFields" value="general_contractor" data-export-column-key="general_contractor" />
        <input type="hidden" name="SelectedFields" value="general_contractor_contact" data-export-column-key="general_contractor_contact" />
        <input type="hidden" name="SelectedFields" value="general_contractor_phone" data-export-column-key="general_contractor_phone" />
        <input type="hidden" name="SelectedFields" value="responsible_user" data-export-column-key="responsible_user" />
        <input type="hidden" name="SelectedFields" value="department" data-export-column-key="department" />
        <input type="hidden" name="SelectedFields" value="branch" data-export-column-key="branch" />
        <input type="hidden" name="SelectedFields" value="legal_entities" data-export-column-key="legal_entities" />
        <input type="hidden" name="SelectedFields" value="actual_start_date" data-export-column-key="actual_start_date" />
        <input type="hidden" name="SelectedFields" value="actual_completion_date" data-export-column-key="actual_completion_date" />
        <input type="hidden" name="SelectedFields" value="contract_amount" data-export-column-key="contract_amount" />
        <input type="hidden" name="SelectedFields" value="estimated_amount" data-export-column-key="estimated_amount" />
        <input type="hidden" name="SelectedFields" value="settled_amount" data-export-column-key="settled_amount" />
        <input type="hidden" name="SelectedFields" value="current_project_amount" data-export-column-key="current_project_amount" />
        <input type="hidden" name="SelectedFields" value="contract_count" data-export-column-key="contract_count" />
        <input type="hidden" name="SelectedFields" value="line_item_count" data-export-column-key="line_item_count" />
        <input type="hidden" name="SelectedFields" value="receivable_amount" data-export-column-key="collection_progress" />
        <input type="hidden" name="SelectedFields" value="collected_amount" data-export-column-key="collection_progress" />
        <input type="hidden" name="SelectedFields" value="uncollected_amount" data-export-column-key="collection_progress" />
        <input type="hidden" name="SelectedFields" value="payable_amount" data-export-column-key="payment_progress" />
        <input type="hidden" name="SelectedFields" value="paid_amount" data-export-column-key="payment_progress" />
        <input type="hidden" name="SelectedFields" value="unpaid_amount" data-export-column-key="payment_progress" />
        <input type="hidden" name="SelectedFields" value="output_invoice_amount" data-export-column-key="invoice_progress" />
        <input type="hidden" name="SelectedFields" value="uninvoiced_amount" data-export-column-key="invoice_progress" />
        <input type="hidden" name="SelectedFields" value="notes" data-export-column-key="notes" />
    </form>
    @if (Model.Result.Items.Count == 0)
    {
        <div class="empty-state"><strong>没有符合条件的项目</strong><p>可以调整筛选条件，或清除筛选后查看授权范围内的全部项目。</p></div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table" id="projects-table">
                <thead><tr>
                    <th>选择</th><th data-column-key="serial_number">序号</th>
                    <th data-column-key="project_number"><button class="table-sort-button" type="button" data-sort-key="ProjectNumber">项目编号</button></th>
                    <th data-column-key="project_name"><button class="table-sort-button" type="button" data-sort-key="Name">项目名称</button></th>
                    <th data-column-key="stage"><button class="table-sort-button" type="button" data-sort-key="Stage">阶段</button></th>
                    <th data-column-key="contract_signing_status">合同签订</th><th data-column-key="affiliation_type">合作方式</th>
                    <th data-column-key="parent_project">上级项目</th><th data-column-key="general_contractor">总包单位</th><th data-column-key="general_contractor_contact">总包联系人</th><th data-column-key="general_contractor_phone">总包电话</th>
                    <th data-column-key="responsible_user">项目负责人</th><th data-column-key="department">部门</th><th data-column-key="branch">分支机构</th><th data-column-key="legal_entities">签约公司</th>
                    <th data-column-key="actual_start_date">实际开始日期</th><th data-column-key="actual_completion_date">实际完工日期</th>
                    <th data-column-key="contract_amount"><button class="table-sort-button" type="button" data-sort-key="ContractAmount">合同金额</button></th>
                    <th data-column-key="estimated_amount">预计金额</th><th data-column-key="settled_amount">已结算金额</th>
                    <th data-column-key="current_project_amount"><button class="table-sort-button" type="button" data-sort-key="CurrentAmount">当前工程金额</button></th>
                    <th data-column-key="settlement_status"><button class="table-sort-button" type="button" data-sort-key="SettlementStatus">结算状态</button></th><th data-column-key="contract_count">合同数量</th><th data-column-key="line_item_count">清单项数量</th>
                    <th data-column-key="collection_progress"><span class="mini-progress-label">收款率（应 / 已 / 未）</span></th><th data-column-key="payment_progress"><span class="mini-progress-label">付款率（应 / 已 / 未）</span></th><th data-column-key="invoice_progress"><span class="mini-progress-label">开票率（已 / 未）</span></th><th data-column-key="notes">备注摘要</th><th data-column-key="actions">操作</th>
                </tr></thead>
                <tbody>
                @foreach (var entry in Model.Result.Items.Select((item, index) => (item, index)))
                {
                    var item = entry.item;
                    var serialNumber = (Model.Result.Page - 1) * Model.Result.PageSize + entry.index + 1;
                    Model.FinanceByProjectId.TryGetValue(item.Project.Id, out var finance);
                    var receivableAmount = finance?.ReceivableAmount ?? 0m;
                    var collectedAmount = finance?.CollectedAmount ?? 0m;
                    var payableAmount = finance?.PayableAmount ?? 0m;
                    var paidAmount = finance?.PaidAmount ?? 0m;
                    var invoicedAmount = finance?.OutputInvoiceAmount ?? 0m;
                    var invoiceBasis = item.Summary.CurrentAmount > 0m ? item.Summary.CurrentAmount : item.Summary.ContractAmount;
                    var collectionRate = receivableAmount > 0m ? Math.Clamp(collectedAmount / receivableAmount * 100m, 0m, 100m) : 0m;
                    var paymentRate = payableAmount > 0m ? Math.Clamp(paidAmount / payableAmount * 100m, 0m, 100m) : 0m;
                    var invoiceRate = invoiceBasis > 0m ? Math.Clamp(invoicedAmount / invoiceBasis * 100m, 0m, 100m) : 0m;
                    <tr>
                        <td>@if (Model.CanExportWorkbook) { <input type="checkbox" name="SelectedProjectIds" value="@item.Project.Id" form="projects-table-workbook-export-form" data-project-export-item /> }</td><td data-column-key="serial_number">@serialNumber</td>
                        <td data-column-key="project_number"><a asp-page="/Projects/Details" asp-route-id="@item.Project.Id">@item.Project.ProjectNumber</a></td>
                        <td data-column-key="project_name">@item.Project.Name</td>
                        <td data-column-key="stage" class="project-stage-cell"><span class="pill">@item.Project.Stage.ToChinese()</span></td>
                        <td data-column-key="contract_signing_status">@item.Project.ContractSigningStatus.ToChinese()</td><td data-column-key="affiliation_type">@item.Project.AffiliationType.ToChinese()</td>
                        <td data-column-key="parent_project">@(item.Project.ParentProjectName ?? "未设置")</td><td data-column-key="general_contractor">@(item.Project.GeneralContractorName ?? "未设置")</td><td data-column-key="general_contractor_contact">@(item.Project.GeneralContractorContact ?? "未设置")</td><td data-column-key="general_contractor_phone">@(item.Project.GeneralContractorPhone ?? "未设置")</td>
                        <td data-column-key="responsible_user">@(item.Project.ResponsibleUserName ?? "未设置")</td><td data-column-key="department">@(item.Project.DepartmentName ?? "未设置")</td><td data-column-key="branch">@(item.Project.BranchName ?? "未设置")</td><td data-column-key="legal_entities">@(item.Project.LegalEntityNames is { Count: > 0 } ? string.Join("、", item.Project.LegalEntityNames) : "未设置")</td>
                        <td data-column-key="actual_start_date">@(item.Project.ActualStartDate?.ToString("yyyy-MM-dd") ?? "未设置")</td><td data-column-key="actual_completion_date">@(item.Project.ActualCompletionDate?.ToString("yyyy-MM-dd") ?? "未设置")</td>
                        <td data-column-key="contract_amount">@item.Summary.ContractAmount.ToString("N2")</td>
                        <td data-column-key="estimated_amount">@item.Summary.EstimatedAmount.ToString("N2")</td><td data-column-key="settled_amount">@item.Summary.SettledAmount.ToString("N2")</td>
                        <td data-column-key="current_project_amount">@item.Summary.CurrentAmount.ToString("N2")</td>
                        <td data-column-key="settlement_status">@item.Summary.SettlementStatus.ToChinese()</td><td data-column-key="contract_count">@item.Summary.ContractCount</td><td data-column-key="line_item_count">@item.Summary.LineItemCount</td>
                        <td data-column-key="collection_progress"><div class="mini-progress mini-progress--success"><div class="mini-progress-head"><span>收款率</span><strong>@collectionRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @collectionRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span><span class="mini-progress-values">@receivableAmount.ToString("N2") / @collectedAmount.ToString("N2") / @((finance?.UncollectedAmount ?? 0m).ToString("N2"))</span></div></td>
                        <td data-column-key="payment_progress"><div class="mini-progress mini-progress--warning"><div class="mini-progress-head"><span>付款率</span><strong>@paymentRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @paymentRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span><span class="mini-progress-values">@payableAmount.ToString("N2") / @paidAmount.ToString("N2") / @((finance?.UnpaidAmount ?? 0m).ToString("N2"))</span></div></td>
                        <td data-column-key="invoice_progress"><div class="mini-progress"><div class="mini-progress-head"><span>开票率</span><strong>@invoiceRate.ToString("N0")%</strong></div><span class="mini-progress-track"><span class="mini-progress-fill" style="width: @invoiceRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></span></span><span class="mini-progress-values">@invoicedAmount.ToString("N2") / @((finance?.UninvoicedAmount ?? 0m).ToString("N2"))</span></div></td>
                        <td data-column-key="notes">@(string.IsNullOrWhiteSpace(item.Project.Notes) ? "—" : item.Project.Notes.Length > 40 ? item.Project.Notes[..40] + "…" : item.Project.Notes)</td>
                        <td data-column-key="actions"><a asp-page="/Projects/Details" asp-route-id="@item.Project.Id">查看</a>@if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator") || User.IsInRole("ProjectManager")) { <span> · </span><a asp-page="/Projects/Edit" asp-route-id="@item.Project.Id">详细编辑</a> }</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <nav class="table-pagination" aria-label="项目分页">
            <a class="button button--secondary @(Model.Result.Page <= 1 ? "is-disabled" : null)" href="@(Model.Result.Page <= 1 ? null : Model.PageUrl(Model.Result.Page - 1))">上一页</a>
            <span>第 @Model.Result.Page / @Model.Result.TotalPages 页</span>
            <a class="button button--secondary @(Model.Result.Page >= Model.Result.TotalPages ? "is-disabled" : null)" href="@(Model.Result.Page >= Model.Result.TotalPages ? null : Model.PageUrl(Model.Result.Page + 1))">下一页</a>
        </nav>
    }
</section>
