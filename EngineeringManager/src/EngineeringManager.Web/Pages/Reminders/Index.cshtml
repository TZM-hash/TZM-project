@page
@model EngineeringManager.Web.Pages.Reminders.IndexModel
@{
    ViewData["Title"] = "提醒中心";
}
<section class="page-heading"><div><p class="eyebrow">风险与任务</p><h1>提醒中心</h1><p class="page-lead">显示项目节点、未收未付、未开票、工资未发和导入/备份失败；第一阶段不发送外部通知。</p></div></section>
<section class="panel">@if (Model.Reminders.Count == 0) { <p class="panel-copy">当前没有待处理提醒。</p> } else { <div class="table-wrap"><table class="data-table"><thead><tr><th>级别</th><th>类型</th><th>标题</th><th>说明</th><th>操作</th></tr></thead><tbody>@foreach (var item in Model.Reminders) { <tr><td>@item.Severity</td><td>@item.Type</td><td>@item.Title</td><td>@item.Message</td><td><form method="post" asp-page-handler="Read" style="display:inline"><input type="hidden" name="id" value="@item.Id" /><button class="button button--secondary" type="submit">已读</button></form> <form method="post" asp-page-handler="Resolve" style="display:inline"><input type="hidden" name="id" value="@item.Id" /><button class="button button--secondary" type="submit">处理</button></form></td></tr> }</tbody></table></div> }</section>
