@page
@model EngineeringManager.Web.Pages.Partners.DetailsModel
@{
    ViewData["Title"] = "合作单位详情";
}
<section class="page-heading"><div><h1>@Model.Partner.Name</h1><p class="page-lead">编号 @Model.Partner.PartnerNumber · @string.Join("、", Model.Partner.Roles.Select(item => item.RoleType))</p></div><div class="page-actions-inline"><a class="button button--secondary" asp-page="/Partners/Index">返回合作单位</a><a class="button button--secondary" asp-page="/Partners/Create" asp-route-id="@Model.Partner.Id">编辑档案</a></div></section>
<section class="overview-strip"><article><span>简称</span><strong>@Model.Partner.ShortName</strong></article><article><span>参与项目</span><strong>@Model.Partner.ProjectCount</strong></article><article><span>状态</span><strong>@(Model.Partner.IsActive ? "启用" : "停用")</strong></article></section>
@if (Model.CanManageFinance) { <section class="panel" style="margin-top:var(--space-3)"><div class="panel-heading"><div><h2>合作单位财务录入</h2><p>应付、进项发票、付款和扣款直接进入中央账本；项目内录入的数据也会在这里汇总。</p></div></div><div class="page-actions-inline"><a class="button button--primary" asp-page="/Ledger/Entries/Edit" asp-route-scope="External" asp-route-recordType="Settlement" asp-route-direction="Payable" asp-route-businessPartnerId="@Model.Partner.Id">新增应付</a><a class="button button--secondary" asp-page="/Ledger/Entries/Edit" asp-route-scope="External" asp-route-recordType="Invoice" asp-route-direction="Payable" asp-route-businessPartnerId="@Model.Partner.Id">录入进项发票</a><a class="button button--secondary" asp-page="/Ledger/Entries/Edit" asp-route-scope="External" asp-route-recordType="Cash" asp-route-direction="Payable" asp-route-businessPartnerId="@Model.Partner.Id">录入付款</a><a class="button button--secondary" asp-page="/Ledger/Entries/Edit" asp-route-scope="External" asp-route-recordType="Deduction" asp-route-direction="Payable" asp-route-businessPartnerId="@Model.Partner.Id">录入扣款</a></div></section> }
<section class="panel" style="margin-top:var(--space-3)"><div class="panel-heading"><div><h2>联系人</h2></div></div><div class="table-wrap"><table class="data-table"><thead><tr><th>姓名</th><th>电话</th><th>邮箱</th><th>地址</th><th>主要联系人</th></tr></thead><tbody>@foreach (var item in Model.Partner.Contacts) { <tr><td>@item.Name</td><td>@item.Phone</td><td>@item.Email</td><td>@item.Address</td><td>@(item.IsPrimary ? "是" : "否")</td></tr> }</tbody></table></div></section>
