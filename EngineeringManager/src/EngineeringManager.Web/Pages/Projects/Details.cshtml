                            var formId = $"payment-row-{row.Id:N}";
                             <tr><td><span data-inline-edit-value>@row.PaymentDate</span><input class="inline-cell-control" name="FinanceRowEdit.EntryDate" value="@row.PaymentDate.ToString("yyyy-MM-dd")" type="date" form="@formId" data-inline-edit-control hidden /></td><td>@(row.ContractNumber ?? "-")</td><td>@row.LegalEntityName</td><td>@row.BusinessPartnerName</td><td><span data-inline-edit-value>@row.AccountName</span><select class="inline-cell-control" name="FinanceRowEdit.AccountId" form="@formId" data-inline-edit-control hidden>@foreach (var account in Model.FinanceOptions.Accounts) { <option value="@account.Id" selected="@(account.Id == row.AccountId ? "selected" : null)">@account.Label</option> }</select></td><td><span data-inline-edit-value>@row.Amount.ToString("N2")</span><input class="inline-cell-control" name="FinanceRowEdit.Amount" value="@row.Amount" type="number" step="0.01" form="@formId" data-inline-edit-control hidden /></td><td><span data-inline-edit-value>@row.PaymentMethod.ToChinese()</span><select class="inline-cell-control" name="FinanceRowEdit.PaymentMethod" form="@formId" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<PaymentMethod>()) { <option value="@value" selected="@(value == row.PaymentMethod ? "selected" : null)">@value.ToChinese()</option> }</select></td><td><span data-inline-edit-value>@row.Notes</span><input class="inline-cell-control" name="FinanceRowEdit.Description" value="@row.Notes" form="@formId" data-inline-edit-control hidden /></td><td>@if (row.PayrollBatchId.HasValue) { <a asp-page="/Payroll/Edit" asp-route-id="@row.PayrollBatchId" asp-route-lineId="@row.PayrollPaymentId" asp-route-returnUrl="@Request.Path">查看来源批次</a> } else { <span data-inline-edit-actions hidden><form id="@formId" method="post" asp-page-handler="FinanceRow" asp-route-id="@item.Overview.Id"><input type="hidden" name="FinanceRowEdit.Id" value="@row.Id" /><input type="hidden" name="FinanceRowEdit.Kind" value="@FinanceEntryKind.Payment" /><input type="hidden" name="FinanceRowEdit.Tab" value="payment" /><input type="hidden" name="FinanceRowEdit.RelatedEntryId" value="@row.PayableEntryId" /><input type="hidden" name="FinanceRowEdit.ContractId" value="@row.ContractId" /><input type="hidden" name="FinanceRowEdit.LegalEntityId" value="@row.LegalEntityId" /><input type="hidden" name="FinanceRowEdit.BusinessPartnerId" value="@row.BusinessPartnerId" /><input type="hidden" name="FinanceRowEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input class="inline-cell-control" name="FinanceRowEdit.Reason" value="项目管理页面快捷修改付款" aria-label="修改原因" /><button class="button button--primary button--small" type="submit">保存本行</button></form></span> }</td></tr>
                        }
                        </tbody></table></div></div>
                    </article>

                    <article class="project-tab-panel project-tab-panel--construction inline-edit-shell" data-inline-edit="project-construction" data-inline-cell-edit data-inline-edit-active="@(Model.ActiveInlineEditor == "project-construction" ? "true" : "false")">
                        <div class="tab-panel-heading"><div><h2>施工详情</h2><p>记录设备和施工班组的多次进退场、停工天数及项目流转。</p></div>@if (Model.CanManage) { <div class="button-row"><button class="button button--primary button--action" type="button" data-inline-edit-open>快捷编辑</button><a class="button button--secondary button--action" asp-page="/Projects/Records/Edit" asp-route-projectId="@item.Overview.Id" asp-route-section="construction">详细编辑</a><button class="button button--secondary button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消编辑</button></div> }</div>
                        @if (Model.CanManage)
                        {
                            <div class="construction-create-grid">
                                <details class="inline-create-details"><summary>新增施工记录</summary><form method="post" asp-page-handler="Construction" asp-route-id="@item.Overview.Id" class="inline-edit-panel"><div class="inline-edit-grid">
                                    <label>类型<select asp-for="ConstructionEdit.RecordType" data-construction-type><option value="1">设备</option><option value="2">施工班组</option></select></label>
                                    <label>设备/施工班组<select asp-for="ConstructionEdit.SubjectId"><option value="">请选择</option><optgroup label="设备">@foreach (var option in Model.ConstructionWorkspace.Equipment) { <option value="@option.Id">@option.Label</option> }</optgroup><optgroup label="施工班组">@foreach (var option in Model.ConstructionWorkspace.Crews) { <option value="@option.Id">@option.Label</option> }</optgroup></select></label>
                                    <label>从哪个项目调入<select asp-for="ConstructionEdit.TransferFromProjectId"><option value="">留空</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id">@option.Label</option> }</select></label>
                                    <label>进场日期<input asp-for="ConstructionEdit.EntryDate" type="date" /></label><label>退场日期<input asp-for="ConstructionEdit.ExitDate" type="date" /></label><label>停工天数<input asp-for="ConstructionEdit.StopDays" type="number" min="0" /></label>
                                    <label>退场到哪个项目<select asp-for="ConstructionEdit.TransferToProjectId"><option value="">留空</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id">@option.Label</option> }</select></label>
                                    <label><input asp-for="ConstructionEdit.AutoConnectPrevious" type="checkbox" /> 自动连接上个项目</label><label data-construction-equipment-only><input asp-for="ConstructionEdit.ShowInProjectOverview" type="checkbox" /> 显示在项目总览</label><label class="inline-edit-span">备注<input asp-for="ConstructionEdit.Notes" /></label><label class="inline-edit-span">修改原因<input asp-for="ConstructionEdit.Reason" /></label>
                                </div><div class="inline-edit-actions"><button class="button button--primary" type="submit">新增记录</button></div></form></details>
                                <details class="inline-create-details"><summary>新建设备主档</summary><form method="post" asp-page-handler="CreateEquipment" asp-route-id="@item.Overview.Id" class="inline-edit-panel"><div class="inline-edit-grid"><label>设备编号<input asp-for="NewEquipment.EquipmentNumber" /></label><label>设备名称<input asp-for="NewEquipment.Name" /></label><label>型号<input asp-for="NewEquipment.Model" /></label><label>分类<input asp-for="NewEquipment.Category" /></label><label>权属<select asp-for="NewEquipment.OwnershipType" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Equipment.EquipmentOwnershipType>()"></select></label><label>所属公司（自有）<select asp-for="NewEquipment.OwnerLegalEntityId"><option value="">请选择</option>@foreach (var option in Model.FinanceOptions.LegalEntities) { <option value="@option.Id">@option.Label</option> }</select></label><label>出租方（租赁）<select asp-for="NewEquipment.LessorBusinessPartnerId"><option value="">请选择</option>@foreach (var option in Model.FinanceOptions.BusinessPartners) { <option value="@option.Id">@option.Label</option> }</select></label><label>内部日租金<input asp-for="NewEquipment.InternalDailyRate" type="number" step="0.01" /></label><label class="inline-edit-span">创建原因<input asp-for="NewEquipment.Reason" /></label></div><button class="button button--primary" type="submit">创建并加入本项目</button></form></details>
                                <details class="inline-create-details"><summary>新建施工班组主档</summary><form method="post" asp-page-handler="CreateCrew" asp-route-id="@item.Overview.Id" class="inline-edit-panel"><div class="inline-edit-grid"><label>班组编号<input asp-for="NewCrew.PartnerNumber" /></label><label>班组名称<input asp-for="NewCrew.Name" /></label><label>联系人<input asp-for="NewCrew.ContactName" /></label><label>联系电话<input asp-for="NewCrew.ContactPhone" /></label><label class="inline-edit-span">创建原因<input asp-for="NewCrew.Reason" /></label></div><button class="button button--primary" type="submit">创建并加入本项目</button></form></details>
                            </div>
                        }
                        <div asp-validation-summary="All" class="panel-copy"></div>
                        <div class="table-wrap"><table class="data-table construction-detail-table"><thead><tr><th>类型</th><th>设备/施工班组</th><th>项目总览</th><th>从哪个项目调入</th><th>进场日期</th><th>退场日期</th><th>总天数</th><th>停工天数</th><th>施工天数</th><th>退场到哪个项目</th><th>备注</th><th>操作</th></tr></thead><tbody>
                        @foreach (var row in Model.ConstructionWorkspace.Records)
                        {
                            var formId = $"construction-row-{row.Id:N}";
                            var isTargetRecord = Model.RecordId == row.Id;
                            <tr id="construction-record-@row.Id" class="@(isTargetRecord ? "is-target-record" : null)" data-construction-row>
                                <td><span data-inline-edit-value>@(row.RecordType == ProjectConstructionRecordType.Equipment ? "设备" : "施工班组")</span><select class="inline-cell-control" name="ConstructionEdit.RecordType" form="@formId" data-construction-type data-inline-edit-control hidden><option value="1" selected="@(row.RecordType == ProjectConstructionRecordType.Equipment ? "selected" : null)">设备</option><option value="2" selected="@(row.RecordType == ProjectConstructionRecordType.ConstructionCrew ? "selected" : null)">施工班组</option></select></td>
                                <td><span data-inline-edit-value>@row.SubjectLabel</span><select class="inline-cell-control" name="ConstructionEdit.SubjectId" form="@formId" data-inline-edit-control hidden>@foreach (var option in (row.RecordType == ProjectConstructionRecordType.Equipment ? Model.ConstructionWorkspace.Equipment : Model.ConstructionWorkspace.Crews)) { <option value="@option.Id" selected="@(option.Id == row.SubjectId ? "selected" : null)">@option.Label</option> }</select></td>
                                <td>@if (row.RecordType == ProjectConstructionRecordType.Equipment) { <span data-inline-edit-value>@(row.ShowInProjectOverview ? "显示" : "不显示")</span><label class="inline-cell-control compact-check" data-construction-equipment-only data-inline-edit-control hidden><input type="checkbox" name="ConstructionEdit.ShowInProjectOverview" value="true" form="@formId" checked="@(row.ShowInProjectOverview ? "checked" : null)" /> 显示在项目总览</label> } else { <span>-</span> }</td>
                                <td><span data-inline-edit-value>@(row.TransferFromProjectName ?? "-")</span><select class="inline-cell-control" name="ConstructionEdit.TransferFromProjectId" form="@formId" data-inline-edit-control hidden><option value="">留空</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id" selected="@(option.Id == row.TransferFromProjectId ? "selected" : null)">@option.Label</option> }</select></td>
                                <td><span data-inline-edit-value>@row.EntryDate?.ToString("yyyy-MM-dd")</span><input class="inline-cell-control" name="ConstructionEdit.EntryDate" value="@row.EntryDate?.ToString("yyyy-MM-dd")" type="date" form="@formId" data-construction-entry data-inline-edit-control hidden /></td>
                                <td><span data-inline-edit-value>@row.ExitDate?.ToString("yyyy-MM-dd")</span><input class="inline-cell-control" name="ConstructionEdit.ExitDate" value="@row.ExitDate?.ToString("yyyy-MM-dd")" type="date" form="@formId" data-construction-exit data-inline-edit-control hidden /></td>
                                <td><span data-construction-total>@row.TotalDays</span></td>
                                <td><span data-inline-edit-value>@row.StopDays</span><input class="inline-cell-control" name="ConstructionEdit.StopDays" value="@row.StopDays" type="number" min="0" form="@formId" data-construction-stop data-inline-edit-control hidden /></td>
                                <td><span data-construction-work>@row.WorkDays</span></td>
                                <td><span data-inline-edit-value>@(row.TransferToProjectName ?? "-")</span><select class="inline-cell-control" name="ConstructionEdit.TransferToProjectId" form="@formId" data-inline-edit-control hidden><option value="">留空</option>@foreach (var option in Model.ConstructionWorkspace.Projects.Where(option => option.Id != item.Overview.Id)) { <option value="@option.Id" selected="@(option.Id == row.TransferToProjectId ? "selected" : null)">@option.Label</option> }</select></td>
                                <td><span data-inline-edit-value>@row.Notes</span><input class="inline-cell-control" name="ConstructionEdit.Notes" value="@row.Notes" form="@formId" data-inline-edit-control hidden /></td>
                                 <td><form id="@formId" method="post" asp-page-handler="Construction" asp-route-id="@item.Overview.Id"><input type="hidden" name="ConstructionEdit.Id" value="@row.Id" /><input type="hidden" name="ConstructionEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input class="inline-cell-control" name="ConstructionEdit.Reason" value="项目管理页面快捷修改施工详情" data-inline-edit-actions hidden /><button class="button button--secondary button--small" type="submit" name="ConstructionEdit.AutoConnectPrevious" value="true" data-inline-edit-actions hidden>自动连接上个项目</button><button class="button button--secondary button--small" type="submit" data-inline-edit-actions hidden>自动连接下个项目</button><button class="button button--primary button--small" type="submit" data-inline-edit-actions hidden>保存本行</button><span class="pill">@(row.IsDraft ? "待完善" : "正式")</span></form></td>
                            </tr>
                        }
                        </tbody></table></div>
                    </article>
                </div>
            </section>
        </main>
        <aside class="project-activity-panel" aria-label="项目提示与修改记录"><div class="activity-panel-heading"><div><p class="eyebrow">动态</p><h2>提示与记录</h2></div><span>@item.Activities.Count</span></div><div class="activity-feed">@if (item.Activities.Count == 0) { <div class="empty-state"><strong>暂无动态</strong><p>编辑项目或录入业务后会在这里形成记录。</p></div> } @foreach (var activity in item.Activities) { <article class="activity-item activity-item--@activity.Tone"><span class="activity-dot"></span><div><p class="activity-meta">@activity.Category · @activity.OccurredAt.ToLocalTime().ToString("MM-dd HH:mm")</p><h3>@activity.Title</h3>@if (!string.IsNullOrWhiteSpace(activity.Detail)) { <p>@activity.Detail</p> }@if (!string.IsNullOrWhiteSpace(activity.UserName)) { <small>操作人：@activity.UserName</small> }</div></article> }</div></aside>
    </div>
}
