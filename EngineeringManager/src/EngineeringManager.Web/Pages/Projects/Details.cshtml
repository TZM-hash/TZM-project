nanceRowEdit.Tab" value="payment" /><input type="hidden" name="FinanceRowEdit.RelatedEntryId" value="@row.PayableEntryId" /><input type="hidden" name="FinanceRowEdit.ContractId" value="@row.ContractId" /><input type="hidden" name="FinanceRowEdit.LegalEntityId" value="@row.LegalEntityId" /><input type="hidden" name="FinanceRowEdit.BusinessPartnerId" value="@row.BusinessPartnerId" /><input type="hidden" name="FinanceRowEdit.ConcurrencyStamp" value="@row.ConcurrencyStamp" /><input class="inline-cell-control" name="FinanceRowEdit.Reason" value="项目管理页面快捷修改付款" aria-label="修改原因" /><button class="button button--primary button--small" type="submit">保存本行</button></form></span> }</td></tr>
