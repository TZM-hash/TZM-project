@page
@model EngineeringManager.Web.Pages.Partners.CreateModel
@{
    ViewData["Title"] = Model.IsEditing ? "编辑合作单位" : "新增合作单位";
}

<section class="page-heading"><div><p class="eyebrow">合作单位</p><h1>@ViewData["Title"]</h1><p class="page-lead">维护单位主档、业务角色和主要联系人，项目、应付和付款模块会自动引用同一档案。</p></div><a class="button button--secondary" asp-page="/Partners/Index">返回列表</a></section>
<form method="post" class="panel form-grid">
    <input type="hidden" asp-for="Id" /><input type="hidden" asp-for="ConcurrencyStamp" /><div asp-validation-summary="All" class="panel-copy form-span"></div>
    <section class="form-section"><h2 class="section-heading">单位资料</h2><label>单位编号<input asp-for="PartnerNumber" /></label><label>单位全称<input asp-for="Name" /></label><label>单位简称<input asp-for="ShortName" /></label><label>统一社会信用代码<input asp-for="UnifiedSocialCreditCode" /></label><label>业务角色<select asp-for="RoleType" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Partners.BusinessPartnerRoleType>()"></select></label><label class="checkbox-row"><input asp-for="IsActive" />启用档案</label></section>
    <section class="form-section"><h2 class="section-heading">联系与结算信息</h2><label>行业/工种<input asp-for="TradeCategory" /></label><label>主要联系人<input asp-for="ContactName" /></label><label>联系电话<input asp-for="ContactPhone" /></label><label>备注<textarea asp-for="Notes" rows="4"></textarea></label></section>
    @if (Model.IsEditing) { <label class="form-span">修改原因<textarea asp-for="Reason" rows="2" required></textarea></label> }
    <div class="sticky-actions form-span"><button class="button button--primary" type="submit">保存合作单位</button></div>
</form>
