<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f766e" />
    <title>@ViewData["Title"] - 工程项目经营管理系统</title>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <a class="brand" asp-page="/Index">
                <span class="brand-mark" aria-hidden="true">工</span>
                <span>工程项目经营管理系统</span>
            </a>
            <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" data-menu-toggle>
                <span class="sr-only">打开导航菜单</span>
                <span aria-hidden="true">☰</span>
            </button>
        </header>
        <div class="app-body">
            <aside class="sidebar" id="primary-nav" data-navigation>
                <nav aria-label="主导航">
                    <a class="nav-link is-active" asp-page="/Index">总览</a>
                    <a class="nav-link" asp-page="/Projects/Index">项目管理<span class="nav-status">阶段 2</span></a>
                    <a class="nav-link" asp-page="/Partners/Index">合作单位<span class="nav-status">阶段 3</span></a>
                    <a class="nav-link" asp-page="/StageResults/Index">阶段成果<span class="nav-status">阶段 3</span></a>
                    @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator") || User.IsInRole("ProjectManager") || User.IsInRole("SiteStaff"))
                    {
                        <a class="nav-link" asp-page="/StageResults/Offline">现场离线<span class="nav-status">阶段 7</span></a>
                    }
                    <a class="nav-link" asp-page="/Finance/Index">经营台账<span class="nav-status">阶段 4</span></a>
                    <a class="nav-link" asp-page="/Employees/Index">员工管理<span class="nav-status">阶段 5</span></a>
                    <a class="nav-link" asp-page="/Payroll/Index">工资台账<span class="nav-status">阶段 5</span></a>
                    <a class="nav-link" asp-page="/EmployeeLedger/Index">员工往来<span class="nav-status">阶段 5</span></a>
                    <a class="nav-link" asp-page="/DataExchange/Index">导入导出<span class="nav-status">阶段 6</span></a>
                    <a class="nav-link" asp-page="/Reminders/Index">提醒中心<span class="nav-status">阶段 6</span></a>
                    @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator"))
                    {
                        <a class="nav-link" asp-page="/Backups/Index">备份管理<span class="nav-status">阶段 6</span></a>
                    }
                </nav>
                <div class="sidebar-footer">
                    <span class="status-dot" aria-hidden="true"></span>
                    <span>阶段 0～7 已完成</span>
                </div>
            </aside>
            <main class="main-content" role="main">
                @RenderBody()
            </main>
        </div>
    </div>
    <div class="toast-region" aria-live="polite" data-pwa-status></div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
