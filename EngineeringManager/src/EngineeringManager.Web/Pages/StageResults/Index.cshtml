@page
@model EngineeringManager.Web.Pages.StageResults.IndexModel
@{
    ViewData["Title"] = "阶段成果";
}

<section class="page-heading">
    <div><p class="eyebrow">阶段性记录</p><h1>阶段成果</h1><p class="page-lead">用于阶段完成、验收和完工资料，不建设高频施工日志。</p></div>
    <a class="button button--secondary" asp-page="/StageResults/Create">提交阶段成果</a>
</section>

<section class="panel">
    <div class="panel-heading"><div><p class="eyebrow">成果记录</p><h2>阶段成果列表</h2></div></div>
    <partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.StageResults" />
    @if (Model.Results.Count == 0)
    {
        <p class="panel-copy">还没有阶段成果记录。</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table" id="stage-results-table">
                <thead><tr><th data-column-key="date">日期</th><th data-column-key="name">名称</th><th data-column-key="type">类型</th><th data-column-key="status">状态</th><th data-column-key="quality">质量</th><th data-column-key="lines">工程量项</th><th data-column-key="attachments">附件</th></tr></thead>
                <tbody>
                @foreach (var result in Model.Results)
                {
                    <tr><td data-column-key="date">@result.ResultDate</td><td data-column-key="name">@result.Title</td><td data-column-key="type">@result.ResultType</td><td data-column-key="status">@result.Status</td><td data-column-key="quality">@result.QualityResult</td><td data-column-key="lines">@result.Lines.Count</td><td data-column-key="attachments">@result.Attachments.Count</td></tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
