@page
@model EngineeringManager.Web.Pages.EmployeeLedger.IndexModel
@{
    ViewData["Title"] = "员工往来";
}

<section class="page-heading"><div><p class="eyebrow">内部往来</p><h1>员工往来</h1><p class="page-lead">简单管理报销、借支、归还、工资抵扣、分红、利息和其他往来，不建立复杂审批或股权档案。</p></div></section>
<section class="metric-grid" aria-label="员工往来汇总">
    <article class="metric-card"><span class="metric-label">报销应付</span><strong class="metric-value">@Model.Overview.ExpensePayableAmount.ToString("N2")</strong><span class="metric-hint">有效报销记录</span></article>
    <article class="metric-card"><span class="metric-label">报销未付</span><strong class="metric-value">@Model.Overview.ExpenseUnpaidAmount.ToString("N2")</strong><span class="metric-hint">应付减支付加退回</span></article>
    <article class="metric-card"><span class="metric-label">借支未清</span><strong class="metric-value">@Model.Overview.AdvanceOutstandingAmount.ToString("N2")</strong><span class="metric-hint">发放减归还和工资抵扣</span></article>
    <article class="metric-card"><span class="metric-label">其他未付</span><strong class="metric-value">@Model.Overview.OtherUnpaidAmount.ToString("N2")</strong><span class="metric-hint">分红、利息和其他往来</span></article>
</section>
<section class="panel" style="margin-top: var(--space-3)"><div class="panel-heading"><div><p class="eyebrow">员工维度</p><h2>往来余额</h2></div></div><partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.EmployeeLedger" /><div class="table-wrap"><table class="data-table" id="employee-ledger-table"><thead><tr><th data-column-key="employee">员工</th><th data-column-key="expense_payable">报销应付</th><th data-column-key="expense_paid">报销已付</th><th data-column-key="expense_unpaid">报销未付</th><th data-column-key="advance">借支未清</th><th data-column-key="other_payable">其他应付</th><th data-column-key="other_paid">其他已付</th><th data-column-key="other_unpaid">其他未付</th><th data-column-key="risk">风险</th></tr></thead><tbody>
@foreach (var item in Model.Overview.EmployeeSummaries)
{
    <tr><td data-column-key="employee">@item.EmployeeNumber · @item.EmployeeName</td><td data-column-key="expense_payable">@item.Summary.ExpensePayableAmount.ToString("N2")</td><td data-column-key="expense_paid">@item.Summary.ExpensePaidAmount.ToString("N2")</td><td data-column-key="expense_unpaid">@item.Summary.ExpenseUnpaidAmount.ToString("N2")</td><td data-column-key="advance">@item.Summary.AdvanceOutstandingAmount.ToString("N2")</td><td data-column-key="other_payable">@item.Summary.OtherPayableAmount.ToString("N2")</td><td data-column-key="other_paid">@item.Summary.OtherPaidAmount.ToString("N2")</td><td data-column-key="other_unpaid">@item.Summary.OtherUnpaidAmount.ToString("N2")</td><td data-column-key="risk">@(item.Summary.HasExpenseOverpaymentRisk || item.Summary.HasOtherOverpaymentRisk || item.Summary.HasAdvanceOverSettlementRisk ? "需关注" : "正常")</td></tr>
}
</tbody></table></div></section>
