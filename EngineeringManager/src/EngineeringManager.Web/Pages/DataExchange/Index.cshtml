@page
@model EngineeringManager.Web.Pages.DataExchange.IndexModel
@using EngineeringManager.Domain.DataExchange
@using EngineeringManager.Web.Pages.DataExchange
@using EngineeringManager.Application.DataExchange
@{
    ViewData["Title"] = "导入导出";
    var datasets = Enum.GetValues<EngineeringManager.Domain.DataExchange.ExportDataset>();
}

<section class="page-heading data-exchange-heading"><div><p class="eyebrow">数据交换工作台</p><h1>导入导出</h1><p class="page-lead">所有业务模块统一使用 Excel。导出沿用当前筛选，导入先校验预览，确认后才写入。</p></div><div class="data-exchange-heading-note"><strong>Excel</strong><span>批量编辑、分享与迁移</span></div></section>

<nav class="workspace-tabs" aria-label="数据交换功能"><a href="#export-panel" class="workspace-tab is-active">导出 Excel</a><a href="#import-panel" class="workspace-tab">导入 Excel</a><a href="#history-panel" class="workspace-tab">任务历史</a></nav>

<section id="export-panel" class="data-exchange-panel" data-exchange-export>
    <div class="data-exchange-section-heading"><div><p class="eyebrow">导出设置</p><h2>选择数据范围</h2></div><span>支持单模块或多模块导出</span></div>
    <div class="data-exchange-layout data-exchange-layout--export">
        <form method="post" asp-page-handler="ExportModules" class="exchange-card exchange-card--settings">
            <div class="exchange-card-heading"><strong>导出范围</strong><span>沿用当前模块权限</span></div>
            <div class="compact-form-grid">
                <label>当前模块<select asp-for="Dataset">@foreach (var dataset in datasets) { <option value="@dataset" selected="@(dataset == Model.Dataset)">@DataExchangeLabels.Dataset(dataset)</option> }</select></label>
                <label>数据范围<select asp-for="Scope">@foreach (var value in Enum.GetValues<ExportScope>()) { <option value="@value" selected="@(value == Model.Scope)">@DataExchangeLabels.Scope(value)</option> }</select></label>
                <label>文件格式<select asp-for="PackageFormat">@foreach (var value in Enum.GetValues<ExportPackageFormat>()) { <option value="@value" selected="@(value == Model.PackageFormat)">@DataExchangeLabels.PackageFormat(value)</option> }</select></label>
                <label>统计截止日<input asp-for="CutoffDate" type="date" /></label>
            </div>
            <details class="selection-dropdown" data-check-selector data-check-selector-empty-label="当前模块">
                <summary class="selection-dropdown-toggle"><span>导出模块</span><strong data-check-selector-count></strong></summary>
                <div class="selection-dropdown-menu">
                    <div class="selection-dropdown-heading"><span>勾选需要导出的模块</span><div><button type="button" data-check-selector-all>全选</button><button type="button" data-check-selector-default>恢复默认</button></div></div>
                    <div class="check-grid">@foreach (var dataset in datasets) { <label><input type="checkbox" name="SelectedDatasets" value="@dataset" checked="@(Model.SelectedDatasets.Contains(dataset) ? "checked" : null)" data-check-selector-option data-default="@(dataset == Model.Dataset ? "true" : "false")" /> @DataExchangeLabels.Dataset(dataset)</label> }</div>
                </div>
            </details>
            <label class="check-label exchange-check"><input asp-for="IncludeAttachments" /> 包含附件，并在 Excel 中生成相对路径链接</label>
            <button class="button button--primary" type="submit">生成导出文件</button>
        </form>

        <section class="exchange-card" data-field-selection>
            <div class="exchange-card-heading"><strong>字段选择</strong><span>最后一次选择会自动保存</span></div>
            <p class="exchange-help">不勾选时使用默认字段；敏感字段按当前权限自动脱敏。</p>
            <form method="post" asp-page-handler="Export" class="field-selection-form">
                <input type="hidden" asp-for="Dataset" /><input type="hidden" asp-for="CutoffDate" />
                <details class="selection-dropdown" data-check-selector data-check-selector-empty-label="默认字段">
                    <summary class="selection-dropdown-toggle"><span>选择导出字段</span><strong data-check-selector-count></strong></summary>
                    <div class="selection-dropdown-menu selection-dropdown-menu--fields">
                        <div class="selection-dropdown-heading"><span>勾选后直接用于导出</span><div><button type="button" data-check-selector-all>全选</button><button type="button" data-check-selector-default>恢复默认</button></div></div>
                        <div class="field-choice-grid">@foreach (var field in Model.Fields) { <label title="@(field.IsSensitive ? "敏感字段：普通用户自动脱敏" : field.IsCalculated ? "计算字段，仅可导出" : null)"><input type="checkbox" name="SelectedFields" value="@field.Key" checked="@(Model.SelectedFields.Contains(field.Key) || (Model.SelectedFields.Count == 0 && field.IsDefault) ? "checked" : null)" data-check-selector-option data-default="@field.IsDefault.ToString().ToLowerInvariant()" /> <span>@field.Label@(field.IsSensitive ? " · 敏感" : null)</span></label> }</div>
                    </div>
                </details>
                <button class="button button--secondary" type="submit">导出当前模块</button>
            </form>
            <form method="post" asp-page-handler="SaveTemplate" class="template-form"><input type="hidden" asp-for="Dataset" />@foreach (var field in Model.SelectedFields) { <input type="hidden" name="SelectedFields" value="@field" /> }<label>保存字段模板<input asp-for="TemplateName" placeholder="例如：项目经营分享版" /></label>@if (Model.CanManage) { <label class="check-label"><input asp-for="SharedTemplate" /> 共享模板</label> }<button class="button button--ghost" type="submit">保存模板</button></form>
            @if (Model.Templates.Count > 0) { <p class="exchange-help">已有模板：@string.Join("、", Model.Templates.Select(item => item.Name))</p> }
        </section>
    </div>
</section>

<section class="data-exchange-panel" data-project-workbook>
    <div class="data-exchange-section-heading"><div><p class="eyebrow">项目管理工作簿</p><h2>按项目范围和细项交换</h2></div><span>支持筛选、手动勾选和多工作表</span></div>
    <div class="data-exchange-layout data-exchange-layout--export">
        @if (Model.CanExportProjectWorkbook)
        {
        <form method="post" asp-page-handler="ExportProjectWorkbook" class="exchange-card">
            <div class="exchange-card-heading"><strong>导出项目工作簿</strong><span>全部授权状态</span></div>
            <div class="compact-form-grid"><label>关键词<input asp-for="ProjectSearch" /></label><label>项目阶段<select asp-for="ProjectStages" multiple>@foreach (var stage in Enum.GetValues<EngineeringManager.Domain.Projects.ProjectStage>()) { <option value="@stage">@stage</option> }</select></label><label>合作方式<select asp-for="ProjectAffiliationType"><option value="">全部</option>@foreach (var value in Enum.GetValues<EngineeringManager.Domain.Projects.ProjectAffiliationType>()) { <option value="@value">@value</option> }</select></label><label>签约公司<select asp-for="ProjectLegalEntityId"><option value="">全部</option>@foreach (var company in Model.ProjectWorkbookOptions.LegalEntities) { <option value="@company.Value">@company.Label</option> }</select></label><label>负责人<select asp-for="ProjectResponsibleUserId"><option value="">全部</option>@foreach (var user in Model.ProjectWorkbookOptions.ResponsibleUsers) { <option value="@user.Value">@user.Label</option> }</select></label><label>当前金额下限<input asp-for="ProjectMinimumCurrentAmount" type="number" step="0.01" /></label><label>当前金额上限<input asp-for="ProjectMaximumCurrentAmount" type="number" step="0.01" /></label></div>
            <p class="exchange-help">筛选命中 @Model.ProjectWorkbookProjects.TotalCount 个项目；已手动选择 <strong data-project-export-selected-count>0</strong> 个；手动勾选时以勾选项目为准。</p>
            <label class="check-label"><input asp-for="SelectAllMatchingProjects" data-project-export-all-matching /> 导出筛选命中的全部项目</label>
            <div class="project-workbook-project-list">@foreach (var project in Model.ProjectWorkbookProjects.Items) { <label><input type="checkbox" name="SelectedProjectIds" value="@project.Project.Id" data-project-export-item /> @project.Project.ProjectNumber · @project.Project.Name</label> }</div>
            @if (Model.CanExportProjectWorkbookAttachments) { <label class="check-label"><input asp-for="IncludeProjectAttachments" data-project-export-attachments /> 包含附件并生成 ZIP</label> }
            <details class="selection-dropdown"><summary>选择项目细项</summary><div class="check-grid">@foreach (var sheet in Model.ProjectWorkbookSheets.Where(sheet => Model.CanExportFullProjectWorkbook || sheet.Sheet != ProjectWorkbookSheet.ProjectSummary && sheet.Sheet != ProjectWorkbookSheet.Attachments)) { <label><input type="checkbox" name="SelectedProjectSheets" value="@sheet.Sheet" checked="@(Model.SelectedProjectSheets.Count == 0 || Model.SelectedProjectSheets.Contains(sheet.Sheet) ? "checked" : null)" data-project-workbook-sheet="@sheet.Sheet" /> @sheet.WorksheetName@(sheet.CanImport ? null : " · 只读")</label> }</div></details>
            <button class="button button--primary" type="submit">生成项目工作簿</button>
        </form>
        }
        @if (Model.CanManage)
        {
            <form method="post" enctype="multipart/form-data" asp-page-handler="PreviewProjectWorkbook" class="exchange-card">
                <div class="exchange-card-heading"><strong>导入项目工作簿</strong><span>整份文件原子校验</span></div>
                <label>Excel 或 ZIP<input asp-for="ProjectWorkbookFile" type="file" accept=".xlsx,.zip" /></label>
                <label>导入模式<select asp-for="ProjectWorkbookImportMode">@foreach (var value in Enum.GetValues<ImportMode>()) { <option value="@value">@DataExchangeLabels.ImportMode(value)</option> }</select></label>
                <label>任意 Excel 的目标细项<select asp-for="MappingTargetSheet">@foreach (var sheet in Model.ProjectWorkbookSheets.Where(item => item.CanImport)) { <option value="@sheet.Sheet">@sheet.WorksheetName</option> }</select></label>
                <label>字段映射 JSON（标准工作簿留空）<textarea asp-for="SourceMappingJson" rows="3"></textarea></label>
                <label class="check-label"><input asp-for="BlankMeansNoChange" /> 任意 Excel 空白时不更新</label>
                <button class="button button--primary" type="submit">上传并全量预览</button>
            </form>
        }
    </div>
    @if (Model.ProjectWorkbookPreview is not null)
    {
        <div class="import-result"><div class="table-wrap"><table class="data-table"><thead><tr><th>工作表</th><th>总行数</th><th>新增</th><th>更新</th><th>未变化</th><th>错误</th></tr></thead><tbody>@foreach (var sheet in Model.ProjectWorkbookPreview.Sheets) { <tr><td>@sheet.WorksheetName</td><td>@sheet.TotalRows</td><td>@sheet.NewRows</td><td>@sheet.UpdatedRows</td><td>@sheet.UnchangedRows</td><td>@sheet.ErrorRows</td></tr> }</tbody></table></div>@if (Model.ProjectWorkbookPreview.Errors.Count == 0) { <form method="post" asp-page-handler="ConfirmProjectWorkbook"><input type="hidden" name="batchId" value="@Model.ProjectWorkbookPreview.BatchId" /><button class="button button--primary" type="submit">确认整批导入</button></form> } else { <p class="validation-summary">存在 @Model.ProjectWorkbookPreview.Errors.Count 个错误，整份文件不会写入。</p><div class="table-wrap"><table class="data-table"><thead><tr><th>源行</th><th>源列</th><th>原值</th><th>错误与修正建议</th></tr></thead><tbody>@foreach (var error in Model.ProjectWorkbookPreview.Errors) { <tr><td>@error.RowNumber</td><td>@error.ColumnName</td><td>@error.RawValue</td><td>@error.Message</td></tr> }</tbody></table></div> }</div>
    }
</section>

@if (Model.CanManage)
{
    <section id="import-panel" class="data-exchange-panel" data-exchange-import>
        <div class="data-exchange-section-heading"><div><p class="eyebrow">批量导入</p><h2>模板、上传、预览、确认</h2></div><span>整批校验，错误不写入</span></div>
        <div class="stepper" aria-label="导入步骤"><span class="is-current">1 选择来源</span><span>2 字段映射</span><span>3 预览校验</span><span>4 确认写入</span></div>
        <div class="data-exchange-layout import-grid">
            <form method="post" asp-page-handler="DownloadTemplate" class="exchange-card"><div class="exchange-card-heading"><strong>下载空白模板</strong><span>填写后批量导入</span></div><label>模板类型<select asp-for="ImportDataset">@foreach (var dataset in datasets) { <option value="@dataset" selected="@(dataset == Model.ImportDataset)">@DataExchangeLabels.Dataset(dataset)</option> }</select></label><button class="button button--secondary" type="submit">下载 Excel 模板</button><p class="exchange-help">模板包含必填字段、可选枚举、关联键和填写说明。</p></form>
            <form method="post" enctype="multipart/form-data" asp-page-handler="PreviewImport" class="exchange-card"><div class="exchange-card-heading"><strong>上传并预览</strong><span>确认前不会写入数据</span></div><div class="compact-form-grid"><label>导入数据集<select asp-for="ImportDataset">@foreach (var dataset in datasets) { <option value="@dataset" selected="@(dataset == Model.ImportDataset)">@DataExchangeLabels.Dataset(dataset)</option> }</select></label><label>更新方式<select asp-for="ImportMode">@foreach (var value in Enum.GetValues<ImportMode>()) { <option value="@value" selected="@(value == Model.ImportMode)">@DataExchangeLabels.ImportMode(value)</option> }</select></label></div><label>Excel 文件<input asp-for="ImportFile" type="file" accept=".xlsx" /></label><label>高级字段映射（可留空自动匹配）<textarea asp-for="SourceMappingJson" rows="2" placeholder='{"姓名":"姓名","联系电话":"联系电话"}'></textarea></label><button class="button button--primary" type="submit">上传并预览</button></form>
        </div>
        <form method="post" asp-page-handler="SaveMappingTemplate" class="mapping-template-form"><input type="hidden" asp-for="ImportDataset" /><input type="hidden" asp-for="SourceMappingJson" /><label>保存映射模板<input asp-for="MappingTemplateName" placeholder="例如：旧系统员工表" /></label>@if (Model.CanManage) { <label class="check-label"><input asp-for="SharedMappingTemplate" /> 共享模板</label> }<button class="button button--ghost" type="submit">保存映射</button><span class="exchange-help">已有：@(Model.MappingTemplates.Count == 0 ? "暂无" : string.Join("、", Model.MappingTemplates.Select(item => item.Name)))</span></form>
        @if (Model.Preview is not null)
        {
            <div class="import-result"><p class="exchange-help">批次 @Model.Preview.BatchId · 总行数 @Model.Preview.TotalRows · 有效 @Model.Preview.ValidRows · 错误 @Model.Preview.ErrorRows</p>@if (Model.Preview.Errors.Count == 0) { <form method="post" asp-page-handler="ConfirmImport"><input type="hidden" name="batchId" value="@Model.Preview.BatchId" /><button class="button button--primary" type="submit">确认整批导入</button></form> } else { <div class="table-wrap"><table class="data-table"><thead><tr><th>源行</th><th>源列</th><th>原值</th><th>错误与修正建议</th></tr></thead><tbody>@foreach (var error in Model.Preview.Errors) { <tr><td>@error.RowNumber</td><td>@error.ColumnName</td><td>@error.RawValue</td><td>@error.Message</td></tr> }</tbody></table></div> }</div>
        }
    </section>
}

<section id="history-panel" class="panel data-exchange-panel" data-exchange-history>
    <div class="data-exchange-section-heading"><div><p class="eyebrow">可追溯记录</p><h2>导出任务历史</h2></div><span>最近 100 条</span></div>
    @if (Model.Tasks.Count == 0) { <p class="exchange-help">暂无导出任务。</p> } else { <div class="table-wrap"><table class="data-table"><thead><tr><th>时间</th><th>模块</th><th>范围</th><th>格式</th><th>行数</th><th>状态</th><th>文件</th></tr></thead><tbody>@foreach (var task in Model.Tasks) { <tr><td>@task.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td><td>@string.Join("、", task.Datasets.Select(DataExchangeLabels.Dataset))</td><td>@DataExchangeLabels.Scope(task.Scope)</td><td>@DataExchangeLabels.PackageFormat(task.PackageFormat)@(task.IncludeAttachments ? " + 附件" : null)</td><td>@task.RowCount</td><td>@DataExchangeLabels.TaskStatus(task.Status)</td><td>@task.FileName</td></tr> }</tbody></table></div> }
</section>
