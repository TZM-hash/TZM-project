@page
@model EngineeringManager.Web.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "员工管理";
}

<section class="page-heading">
    <div><p class="eyebrow">人员主档</p><h1>员工管理</h1><p class="page-lead">统一管理正式员工和劳务员工。部门、项目、班组和签约公司归属按时间段保存，历史工资和往来不会随主档复制。</p></div>
    @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator"))
    {
        <a class="button button--secondary" asp-page="/Employees/Create">新增员工</a>
    }
</section>

<section class="metric-grid" aria-label="员工统计">
    <article class="metric-card"><span class="metric-label">员工总数</span><strong class="metric-value">@Model.Employees.Count</strong><span class="metric-hint">当前员工主档</span></article>
    <article class="metric-card"><span class="metric-label">正式员工</span><strong class="metric-value">@Model.Employees.Count(item => item.EmployeeType == EngineeringManager.Domain.Employees.EmployeeType.Formal)</strong><span class="metric-hint">公司正式员工</span></article>
    <article class="metric-card"><span class="metric-label">劳务员工</span><strong class="metric-value">@Model.Employees.Count(item => item.EmployeeType == EngineeringManager.Domain.Employees.EmployeeType.Labor)</strong><span class="metric-hint">直接聘用或班组归属</span></article>
    <article class="metric-card"><span class="metric-label">在用员工</span><strong class="metric-value metric-value--good">@Model.Employees.Count(item => item.IsActive)</strong><span class="metric-hint">未停用主档</span></article>
</section>

<section class="panel chart-summary" data-chart data-chart-kind="progress-ring" data-chart-value="@(Model.Employees.Count == 0 ? 0 : (decimal)Model.Employees.Count(item => item.IsActive) / Model.Employees.Count * 100m)" data-chart-label="在用员工比例"><div class="panel-heading"><div><p class="eyebrow">图形摘要</p><h2>在用员工比例</h2></div></div><div data-chart-canvas></div></section>

<section class="panel" style="margin-top: var(--space-3)">
    <div class="panel-heading"><div><p class="eyebrow">员工清单</p><h2>基础资料</h2></div></div>
    <partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.Employees" />
    <div class="table-wrap"><table class="data-table" id="employees-table"><thead><tr><th data-column-key="employee_number">员工编号</th><th data-column-key="name">姓名</th><th data-column-key="employee_type">类型</th><th data-column-key="position">岗位</th><th data-column-key="phone">电话</th><th data-column-key="assignments">主归属记录</th><th data-column-key="status">状态</th></tr></thead><tbody>
    @foreach (var item in Model.Employees)
    {
        <tr><td data-column-key="employee_number">@item.EmployeeNumber</td><td data-column-key="name">@item.Name</td><td data-column-key="employee_type">@item.EmployeeType</td><td data-column-key="position">@item.PositionTitle</td><td data-column-key="phone">@item.Phone</td><td data-column-key="assignments">@item.Affiliations.Count</td><td data-column-key="status">@(item.IsActive ? "启用" : "停用")</td></tr>
    }
    </tbody></table></div>
</section>
