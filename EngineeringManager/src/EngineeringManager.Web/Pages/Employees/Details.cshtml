@page
@model EngineeringManager.Web.Pages.Employees.DetailsModel
@{ ViewData["Title"] = "员工详情"; var affiliation = Model.Employee.Affiliations.FirstOrDefault(item => item.IsPrimary); }

<partial name="_EmployeeSubNavigation" />
<section class="page-heading"><div><p class="eyebrow">员工详情</p><h1>@Model.Employee.EmployeeNumber · @Model.Employee.Name</h1><p class="page-lead">主档、年度总账、证书和历史记录集中在同一员工档案中。</p></div></section>
<section class="panel detail-grid">
    <div><span>员工编号</span><strong>@Model.Employee.EmployeeNumber</strong></div><div><span>姓名</span><strong>@Model.Employee.Name</strong></div><div><span>类型</span><strong>@Model.Employee.EmployeeType</strong></div><div><span>状态</span><strong>@(Model.Employee.IsActive ? "启用" : "停用")</strong></div>
    <div><span>联系方式</span><strong>@(Model.Employee.Phone ?? "未填写")</strong></div><div><span>身份证</span><strong>@(Model.Employee.IdentityNumber ?? "未填写")</strong></div><div><span>开户行</span><strong>@(Model.Employee.BankName ?? "未填写")</strong></div><div><span>银行卡号</span><strong>@(Model.Employee.BankAccountNumber ?? "未填写")</strong></div>
    <div><span>入职日期</span><strong>@(Model.Employee.HireDate?.ToString() ?? "未填写")</strong></div><div><span>离职日期</span><strong>@(Model.Employee.LeaveDate?.ToString() ?? "未填写")</strong></div><div><span>工种岗位</span><strong>@(Model.Employee.PositionTitle ?? "未填写")</strong></div><div><span>主要计薪方式</span><strong>@Model.PrimaryPayMethod</strong></div>
    <div><span>当前公司</span><strong>@(affiliation?.LegalEntityName ?? "未归属")</strong></div><div><span>当前部门</span><strong>@(affiliation?.DepartmentName ?? "未归属")</strong></div><div><span>当前项目</span><strong>@(affiliation?.ProjectName ?? "未归属")</strong></div><div><span>当前班组</span><strong>@(affiliation?.CrewBusinessPartnerName ?? "未归属")</strong></div>
    <div><span>主档备注</span><strong>@(Model.Employee.Notes ?? "暂无备注")</strong></div><div><span>证书摘要</span><strong>@Model.Certificates.Count 项</strong></div>
</section>

@if (Model.Ledger is not null)
{
    <section class="overview-strip" aria-label="当前年度总账"><article><span>往年结转</span><strong>@Model.Ledger.Summary.PriorYearCarryForward.ToString("N2")</strong></article><article><span>本年度工资应发</span><strong>@Model.Ledger.Summary.CurrentYearWagePayable.ToString("N2")</strong></article><article><span>报销应付</span><strong>@Model.Ledger.Summary.ExpensePayable.ToString("N2")</strong></article><article><span>分红及其他应付</span><strong>@Model.Ledger.Summary.OtherPayable.ToString("N2")</strong></article><article><span>管理员调整</span><strong>@Model.Ledger.Summary.AdjustmentAmount.ToString("N2")</strong></article><article><span>本年新增应付</span><strong>@Model.Ledger.Summary.CurrentYearNewPayable.ToString("N2")</strong></article><article><span>已领总额</span><strong>@Model.Ledger.Summary.ReceivedAmount.ToString("N2")</strong></article><article><span>当前余额</span><strong>@Model.Ledger.Summary.CurrentBalance.ToString("N2")</strong></article><article><span>结算进度</span><strong>@Model.Ledger.Summary.SettlementProgressPercent.ToString("N2")%</strong></article></section>
}

<nav class="page-tabs" aria-label="员工详情标签">
    <a asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="wages">工资明细</a><a asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="expenses">报销明细</a><a asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="other">分红及其他</a><a asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="receipts">领款明细</a><a asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="certificates">证书管理</a><a asp-route-id="@Model.Id" asp-route-businessYearId="@Model.BusinessYearId" asp-route-tab="history">历史记录</a>
</nav>
<section class="panel">
@if (Model.Tab == "expenses")
{
    <div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>来源</th><th>最终金额</th></tr></thead><tbody>@foreach (var line in Model.Ledger?.PayableLines.Where(item => item.Category == EngineeringManager.Domain.Employees.AnnualLedgerEntryCategory.Expense) ?? []) { <tr><td>@line.EntryDate</td><td>@line.SourceType</td><td>@line.Amount.ToString("N2")</td></tr> }</tbody></table></div>
    @if (Model.CanEditFinancial)
    {
        <form method="post" enctype="multipart/form-data" asp-page-handler="AddExpense" class="form-grid"><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="BusinessYearId" /><label>日期<input asp-for="ExpenseInput.ExpenseDate" type="date" /></label><label>类别<input asp-for="ExpenseInput.Category" /></label><label>原始金额<input asp-for="ExpenseInput.OriginalAmount" type="number" step="0.01" /></label><label>管理员调整<input asp-for="ExpenseInput.AdjustmentAmount" type="number" step="0.01" /></label><label>公司<select asp-for="ExpenseInput.LegalEntityId">@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>项目<select asp-for="ExpenseInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>票据号<input asp-for="ExpenseInput.ReceiptNumber" /></label><label>可选附件<input asp-for="ExpenseInput.Attachment" type="file" /></label><label>备注<textarea asp-for="ExpenseInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存报销</button></form>
    }
}
else if (Model.Tab == "other")
{
    <div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>类型</th><th>金额</th></tr></thead><tbody>@foreach (var line in Model.Ledger?.PayableLines.Where(item => item.Category == EngineeringManager.Domain.Employees.AnnualLedgerEntryCategory.OtherPayable) ?? []) { <tr><td>@line.EntryDate</td><td>@line.SourceType</td><td>@line.Amount.ToString("N2")</td></tr> }</tbody></table></div>
    @if (Model.CanEditFinancial)
    {
        <form method="post" asp-page-handler="AddOtherPayable" class="form-grid"><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="BusinessYearId" /><label>日期<input asp-for="OtherInput.EntryDate" type="date" /></label><label>类型<select asp-for="OtherInput.EntryType"><option value="4">分红</option><option value="5">利息</option><option value="6">其他应付</option></select></label><label>金额<input asp-for="OtherInput.Amount" type="number" step="0.01" /></label><label>公司<select asp-for="OtherInput.LegalEntityId">@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>项目<select asp-for="OtherInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>备注<textarea asp-for="OtherInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存分红及其他</button></form>
    }
}
else if (Model.Tab == "receipts")
{
    <div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>来源</th><th>实际收款人</th><th>金额</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var line in Model.Ledger?.ReceiptLines ?? []) { <tr><td>@line.ReceiptDate</td><td>@line.SourceType</td><td>@(line.Recipient ?? "未填写")</td><td>@line.Amount.ToString("N2")</td><td>@line.Notes</td><td>@if (line.PayrollBatchId.HasValue) { <a asp-page="/Payroll/Edit" asp-route-id="@line.PayrollBatchId" asp-route-lineId="@line.PayrollPaymentId" asp-route-returnUrl="@($"/Employees/Details?id={Model.Id}&businessYearId={Model.BusinessYearId}&tab=receipts")">查看并修改来源批次</a> }</td></tr> }</tbody></table></div>
    @if (Model.CanEditFinancial)
    {
        <form method="post" asp-page-handler="AddReceipt" class="form-grid"><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="BusinessYearId" /><label>日期<input asp-for="ReceiptInput.ReceiptDate" type="date" /></label><label>类型<select asp-for="ReceiptInput.ReceiptType"><option value="1">工资</option><option value="2">报销</option><option value="3">分红及其他</option><option value="4">借支</option><option value="5">其他</option></select></label><label>金额<input asp-for="ReceiptInput.Amount" type="number" step="0.01" /></label><label>付款公司<select asp-for="ReceiptInput.PaymentLegalEntityId">@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>账户<select asp-for="ReceiptInput.AccountId">@foreach (var item in Model.Accounts) { <option value="@item.Id">@item.LegalEntityName · @item.AccountName</option> }</select></label><label>支付方式<select asp-for="ReceiptInput.PaymentMethod"><option value="1">银行转账</option><option value="2">现金</option><option value="3">微信</option><option value="4">支付宝</option><option value="5">其他</option></select></label><label>实际收款人<input asp-for="ReceiptInput.ActualRecipientName" /></label><label>项目<select asp-for="ReceiptInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>劳务单位<select asp-for="ReceiptInput.LaborBusinessPartnerId"><option value="">未归属</option>@foreach (var item in Model.LaborPartners) { <option value="@item.Id">@item.Name</option> }</select></label><label>备注<textarea asp-for="ReceiptInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存领款</button></form>
    }
}
else if (Model.Tab == "certificates")
{
    <div class="table-wrap"><table class="data-table"><thead><tr><th>证书</th><th>编号</th><th>有效期</th><th>备注</th></tr></thead><tbody>@foreach (var certificate in Model.Certificates) { <tr><td>@certificate.CertificateType</td><td>@certificate.CertificateNumber</td><td>@(certificate.ExpiresOn?.ToString() ?? "长期有效")</td><td>@certificate.Notes</td></tr> }</tbody></table></div>
}
else if (Model.Tab == "history")
{
    <div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>来源</th><th>金额</th><th>操作</th></tr></thead><tbody>@foreach (var line in Model.Ledger?.PayableLines.Where(item => item.Category == EngineeringManager.Domain.Employees.AnnualLedgerEntryCategory.Adjustment || item.Category == EngineeringManager.Domain.Employees.AnnualLedgerEntryCategory.OpeningBalance) ?? []) { <tr><td>@line.EntryDate</td><td>@line.SourceType</td><td>@line.Amount.ToString("N2")</td><td>@if (Model.CanAdjust && line.SourceType == "EmployeeFinancialAdjustment") { <form method="post" asp-page-handler="ReverseAdjustment"><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="BusinessYearId" /><input type="hidden" name="adjustmentId" value="@line.Id" /><input type="date" name="reversalDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" /><input name="notes" value="冲销调整" /><button class="button button--secondary button--small" type="submit">相反金额冲销</button></form> }</td></tr> }</tbody></table></div>
    @if (Model.CanAdjust)
    {
        <form method="post" asp-page-handler="AddAdjustment" class="form-grid"><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="BusinessYearId" /><label>日期<input asp-for="AdjustmentInput.AdjustmentDate" type="date" /></label><label>类型<select asp-for="AdjustmentInput.AdjustmentType"><option value="1">管理员调整</option><option value="2">历史期初余额</option></select></label><label>正负金额<input asp-for="AdjustmentInput.Amount" type="number" step="0.01" /></label><label>备注<textarea asp-for="AdjustmentInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存不可修改调整</button></form>
    }
}
else
{
    <div class="table-wrap"><table class="data-table"><thead><tr><th>起始日期</th><th>来源</th><th>最终金额</th><th>归属</th></tr></thead><tbody>@foreach (var line in Model.Ledger?.PayableLines.Where(item => item.Category == EngineeringManager.Domain.Employees.AnnualLedgerEntryCategory.Wage) ?? []) { <tr><td>@line.EntryDate</td><td>@line.SourceType</td><td>@line.Amount.ToString("N2")</td><td>@(line.IsUnassigned ? "未归属" : "已归属或历史记录")</td></tr> }</tbody></table></div>
    @if (Model.CanEditFinancial)
    {
        <form method="post" asp-page-handler="AddWage" class="form-grid"><input type="hidden" asp-for="Id" /><input type="hidden" asp-for="BusinessYearId" /><label>开始日期<input asp-for="WageInput.StartDate" type="date" /></label><label>结束日期<input asp-for="WageInput.EndDate" type="date" /></label><label>收入/扣减<select asp-for="WageInput.Nature"><option value="1">收入</option><option value="2">扣减</option></select></label><label>工资分类<select asp-for="WageInput.WageCategory"><option value="1">社保工资</option><option value="2">民工工资</option><option value="3">其他工资</option></select></label><label>计薪方式<select asp-for="WageInput.CalculationMethod"><option value="1">月薪</option><option value="2">计日</option><option value="3">计时</option><option value="4">计件</option><option value="5">固定金额</option><option value="6">自定义单位</option></select></label><label>数量<input asp-for="WageInput.Quantity" type="number" step="0.0001" /></label><label>自定义单位<input asp-for="WageInput.Unit" /></label><label>单价<input asp-for="WageInput.UnitPrice" type="number" step="0.0001" /></label><label>手工金额<input asp-for="WageInput.ManualAmount" type="number" step="0.01" /></label><label>公司<select asp-for="WageInput.LegalEntityId"><option value="">未归属</option>@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.ShortName</option> }</select></label><label>项目<select asp-for="WageInput.ProjectId"><option value="">未归属</option>@foreach (var item in Model.Projects) { <option value="@item.Project.Id">@item.Project.Name</option> }</select></label><label>劳务单位<select asp-for="WageInput.LaborBusinessPartnerId"><option value="">未归属</option>@foreach (var item in Model.LaborPartners) { <option value="@item.Id">@item.Name</option> }</select></label><label>管理员调整<input asp-for="WageInput.AdjustmentAmount" type="number" step="0.01" /></label><label>备注<textarea asp-for="WageInput.Notes"></textarea></label><button class="button button--primary" type="submit">保存工资段</button></form>
    }
}
</section>
