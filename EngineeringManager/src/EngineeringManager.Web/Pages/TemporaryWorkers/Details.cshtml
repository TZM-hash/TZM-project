@page
@model EngineeringManager.Web.Pages.TemporaryWorkers.DetailsModel
@{ ViewData["Title"] = "临时人员详情"; }
<section class="page-heading"><div><p class="eyebrow">临时人员</p><h1>@Model.Worker.Name</h1><p class="page-lead">历史金额只读展示，发现问题时跳转原工资批次统一修改。</p></div><a class="button button--secondary" asp-page="/TemporaryWorkers/Index">返回临时人员</a></section>
<section class="panel detail-grid"><div><span>身份证</span><strong>@(Model.Worker.IdentityNumber ?? "未填写")</strong></div><div><span>手机号</span><strong>@(Model.Worker.Phone ?? "未填写")</strong></div><div><span>工种</span><strong>@(Model.Worker.Trade ?? "未填写")</strong></div><div><span>历史发放合计</span><strong>@Model.Worker.TotalPaidAmount.ToString("N2")</strong></div></section>
<section class="panel" style="margin-top:var(--space-3)"><div class="panel-heading"><div><h2>历次发放记录</h2><p>点击查看来源批次可定位到该人员明细并由管理员修改。</p></div></div><div class="table-wrap"><table class="data-table"><thead><tr><th>日期</th><th>批次</th><th>项目</th><th>金额</th><th>备注</th><th>操作</th></tr></thead><tbody>@foreach (var item in Model.Worker.Payments) { <tr><td>@item.PaymentDate</td><td>@item.BatchNumber</td><td>@(item.ProjectName ?? "未归属")</td><td>@item.Amount.ToString("N2")</td><td>@item.Notes</td><td><a asp-page="/Payroll/Edit" asp-route-id="@item.PayrollBatchId" asp-route-lineId="@item.PayrollPaymentId" asp-route-returnUrl="@($"/TemporaryWorkers/Details?id={Model.Id}")">查看来源批次</a></td></tr> }</tbody></table></div></section>
@if (Model.CanManage && !Model.Worker.ConvertedEmployeeId.HasValue) { <section class="panel" style="margin-top:var(--space-3)"><h2>转为员工</h2><form method="post" asp-page-handler="Convert" class="form-grid"><select asp-for="EmployeeId">@foreach (var employee in Model.Employees) { <option value="@employee.Id">@employee.Label</option> }</select><input asp-for="ConversionReason" /><button class="button button--primary" type="submit">建立员工身份关联</button></form></section> }
