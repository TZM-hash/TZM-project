@page
@model EngineeringManager.Web.Pages.Companies.IndexModel
@{
    ViewData["Title"] = "自有公司";
    var dashboard = Model.Dashboard;
}

<div data-company-dashboard>
    <section class="page-heading">
        <div><p class="eyebrow">公司维度经营统计</p><h1>自有公司</h1><p class="page-lead">分别查看各公司合同、收付款、发票、工资、账户和项目数据，并在全公司口径汇总。</p></div>
        @if (Model.CanManage) { <a class="button button--primary" asp-page="Edit">新增公司</a> }
    </section>

    <form method="get" class="filter-bar">
        <label>统计范围
            <select asp-for="CompanyId">
                <option value="">全部自有公司</option>
                @foreach (var company in Model.Companies) { <option value="@company.Id">@company.Name</option> }
            </select>
        </label>
        <button class="button button--secondary" type="submit">查看</button>
    </form>

    <section class="metric-grid" aria-label="公司关键指标">
        <article class="metric-card"><span class="metric-label">公司数量</span><strong class="metric-value">@dashboard.CompanyCount</strong></article>
        <article class="metric-card"><span class="metric-label">合同金额</span><strong class="metric-value">@dashboard.ContractAmount.ToString("N2")</strong></article>
        <article class="metric-card"><span class="metric-label">未收款</span><strong class="metric-value">@((dashboard.ReceivableAmount - dashboard.CollectedAmount).ToString("N2"))</strong></article>
        <article class="metric-card"><span class="metric-label">账户余额</span><strong class="metric-value">@dashboard.AccountBalance.ToString("N2")</strong></article>
    </section>

    <section class="dashboard-grid">
        <article class="panel" data-company-money-chart>
            <div class="panel-heading"><div><p class="eyebrow">金额对比</p><h2>收款、付款与开票</h2></div></div>
            <div class="comparison-chart">
                <div class="comparison-row"><div class="chart-label"><strong>应收 / 已收</strong><span>@dashboard.ReceivableAmount.ToString("N2") / @dashboard.CollectedAmount.ToString("N2")</span></div></div>
                <div class="comparison-row"><div class="chart-label"><strong>应付 / 已付</strong><span>@dashboard.PayableAmount.ToString("N2") / @dashboard.PaidAmount.ToString("N2")</span></div></div>
                <div class="comparison-row"><div class="chart-label"><strong>销项 / 进项发票</strong><span>@dashboard.OutputInvoiceAmount.ToString("N2") / @dashboard.InputInvoiceAmount.ToString("N2")</span></div></div>
                <div class="comparison-row"><div class="chart-label"><strong>工资 / 设备成本</strong><span>@dashboard.PayrollCost.ToString("N2") / @dashboard.EquipmentCost.ToString("N2")</span></div></div>
            </div>
        </article>
        <article class="panel">
            <div class="panel-heading"><div><p class="eyebrow">公司档案</p><h2>公司列表</h2></div></div>
            <partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.Companies" />
            @if (Model.Companies.Count == 0) { <p class="panel-copy">当前权限范围内没有自有公司。</p> }
            else
            {
        <div class="table-wrap"><table class="data-table" id="companies-table"><thead><tr><th data-column-key="code">编码</th><th data-column-key="company">公司</th><th data-column-key="category">分类</th><th data-column-key="representative">法人/经营者</th><th data-column-key="status">状态</th><th data-column-key="actions">操作</th></tr></thead><tbody>
                @foreach (var company in Model.Companies)
                {
            <tr><td data-column-key="code">@company.Code</td><td data-column-key="company"><a asp-page="Details" asp-route-id="@company.Id">@company.Name</a></td><td data-column-key="category">@(company.CategoryName ?? "未分类")</td><td data-column-key="representative">@company.LegalRepresentative</td><td data-column-key="status">@(company.IsActive ? "启用" : "停用")</td><td data-column-key="actions"><a asp-page="Details" asp-route-id="@company.Id">查看</a>@if (Model.CanManage) { <span> · </span><a asp-page="Edit" asp-route-id="@company.Id">编辑</a><span> · </span><a asp-page="Edit" asp-route-copyFrom="@company.Id">复制</a> }<span> · </span><a asp-page="/Companies/Certificates/Index" asp-route-CompanyId="@company.Id">证书</a></td></tr>
                }
                </tbody></table></div>
            }
        </article>
    </section>
    <section class="panel chart-summary" data-chart data-chart-kind="progress-ring" data-chart-value="@(dashboard.ReceivableAmount == 0 ? 0 : dashboard.CollectedAmount / dashboard.ReceivableAmount * 100m)" data-chart-label="公司收款完成率"><div class="panel-heading"><div><p class="eyebrow">图形摘要</p><h2>公司收款完成率</h2></div></div><div data-chart-canvas></div></section>
    @if (Model.CanManage)
    {
        <section class="panel" data-company-categories>
            <div class="panel-heading"><div><p class="eyebrow">管理员字典</p><h2>组合分类维护</h2></div></div>
            <div class="table-wrap"><table><thead><tr><th>编码</th><th>分类名称</th><th>排序</th><th>状态</th></tr></thead><tbody>@foreach (var category in Model.Categories) { <tr><td>@category.Code</td><td>@category.Name</td><td>@category.SortOrder</td><td>@(category.IsActive ? "启用" : "停用")</td></tr> }</tbody></table></div>
            <form method="post" asp-page-handler="Category" class="filter-bar"><label>编码<input asp-for="Category.Code" required /></label><label>分类名称<input asp-for="Category.Name" required /></label><label>排序<input asp-for="Category.SortOrder" type="number" /></label><button class="button button--secondary" type="submit">新增分类</button></form>
        </section>
    }
</div>
