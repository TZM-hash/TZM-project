@page "{id:guid}"
@model EngineeringManager.Web.Pages.Companies.DetailsModel
@{ ViewData["Title"] = Model.Company.Name; }
<section class="page-heading"><div><p class="eyebrow">@Model.Company.Code · @(Model.Company.CompanyCategoryName ?? "未分类")</p><h1>@Model.Company.Name</h1><p class="page-lead">@Model.Company.ShortName · 法人/经营者：@(Model.Company.LegalRepresentative ?? "未填写")</p></div>@if (Model.CanManage) { <div class="button-row"><a class="button button--secondary" asp-page="Edit" asp-route-id="@Model.Company.Id">编辑</a><a class="button button--secondary" asp-page="Edit" asp-route-copyFrom="@Model.Company.Id">整条复制</a></div> }</section>
<section class="metric-grid"><article class="metric-card"><span class="metric-label">合同额</span><strong class="metric-value">@Model.Dashboard.ContractAmount.ToString("N2")</strong></article><article class="metric-card"><span class="metric-label">应收 / 已收</span><strong class="metric-value">@Model.Dashboard.ReceivableAmount.ToString("N2") / @Model.Dashboard.CollectedAmount.ToString("N2")</strong></article><article class="metric-card"><span class="metric-label">应付 / 已付</span><strong class="metric-value">@Model.Dashboard.PayableAmount.ToString("N2") / @Model.Dashboard.PaidAmount.ToString("N2")</strong></article><article class="metric-card"><span class="metric-label">账户余额</span><strong class="metric-value">@Model.Dashboard.AccountBalance.ToString("N2")</strong></article></section>
<section class="content-grid"><article class="panel"><div class="panel-heading"><h2>基础与开票资料</h2></div><dl class="detail-grid"><div><dt>税号</dt><dd>@(Model.Company.UnifiedSocialCreditCode ?? "未填写")</dd></div><div><dt>电话</dt><dd>@(Model.Company.Phone ?? "未填写")</dd></div><div><dt>注册地址</dt><dd>@(Model.Company.RegisteredAddress ?? "未填写")</dd></div><div><dt>经营地址</dt><dd>@(Model.Company.BusinessAddress ?? "未填写")</dd></div><div><dt>开票抬头</dt><dd>@(Model.Company.InvoiceTitle ?? "未填写")</dd></div></dl></article><article class="panel"><div class="panel-heading"><h2>账户与证照</h2></div><p class="panel-copy">账户 @Model.Company.Accounts.Count 个，证照 @Model.Company.Certificates.Count 项。</p><ul class="check-list">@foreach (var account in Model.Company.Accounts) { <li>@account.AccountName @if (account.IsDefaultCollection) { <span>· 默认收款</span> } @if (account.IsDefaultPayment) { <span>· 默认付款</span> } @if (account.IsDefaultInvoice) { <span>· 默认开票</span> }</li> } @foreach (var certificate in Model.Company.Certificates) { <li>@certificate.CertificateType · @(certificate.CertificateNumber ?? "未编号") · @(certificate.ExpiresOn?.ToString("yyyy-MM-dd") ?? "长期")</li> }</ul></article></section>
@if (Model.CanManage)
{
    <section class="content-grid"><article class="panel"><div class="panel-heading"><h2>新增公司账户</h2></div><form method="post" asp-page-handler="Account" class="form-stack"><label>账户名称<input asp-for="Account.Name" required /></label><label>账户类型<select asp-for="Account.AccountType"><option value="1">银行</option><option value="2">现金</option><option value="3">其他</option></select></label><label>账号<input asp-for="Account.Number" /></label><label>开户行<input asp-for="Account.BankName" /></label><label>期初余额<input asp-for="Account.OpeningBalance" /></label><label class="checkbox-row"><input asp-for="Account.DefaultCollection" />默认收款</label><label class="checkbox-row"><input asp-for="Account.DefaultPayment" />默认付款</label><label class="checkbox-row"><input asp-for="Account.DefaultInvoice" />默认开票</label><button class="button button--secondary" type="submit">保存账户</button></form></article><article class="panel"><div class="panel-heading"><h2>新增公司证照</h2></div><form method="post" asp-page-handler="Certificate" class="form-stack"><label>资料类型<input asp-for="Certificate.Type" required /></label><label>资料编号<input asp-for="Certificate.Number" /></label><label>签发日期<input asp-for="Certificate.IssuedOn" type="date" /></label><label>有效期<input asp-for="Certificate.ExpiresOn" type="date" /></label><label>备注<textarea asp-for="Certificate.Notes"></textarea></label><button class="button button--secondary" type="submit">保存证照</button></form></article></section>
}
