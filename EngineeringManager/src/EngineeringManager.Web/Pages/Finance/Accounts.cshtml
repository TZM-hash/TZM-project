@page
@model EngineeringManager.Web.Pages.Finance.AccountsModel
@{
    ViewData["Title"] = "资金账户";
}

<section class="page-heading"><div><p class="eyebrow">内部账户</p><h1>资金账户</h1><p class="page-lead">账户余额由期初余额和业务流水自动计算，收付款、退款、冲销和内部转账不会直接手改余额。</p></div><a class="button button--secondary" asp-page="/Finance/Index">返回台账</a></section>

<section class="panel">
    <div class="panel-heading"><div><p class="eyebrow">新建账户</p><h2>账户资料</h2></div></div>
    <div asp-validation-summary="All" class="panel-copy"></div>
    <form method="post" class="form-grid">
        <section class="form-section"><h3 class="section-heading">账户归属</h3><label>签约公司<select asp-for="LegalEntityId"><option value="">请选择</option>@foreach (var item in Model.LegalEntities) { <option value="@item.Id">@item.Label</option> }</select></label><label>账户名称<input asp-for="AccountName" /></label><label>账户类型<select asp-for="AccountType" asp-items="Html.GetEnumSelectList<EngineeringManager.Domain.Finance.FinancialAccountType>()"></select></label></section>
        <section class="form-section"><h3 class="section-heading">开户与期初数据</h3><label>期初余额<input asp-for="OpeningBalance" type="number" step="0.01" /></label><label>开户行<input asp-for="BankName" /></label><label>账号<input asp-for="AccountNumber" /></label></section>
        <div class="sticky-actions form-span"><button class="button button--secondary" type="submit">保存账户</button></div>
    </form>
</section>

<section class="panel page-section">
    <div class="panel-heading"><div><p class="eyebrow">账户清单</p><h2>当前余额</h2></div></div>
    <div class="table-wrap"><table class="data-table"><thead><tr><th>签约公司</th><th>账户</th><th>类型</th><th>期初余额</th><th>当前余额</th><th>状态</th></tr></thead><tbody>
    @foreach (var item in Model.Accounts)
    {
        <tr><td>@item.LegalEntityName</td><td>@item.AccountName</td><td>@item.AccountType</td><td>@item.OpeningBalance.ToString("N2")</td><td>@item.CurrentBalance.ToString("N2")</td><td>@(item.IsActive ? "启用" : "停用")</td></tr>
    }
    </tbody></table></div>
</section>
