@page
@model EngineeringManager.Web.Pages.Backups.IndexModel
@{
    ViewData["Title"] = "备份管理";
}
<section class="page-heading"><div><p class="eyebrow">数据安全</p><h1>备份与恢复</h1><p class="page-lead">设置备份与完整数据备份分开管理。备份包不加密，使用管理员授权、目标目录权限和 SHA-256 校验保障安全。</p></div><div class="button-row"><form method="post"><button class="button button--primary" type="submit">立即完整备份</button></form><form method="post" asp-page-handler="Settings"><button class="button button--secondary" type="submit">立即设置备份</button></form></div></section>

<section class="overview-strip backup-overview"><article class="is-accent"><span>完整备份</span><strong>@(Model.Tasks.FirstOrDefault(item => item.Kind == EngineeringManager.Application.Backups.BackupKind.Full)?.Status.ToString() ?? "暂无")</strong></article><article><span>设置备份</span><strong>@(Model.Tasks.FirstOrDefault(item => item.Kind == EngineeringManager.Application.Backups.BackupKind.Settings)?.Status.ToString() ?? "暂无")</strong></article><article><span>计划数量</span><strong>@Model.Schedules.Count</strong></article><article><span>最近失败</span><strong>@Model.Tasks.Count(item => item.Status == EngineeringManager.Domain.DataExchange.DataExchangeTaskStatus.Failed)</strong></article></section>

<section class="content-grid backup-workspace">
    <section class="panel" data-backup-settings><div class="panel-heading"><div><p class="eyebrow">设置备份</p><h2>轻量配置包</h2></div><span class="pill">可在线恢复设置</span></div><p class="panel-copy">包含组织、业务年度、分类、显示设置、用户基本资料、角色权限和备份策略，不包含密码、令牌、连接字符串、TLS 或服务器密钥。</p><form method="post" asp-page-handler="Settings"><button class="button button--secondary" type="submit">生成设置备份</button></form><form method="post" enctype="multipart/form-data" asp-page-handler="PreviewSettingsRestore" class="form-grid backup-restore-form"><label>设置备份包<input asp-for="SettingsRestoreFile" type="file" accept=".zip" /></label><button class="button button--ghost" type="submit">校验并预览恢复</button></form>@if (Model.SettingsPreview is not null) { <p class="panel-copy">版本 @Model.SettingsPreview.FormatVersion · 设置 @Model.SettingsPreview.SettingCount 项 · 用户 @Model.SettingsPreview.UserCount 个</p><form method="post" enctype="multipart/form-data" asp-page-handler="RestoreSettings" class="form-grid backup-restore-form"><label>再次选择已确认的设置包<input asp-for="SettingsRestoreFile" type="file" accept=".zip" /></label><button class="button button--primary" type="submit">确认恢复设置</button></form> }</section>
    <section class="panel" data-backup-full><div class="panel-heading"><div><p class="eyebrow">完整数据备份</p><h2>可迁移恢复包</h2></div><span class="pill">数据库 + 附件 + 清单</span></div><p class="panel-copy">包含 SQL Server 数据库、全部附件、设置快照、迁移版本、恢复说明和哈希清单。完整恢复由独立恢复工具执行。</p><form method="post"><button class="button button--primary" type="submit">生成完整备份</button></form></section>
</section>

<section class="panel backup-schedule-panel"><div class="panel-heading"><div><p class="eyebrow">定时策略</p><h2>设置备份与完整备份分别计划</h2></div></div><form method="post" asp-page-handler="SaveSchedule" class="form-grid"><label>备份类型<select asp-for="ScheduleKind" asp-items="Html.GetEnumSelectList<EngineeringManager.Application.Backups.BackupKind>()"></select></label><label class="check-label"><input asp-for="ScheduleEnabled" /> 启用</label><label>执行方式<select asp-for="ScheduleMode" asp-items="Html.GetEnumSelectList<EngineeringManager.Application.Backups.BackupScheduleMode>()"></select></label><label>间隔分钟<input asp-for="IntervalMinutes" type="number" min="1" /></label><label>固定时间<input asp-for="FixedTime" type="time" /></label><label>时区<input asp-for="TimeZoneId" /></label><label>本机目录<input asp-for="LocalTargetDirectory" /></label><label>NAS/共享目录<input asp-for="NasTargetDirectory" /></label><label>本机保留数量<input asp-for="LocalRetentionCount" type="number" min="1" /></label><label>NAS 保留数量<input asp-for="NasRetentionCount" type="number" min="0" /></label><label class="check-label"><input asp-for="AlertOnFailure" /> 失败提醒</label><div class="form-span"><button class="button button--secondary" type="submit">保存当前类型计划</button></div></form>@if (Model.Schedules.Count > 0) { <div class="table-wrap"><table class="data-table"><thead><tr><th>类型</th><th>状态</th><th>方式</th><th>下次执行</th><th>本机目标</th><th>NAS 目标</th></tr></thead><tbody>@foreach (var schedule in Model.Schedules) { <tr><td>@schedule.Kind</td><td>@(schedule.Enabled ? "启用" : "停用")</td><td>@schedule.Mode</td><td>@schedule.NextRunAt?.ToLocalTime()</td><td>@schedule.LocalTargetDirectory</td><td>@schedule.NasTargetDirectory</td></tr> }</tbody></table></div> }</section>

<section class="panel" data-backup-history><div class="panel-heading"><div><p class="eyebrow">任务历史</p><h2>备份记录与下载</h2></div></div><partial name="_DataWorkbench" model="EngineeringManager.Web.Workbenches.DataWorkbenchPresets.Backups" />@if (Model.Tasks.Count == 0) { <p class="panel-copy">暂无备份任务。</p><div hidden><table id="backups-table"><thead><tr><th data-column-key="created">时间</th></tr></thead></table></div> } else { <div class="table-wrap"><table class="data-table" id="backups-table"><thead><tr><th data-column-key="created">时间</th><th data-column-key="kind">类型</th><th data-column-key="status">状态</th><th data-column-key="local">本机</th><th data-column-key="nas">NAS</th><th data-column-key="hash">SHA-256</th><th data-column-key="actions">操作</th></tr></thead><tbody>@foreach (var item in Model.Tasks) { <tr><td data-column-key="created">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td><td data-column-key="kind">@item.Kind</td><td data-column-key="status">@item.Status</td><td data-column-key="local">@item.LocalStatus</td><td data-column-key="nas">@item.NasStatus</td><td data-column-key="hash"><code>@item.Sha256</code></td><td data-column-key="actions">@if (item.PackagePath is not null || item.DatabaseBackupPath is not null) { <a asp-page-handler="Download" asp-route-id="@item.Id">下载</a> }</td></tr> }</tbody></table></div> }</section>
