@page
@model EngineeringManager.Web.Pages.Finance.IndexModel
@{
    ViewData["Title"] = "内部经营台账";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">内部经营财务</p>
        <h1>经营台账</h1>
        <p class="page-lead">按项目汇总应收、实收、应付、实付和发票数据。这里用于把内账理清，不替代会计总账或法定报表。</p>
    </div>
    @if (User.IsInRole("SystemAdministrator") || User.IsInRole("ApplicationAdministrator") || User.IsInRole("Finance"))
    {
        <div>
            <a class="button button--secondary" asp-page="/Finance/Accounts">资金账户</a>
            <a class="button button--secondary" asp-page="/Finance/Entries/Create">录入业务</a>
        </div>
    }
</section>

<section class="metric-grid" aria-label="经营财务汇总">
    <article class="metric-card"><span class="metric-label">应收款</span><strong class="metric-value">@Model.Overview.Total.ReceivableAmount.ToString("N2")</strong><span class="metric-hint">独立经营应收记录</span></article>
    <article class="metric-card"><span class="metric-label">已收款</span><strong class="metric-value metric-value--good">@Model.Overview.Total.CollectedAmount.ToString("N2")</strong><span class="metric-hint">收款减退款/冲销</span></article>
    <article class="metric-card"><span class="metric-label">未收款</span><strong class="metric-value">@Model.Overview.Total.UncollectedAmount.ToString("N2")</strong><span class="metric-hint">应收减已收</span></article>
    <article class="metric-card"><span class="metric-label">未开票</span><strong class="metric-value">@Model.Overview.Total.UninvoicedAmount.ToString("N2")</strong><span class="metric-hint">应收减有效销项发票</span></article>
</section>

<section class="panel" style="margin-top: var(--space-3)">
    <div class="panel-heading"><div><p class="eyebrow">项目维度</p><h2>项目经营明细</h2></div></div>
    @if (Model.Overview.Projects.Count == 0)
    {
        <p class="panel-copy">当前还没有可汇总的项目。录入项目和财务业务后，这里会自动计算经营口径。</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead><tr><th>项目</th><th>应收</th><th>已收</th><th>未收</th><th>应付</th><th>已付</th><th>未付</th><th>已开票</th><th>未开票</th><th>风险</th></tr></thead>
                <tbody>
                @foreach (var item in Model.Overview.Projects)
                {
                    <tr>
                        <td>@item.ProjectNumber · @item.ProjectName</td>
                        <td>@item.Summary.ReceivableAmount.ToString("N2")</td>
                        <td>@item.Summary.CollectedAmount.ToString("N2")</td>
                        <td>@item.Summary.UncollectedAmount.ToString("N2")</td>
                        <td>@item.Summary.PayableAmount.ToString("N2")</td>
                        <td>@item.Summary.PaidAmount.ToString("N2")</td>
                        <td>@item.Summary.UnpaidAmount.ToString("N2")</td>
                        <td>@item.Summary.OutputInvoiceAmount.ToString("N2")</td>
                        <td>@item.Summary.UninvoicedAmount.ToString("N2")</td>
                        <td>@(item.Summary.HasCollectionRisk || item.Summary.HasPaymentRisk ? "超收/超付" : "正常")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
