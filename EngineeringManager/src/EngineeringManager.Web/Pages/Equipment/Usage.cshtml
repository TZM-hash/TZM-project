@page
@using EngineeringManager.Domain.Equipment
@model EngineeringManager.Web.Pages.Equipment.UsageModel
@{ ViewData["Title"] = "设备进退场"; }
<section class="page-heading"><div><p class="eyebrow">项目使用</p><h1>设备进退场</h1><p class="page-lead">进退场首尾均计入；详细施工/停工多段日期可在现场离线页持续维护。</p></div></section><form method="post" class="panel form-grid"><input asp-for="Input.EquipmentId" type="hidden" />
    <section class="form-section"><h2 class="section-heading">项目与日期</h2><label>项目 ID<input asp-for="Input.ProjectId" required /></label><label>签约公司 ID<input asp-for="Input.LegalEntityId" required /></label><label>进场日期<input asp-for="Input.EntryDate" type="date" /></label><label>退场日期<input asp-for="Input.ExitDate" type="date" /></label></section>
    <section class="form-section"><h2 class="section-heading">计租口径</h2><p class="section-help">一次使用记录保持一个基础单价，临时调价在结算调整项中处理。</p><label>计租方式<select asp-for="Input.RentMode" asp-items="Html.GetEnumSelectList<RentMode>()"></select></label><label>基础单价<input asp-for="Input.UnitRate" type="number" step="0.01" /></label><label class="form-span">原因<input asp-for="Input.Reason" /></label></section>
    <div class="sticky-actions form-span"><button class="button button--primary">保存使用记录</button></div>
</form>
