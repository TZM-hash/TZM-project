@page
@model EngineeringManager.Web.Pages.Partners.IndexModel
@using EngineeringManager.Domain.Partners
@using EngineeringManager.Web.Presentation
@using EngineeringManager.Web.Workbenches
@{
    ViewData["Title"] = "合作单位";
    var workbench = DataWorkbenchPresets.Partners with
    {
        InlineFilters = new DataWorkbenchFilterField[] { new("Search", "搜索", Model.Search, Placeholder: "搜索合作单位全部信息") }
    };
}

<section class="page-heading"><div><p class="eyebrow">统一档案</p><h1>合作单位</h1><p class="page-lead">同一家单位可以同时作为甲方/总包、施工班组、材料供应商或零星供应商。</p></div><a class="button button--secondary button--action" asp-page="/Partners/Create">新增合作单位</a></section>

<section class="panel">
    <div class="panel-heading"><div><p class="eyebrow">单位主档</p><h2>当前合作单位</h2><small>@(Model.CanManage ? "点击每行的“快捷编辑合作单位”，可直接在当前单元格修改常用字段。" : "查看合作单位及其项目参与情况。")</small></div></div>
    <partial name="_DataWorkbench" model="workbench" />
    @if (Model.CanManage) { <div asp-validation-summary="All" class="panel-copy"></div> }
    @if (Model.Partners.Count == 0) { <p class="panel-copy">还没有合作单位档案。</p> }
    <div class="table-wrap"><table class="data-table" id="partners-table"><thead><tr><th data-column-key="number">编号</th><th data-column-key="name">单位名称</th><th data-column-key="short_name">简称</th><th data-column-key="roles">角色</th><th data-column-key="trade">专业/类别</th><th data-column-key="contact">主要联系人</th><th data-column-key="phone">联系人电话</th><th data-column-key="projects">参与项目</th><th data-column-key="notes">备注摘要</th><th data-column-key="status">状态</th><th data-column-key="actions">操作</th></tr></thead><tbody>
    @foreach (var partner in Model.Partners)
    {
        var primaryRole = partner.Roles.FirstOrDefault();
        var primaryContact = partner.Contacts.FirstOrDefault(contact => contact.IsPrimary) ?? partner.Contacts.FirstOrDefault();
        var formId = $"partner-inline-{partner.Id:N}";
        var role = primaryRole?.RoleType ?? BusinessPartnerRoleType.ConstructionCrew;
        var activeEditor = Model.QuickEditOpen && Model.QuickEdit.Id == partner.Id;
        <tr class="inline-edit-shell" data-inline-edit="partner-@partner.Id" data-inline-cell-edit data-inline-edit-active="@(activeEditor ? "true" : "false")">
            <td data-column-key="number"><span data-inline-edit-value>@partner.PartnerNumber</span>@if (Model.CanManage) { <input class="inline-cell-control" name="QuickEdit.PartnerNumber" value="@partner.PartnerNumber" form="@formId" data-inline-edit-control hidden required /> }</td>
            <td data-column-key="name"><span data-inline-edit-value><a asp-page="/Partners/Details" asp-route-id="@partner.Id">@partner.Name</a></span>@if (Model.CanManage) { <input class="inline-cell-control" name="QuickEdit.Name" value="@partner.Name" form="@formId" data-inline-edit-control hidden required /> }</td>
            <td data-column-key="short_name"><span data-inline-edit-value>@partner.ShortName</span>@if (Model.CanManage) { <input class="inline-cell-control" name="QuickEdit.ShortName" value="@partner.ShortName" form="@formId" data-inline-edit-control hidden required /> }</td>
            <td data-column-key="roles"><span data-inline-edit-value>@string.Join("、", partner.Roles.Select(item => item.RoleType.ToChinese()))</span>@if (Model.CanManage) { <select class="inline-cell-control" name="QuickEdit.RoleType" form="@formId" data-inline-edit-control hidden>@foreach (var value in Enum.GetValues<BusinessPartnerRoleType>()) { <option value="@((int)value)" selected="@(value == role ? "selected" : null)">@value.ToChinese()</option> }</select> }</td>
            <td data-column-key="trade"><span data-inline-edit-value>@(primaryRole?.TradeCategory ?? "未填写")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="QuickEdit.TradeCategory" value="@primaryRole?.TradeCategory" form="@formId" data-inline-edit-control hidden /> }</td>
            <td data-column-key="contact"><span data-inline-edit-value>@(primaryContact?.Name ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="QuickEdit.ContactName" value="@primaryContact?.Name" form="@formId" data-inline-edit-control hidden /> }</td>
            <td data-column-key="phone"><span data-inline-edit-value>@(primaryContact?.Phone ?? "未设置")</span>@if (Model.CanManage) { <input class="inline-cell-control" name="QuickEdit.ContactPhone" value="@primaryContact?.Phone" form="@formId" data-inline-edit-control hidden /> }</td>
            <td data-column-key="projects">@partner.ProjectCount</td>
            <td data-column-key="notes">@(string.IsNullOrWhiteSpace(partner.Notes) ? "—" : partner.Notes.Length > 40 ? partner.Notes[..40] + "…" : partner.Notes)</td>
            <td data-column-key="status"><span data-inline-edit-value>@(partner.IsActive ? "启用" : "停用")</span>@if (Model.CanManage) { <select class="inline-cell-control" name="QuickEdit.IsActive" form="@formId" data-inline-edit-control hidden><option value="true" selected="@(partner.IsActive ? "selected" : null)">启用</option><option value="false" selected="@(!partner.IsActive ? "selected" : null)">停用</option></select> }</td>
            <td data-column-key="actions"><div class="table-action-buttons table-action-buttons--compact">@if (Model.CanManage) { <button class="button button--primary button--small button--action" type="button" data-inline-edit-open>快捷编辑合作单位</button> }<a class="button button--secondary button--small button--action" asp-page="/Partners/Create" asp-route-id="@partner.Id">详细编辑</a>@if (Model.CanManageFinance) { <a class="button button--secondary button--small button--action" asp-page="/Partners/Details" asp-route-id="@partner.Id">财务</a> }<a class="button button--text button--small" asp-page="/Partners/Create" asp-route-copyFrom="@partner.Id">复制</a>@if (Model.CanManage) { <button class="button button--secondary button--small button--action" type="button" data-inline-edit-cancel data-inline-edit-actions hidden>取消</button><button class="button button--primary button--small button--action" type="submit" form="@formId" data-inline-edit-actions hidden>保存</button><form id="@formId" method="post" asp-page-handler="QuickEdit"><input type="hidden" name="QuickEdit.Id" value="@partner.Id" /><input type="hidden" name="QuickEdit.UnifiedSocialCreditCode" value="@partner.UnifiedSocialCreditCode" /><input type="hidden" name="QuickEdit.Notes" value="@partner.Notes" /><input type="hidden" name="QuickEdit.ConcurrencyStamp" value="@partner.ConcurrencyStamp" /><input type="hidden" name="QuickEdit.Reason" value="快捷编辑合作单位" /></form> }</div></td>
        </tr>
    }
    </tbody></table></div>
</section>
